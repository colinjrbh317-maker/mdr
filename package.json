{
  "name": "mdr-astro-init",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "audit": "node audit-site.mjs",
    "verify": "astro check && playwright test && node audit-site.mjs",
    "verify:quick": "astro check && playwright test",
    "verify:sms": "node scripts/verify-acculynx-sms.mjs",
    "verify:contact": "node scripts/verify-contact-form.mjs",
    "audit:perf": "lighthouse http://localhost:4321 --output json --output-path .verify/lighthouse.json --chrome-flags=--headless --quiet",
    "audit:a11y": "axe http://localhost:4321 --save .verify/axe.json --exit",
    "audit:links": "linkinator http://localhost:4321 --recurse --skip 'mailto:|tel:'"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@astrojs/react": "^4.4.2",
    "@astrojs/sitemap": "^3.7.0",
    "@astrojs/vercel": "^9.0.4",
    "@sanity/astro": "^3.2.11",
    "@sanity/client": "^7.14.1",
    "@sanity/icons": "^3.7.0",
    "@sanity/image-url": "^2.0.3",
    "astro": "^5.17.1",
    "astro-portabletext": "^0.13.0",
    "dompurify": "^3.3.3",
    "framer-motion": "^12.34.1",
    "groq": "^5.24.0",
    "lodash": "^4.18.1",
    "lucide-react": "^0.574.0",
    "react": "^19.2.4",
    "react-compiler-runtime": "^1.0.0",
    "react-dom": "^19.2.4",
    "react-is": "^19.2.6",
    "sanity": "^5.24.0",
    "styled-components": "^6.4.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.1.18",
    "@types/dompurify": "^3.0.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.1.18"
  }
}
