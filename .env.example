PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=
SANITY_API_TOKEN=

# Google Sheets webhook URL (Google Apps Script deployed as web app)
# See docs/google-sheets-setup.md for setup instructions
FORM_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Analytics (leave empty to disable)
PUBLIC_GA4_ID=
PUBLIC_META_PIXEL_ID=
PUBLIC_HOTJAR_ID=5444251

# Google Ads (landing pages only). Format: AW-XXXXXXXXX
PUBLIC_GOOGLE_ADS_ID=
# Conversion send_to values. Format: AW-XXXXXXXXX/AbCdEfGhIjKlMnOpQ
PUBLIC_GOOGLE_ADS_LEAD_CONVERSION=
PUBLIC_GOOGLE_ADS_CALL_CONVERSION=

# PostHog — analytics + session replay + heatmaps + A/B testing + feature flags
# Get project API key: https://us.posthog.com/project/settings
PUBLIC_POSTHOG_KEY=
# Use Vercel reverse proxy in prod (see vercel.json /ingest rewrites) to survive ad blockers.
# Local dev can stay on direct host — set to https://us.i.posthog.com
PUBLIC_POSTHOG_HOST=https://moderndayroof.com/ingest

# CallRail dynamic number swap — also enables on the main site (not just LP).
# Get company ID from CallRail dashboard.
PUBLIC_CALLRAIL_ID=

# Resend (transactional email) — sends thank-you confirmation to leads after form submit.
# Get API key: https://resend.com/api-keys. If unset, email send is gracefully skipped.
RESEND_API_KEY=
LEAD_CONFIRMATION_FROM=Modern Day Roofing <hello@moderndayroof.com>
LEAD_CONFIRMATION_REPLY_TO=sales@moderndayroof.com
