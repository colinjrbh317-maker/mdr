# AccuLynx CRM
ACCULYNX_API_KEY=your_acculynx_api_key_here

# Anthropic (Claude API)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# Twilio (SMS) — gated off until A2P approval lands
TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+15405550000

# SendGrid (Email)
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=colin@socialtheorymedia.com
SENDGRID_FROM_NAME=Modern Day Roofing
SENDGRID_REPLY_SUBDOMAIN=reply.socialtheorymedia.com
# Optional: force a single Reply-To address for all sends. Leave blank to use per-lead sub-addressing.
REPLY_TO_OVERRIDE=

# Channel routing — comma-separated. Flip to "email,sms" once Twilio A2P is approved.
MESSAGING_CHANNELS=email

# Solo-sender mode — every approval routes to the default rep regardless of AccuLynx assignment.
# Flip to false after Austin onboards real reps in config/reps.yaml.
SOLO_SENDER_MODE=true

# Safety: when true, drafts are produced but no outbound mail is sent.
DRY_RUN=true

# Test allowlist — comma-separated AccuLynx job IDs that can receive real sends when DRY_RUN=false.
TEST_LEAD_ALLOWLIST=

# Escalation
ESCALATION_EMAIL=austin@moderndayroof.com

# Approval link signing — generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# Public URL for magic links and inbound webhooks. Set to Railway URL in prod.
APP_BASE_URL=http://localhost:8000
