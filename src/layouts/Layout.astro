---
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import { VisualEditing } from "@sanity/astro/visual-editing";
import { loadQuery } from "@/sanity/lib/load-query";
import { SITE_SETTINGS_QUERY, NAVIGATION_QUERY } from "@/sanity/lib/queries";
import GclidCapture from "@/components/common/GclidCapture.astro";
import ExitIntentPopup from "@/components/cro/ExitIntentPopup";
// ScrollPopup removed — less intrusive CRO approach preferred
import MobileRetentionPopup from "@/components/cro/MobileRetentionPopup";
import EngagementPopup from "@/components/cro/EngagementPopup";
import SocialProofToast from "@/components/cro/SocialProofToast";
import ChatWidget from "@/components/chat/ChatWidget";
import PostHog from "@/components/analytics/PostHog.astro";
// StickyMobileCTA removed — phone icon in header is sufficient
import "@/styles/global.css";

const isStudio = Astro.url.pathname.startsWith("/studio");

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "Modern Day Roofing — Southwest Virginia's trusted roofing contractor serving Christiansburg, Roanoke, and the New River Valley. GAF Master Elite certified. Free inspections.",
  ogImage,
} = Astro.props;

// Fetch global CMS data
const [siteSettings, navigation] = await Promise.all([
  loadQuery<any>(SITE_SETTINGS_QUERY).catch(() => null),
  loadQuery<any>(NAVIGATION_QUERY).catch(() => null),
]);

const companyName = siteSettings?.companyName || "Modern Day Roofing";
const phone = siteSettings?.phone || "5405536007";
const siteTitle = title.includes(companyName) ? title : `${title} | ${companyName}`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site || "https://moderndayroof.com");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{siteTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage || `${Astro.site || "https://moderndayroof.com"}og-default.png`} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage || `${Astro.site || "https://moderndayroof.com"}og-default.png`} />

    <!-- Organization + AggregateRating JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "RoofingContractor",
      "name": "Modern Day Roofing",
      "url": "https://moderndayroof.com",
      "telephone": "(540) 553-6007",
      "address": [
        {
          "@type": "PostalAddress",
          "streetAddress": "80 College St. STE R",
          "addressLocality": "Christiansburg",
          "addressRegion": "VA",
          "postalCode": "24073"
        },
        {
          "@type": "PostalAddress",
          "streetAddress": "2740 Franklin Rd SW",
          "addressLocality": "Roanoke",
          "addressRegion": "VA",
          "postalCode": "24014"
        }
      ],
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5.0",
        "reviewCount": "231",
        "bestRating": "5",
        "worstRating": "1"
      },
      "image": "https://moderndayroof.com/og-default.png",
      "priceRange": "$$",
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
        "opens": "08:30",
        "closes": "17:00"
      },
      "sameAs": [
        "https://www.facebook.com/moderndayroofing",
        "https://www.instagram.com/moderndayroofing",
        "https://www.linkedin.com/company/modern-day-roofing"
      ],
      "email": "sales@moderndayroof.com",
      "foundingDate": "2019"
    })} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
    <link rel="apple-touch-icon" sizes="150x150" href="/favicon-150x150.png" />

    <!-- Preconnect -->
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=DM+Sans:wght@400;500;600&display=swap" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet" />

    {/* GA4 */}
    {!isStudio && import.meta.env.PUBLIC_GA4_ID && (
      <>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${import.meta.env.PUBLIC_GA4_ID}`}></script>
        <script is:inline define:vars={{ gaId: import.meta.env.PUBLIC_GA4_ID }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', gaId);
        </script>
      </>
    )}

    {/* Meta Pixel */}
    {!isStudio && import.meta.env.PUBLIC_META_PIXEL_ID && (
      <script is:inline define:vars={{ pixelId: import.meta.env.PUBLIC_META_PIXEL_ID }}>
        !function(f,b,e,v,n,t,s)
        {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
        n.callMethod.apply(n,arguments):n.queue.push(arguments)};
        if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
        n.queue=[];t=b.createElement(e);t.async=!0;
        t.src=v;s=b.getElementsByTagName(e)[0];
        s.parentNode.insertBefore(t,s)}(window, document,'script',
        'https://connect.facebook.net/en_US/fbevents.js');
        fbq('init', pixelId);
        fbq('track', 'PageView');
      </script>
    )}

    {/* PostHog — analytics, session recording, heatmaps, feature flags, A/B tests */}
    {!isStudio && <PostHog />}
  </head>
  <body class="min-h-screen flex flex-col">
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <Header navigation={navigation} siteSettings={siteSettings} />

    <!-- Spacer for fixed header -->
    <div id="header-spacer" class="h-[100px]" aria-hidden="true"></div>

    <main id="main-content" class="flex-1">
      <slot />
    </main>

    <Footer siteSettings={siteSettings} />

    {/* Visual Editing overlays for Sanity Presentation Tool */}
    <VisualEditing enabled={import.meta.env.DEV} />

    <ExitIntentPopup client:idle currentPage={Astro.url.pathname} />
    {/* ScrollPopup removed — less intrusive CRO approach preferred */}
    <MobileRetentionPopup client:idle />
    <EngagementPopup client:idle />
    <SocialProofToast client:idle />
    <ChatWidget client:idle />
    {/* StickyMobileCTA removed — phone icon in header is sufficient */}

    <GclidCapture />

    {/* PostHog global click tracking — phone_click + quote_cta_click (delegated, survives hydration) */}
    {!isStudio && (
      <script is:inline>
        document.addEventListener('click', function(e) {
          var el = e.target && e.target.closest ? e.target.closest('a, button') : null;
          if (!el) return;
          var ph = window.posthog;
          if (!ph || !ph.capture) return;
          var href = el.getAttribute('href') || '';
          var text = (el.textContent || '').trim();
          if (href.indexOf('tel:') === 0) {
            ph.capture('phone_click', {
              number: href.replace('tel:', ''),
              location: el.dataset.ctaLocation || window.location.pathname,
              label: text.slice(0, 60)
            });
          } else if (el.dataset.cta === 'quote' || /free estimate|get.*(quote|estimate)|request.*quote/i.test(text)) {
            ph.capture('quote_cta_click', {
              location: window.location.pathname,
              label: text.slice(0, 60),
              href: href.slice(0, 120)
            });
          }
        }, { passive: true });
      </script>
    )}
  </body>
</html>
