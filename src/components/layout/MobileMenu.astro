---
import Button from "@/components/ui/Button.astro";

interface Props {
  navigation?: any;
  siteSettings?: any;
}

const { navigation, siteSettings } = Astro.props;

// Helper to resolve a navItem link object to an href string
function resolveLink(link: any): string {
  if (!link) return "#";
  if (link.linkType === "external" && link.externalUrl) return link.externalUrl;
  if (link.linkType === "internal" && link.internalLink) {
    const ref = link.internalLink;
    const slug = ref.slug;
    if (!slug) return "#";
    switch (ref._type) {
      case "page": return `/${slug}`;
      case "service": return `/services/${slug}`;
      case "serviceArea": return `/areas/${slug}`;
      case "blogPost": return `/blog/${slug}`;
      default: return `/${slug}`;
    }
  }
  return "#";
}

// Fallback hardcoded nav
const fallbackNavItems = [
  {
    label: "Services",
    href: "/services",
    children: [
      { label: "Roof Replacement", href: "/services/roof-replacement" },
      { label: "Shingle Roofing", href: "/services/shingle-roofing" },
      { label: "Metal Roofing", href: "/services/metal-roofing" },
      { label: "Timber Seal", href: "/services/timber-seal" },
      { label: "Roof Repair", href: "/services/roof-repair" },
      { label: "Maintenance", href: "/services/roof-maintenance" },
      { label: "Gutters", href: "/services/gutters" },
    ],
  },
  { label: "Financing", href: "/financing" },
  {
    label: "Education Hub",
    href: "/blog",
    children: [
      { label: "Blog", href: "/blog" },
      { label: "FAQ", href: "/faq" },
      { label: "Roofing Systems", href: "/roofing-systems" },
    ],
  },
  { label: "Storm Damage", href: "/services/storm-damage" },
  { label: "About Us", href: "/about" },
  { label: "Contact", href: "/contact" },
];

const navItems = navigation?.items?.length
  ? navigation.items.map((item: any) => ({
      label: item.label,
      href: resolveLink(item.link),
      children: item.children?.map((child: any) => ({
        label: child.label,
        href: resolveLink(child.link),
      })),
    }))
  : fallbackNavItems;

const phone = siteSettings?.phone || "(540) 553-6007";
const ctaText = navigation?.ctaText || "Get a Free Quote";
const ctaLink = navigation?.ctaLink || "/contact";
---

<div
  id="mobile-menu"
  class="fixed inset-0 z-50 hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Navigation menu"
>
  <!-- Backdrop -->
  <div id="mobile-menu-backdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>

  <!-- Drawer -->
  <div
    id="mobile-menu-drawer"
    class="absolute right-0 top-0 h-full w-[300px] max-w-[85vw] bg-bg-darker border-l border-border overflow-y-auto transform translate-x-full transition-transform duration-300 ease-out"
  >
    <!-- Close -->
    <div class="flex justify-end p-4">
      <button
        type="button"
        id="mobile-menu-close"
        class="p-2 text-text-muted hover:text-text-primary min-w-[48px] min-h-[48px] flex items-center justify-center"
        aria-label="Close menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <!-- Nav Items -->
    <nav class="px-4 pb-6" aria-label="Mobile navigation">
      <ul class="flex flex-col gap-1">
        {
          navItems.map((item: any) => (
            <li>
              <a
                href={item.href}
                class="block px-4 py-3 text-base font-medium text-text-muted hover:text-text-primary hover:bg-bg-card rounded-lg transition-colors min-h-[48px] flex items-center"
              >
                {item.label}
              </a>
              {item.children && (
                <ul class="pl-4">
                  {item.children.map((child: any) => (
                    <li>
                      <a
                        href={child.href}
                        class="block px-4 py-2.5 text-sm text-text-dim hover:text-text-primary hover:bg-bg-card rounded-lg transition-colors min-h-[44px] flex items-center"
                      >
                        {child.label}
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </li>
          ))
        }
      </ul>

      <!-- CTA -->
      <div class="mt-6 px-4 flex flex-col gap-3">
        <a
          href={`tel:${phone.replace(/[^0-9+]/g, "")}`}
          class="flex items-center justify-center gap-2 py-3 text-base font-semibold text-text-primary border border-border rounded-lg hover:bg-bg-card transition-colors min-h-[48px]"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
            />
          </svg>
          {phone}
        </a>
        <Button href={ctaLink} size="md" class="w-full">{ctaText}</Button>
      </div>
    </nav>
  </div>
</div>

<script>
  function initMobileMenu() {
    const toggle = document.getElementById("mobile-menu-toggle");
    const menu = document.getElementById("mobile-menu");
    const drawer = document.getElementById("mobile-menu-drawer");
    const close = document.getElementById("mobile-menu-close");
    const backdrop = document.getElementById("mobile-menu-backdrop");

    if (!toggle || !menu || !drawer || !close || !backdrop) return;

    let focusableElements: HTMLElement[] = [];
    let firstFocusable: HTMLElement | null = null;
    let lastFocusable: HTMLElement | null = null;

    function openMenu() {
      menu!.classList.remove("hidden");
      requestAnimationFrame(() => {
        drawer!.classList.remove("translate-x-full");
      });
      toggle!.setAttribute("aria-expanded", "true");
      document.body.style.overflow = "hidden";

      focusableElements = Array.from(
        drawer!.querySelectorAll<HTMLElement>(
          'a, button, input, [tabindex]:not([tabindex="-1"])'
        )
      );
      firstFocusable = focusableElements[0] || null;
      lastFocusable = focusableElements[focusableElements.length - 1] || null;
      close!.focus();
    }

    function closeMenu() {
      drawer!.classList.add("translate-x-full");
      toggle!.setAttribute("aria-expanded", "false");
      document.body.style.overflow = "";
      setTimeout(() => menu!.classList.add("hidden"), 300);
      toggle!.focus();
    }

    toggle.addEventListener("click", openMenu);
    close.addEventListener("click", closeMenu);
    backdrop.addEventListener("click", closeMenu);

    document.addEventListener("keydown", (e) => {
      if (!menu!.classList.contains("hidden")) {
        if (e.key === "Escape") {
          closeMenu();
        }
        if (e.key === "Tab" && focusableElements.length > 0) {
          if (e.shiftKey && document.activeElement === firstFocusable) {
            e.preventDefault();
            lastFocusable!.focus();
          } else if (!e.shiftKey && document.activeElement === lastFocusable) {
            e.preventDefault();
            firstFocusable!.focus();
          }
        }
      }
    });
  }

  initMobileMenu();
  document.addEventListener("astro:after-swap", initMobileMenu);
</script>
