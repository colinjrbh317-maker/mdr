---
import Logo from "@/components/common/Logo.astro";

interface Props {
  siteSettings?: any;
}

const { siteSettings } = Astro.props;

const currentYear = new Date().getFullYear();
const phone = siteSettings?.phone || "(540) 553-6007";
const email = siteSettings?.email || "info@moderndayroof.com";
const companyName = siteSettings?.companyName || "Modern Day Roofing";
const tagline = siteSettings?.tagline || "GAF Master Elite contractor serving Christiansburg, Roanoke, and the New River Valley. Built to protect. Backed for life.";

const companyLinks = [
  { label: "About Us", href: "/about" },
  { label: "Contact", href: "/contact" },
  { label: "Blog", href: "/blog" },
  { label: "FAQ", href: "/faq" },
  { label: "Financing", href: "/financing" },
  { label: "Roofing Systems", href: "/roofing-systems" },
];

const serviceLinks = [
  { label: "Roof Replacement", href: "/services/roof-replacement" },
  { label: "Shingle Roofing", href: "/services/shingle-roofing" },
  { label: "Metal Roofing", href: "/services/metal-roofing" },
  { label: "Roof Repair", href: "/services/roof-repair" },
  { label: "Gutters", href: "/services/gutters" },
  { label: "Maintenance", href: "/services/roof-maintenance" },
];

const areaLinks = [
  { label: "Christiansburg", href: "/areas/christiansburg" },
  { label: "Roanoke", href: "/areas/roanoke" },
  { label: "Blacksburg", href: "/areas/blacksburg" },
  { label: "Salem", href: "/areas/salem" },
  { label: "Radford", href: "/areas/radford" },
];
---

<footer class="bg-bg-darker border-t border-white/10" role="contentinfo">
  <div class="mx-auto max-w-[1200px] px-4 md:px-6 py-12 md:py-16">
    <!-- Top Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 md:gap-8">
      <!-- Company Info -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" aria-label={`${companyName} home`}>
          <Logo />
        </a>
        <p class="mt-4 text-sm text-gray-400 leading-relaxed">
          {tagline}
        </p>
        {/* Contact Info */}
        <div class="mt-4 flex flex-col gap-2">
          <a
            href={`tel:${phone.replace(/[^0-9+]/g, "")}`}
            class="text-sm font-semibold text-gray-300 hover:text-accent transition-colors"
          >
            {phone}
          </a>
          <a
            href={`mailto:${email}`}
            class="text-sm text-gray-400 hover:text-accent transition-colors"
          >
            {email}
          </a>
        </div>

        {/* Office Addresses */}
        <div class="mt-4 flex flex-col gap-3 text-xs text-gray-400">
          <div>
            <p class="font-semibold text-gray-300">Christiansburg Office</p>
            <p>80 College St. STE R<br/>Christiansburg, VA 24073</p>
          </div>
          <div>
            <p class="font-semibold text-gray-300">Roanoke Office</p>
            <p>4552 Franklin Rd SW STE 7<br/>Roanoke, VA 24014</p>
          </div>
        </div>

        {/* Hours */}
        <div class="mt-3 text-xs text-gray-400">
          <p class="font-semibold text-gray-300">Hours</p>
          <p>Mon – Fri: 8:30 AM – 5:00 PM</p>
          <p class="text-accent text-[11px] mt-1">24/7 Emergency Storm Damage Service</p>
        </div>

        {/* Social Links */}
        <div class="mt-4 flex items-center gap-3">
          <a href="https://www.facebook.com/ModernDayRoof" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="text-gray-400 hover:text-white transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="https://www.instagram.com/moderndayroofing" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="text-gray-400 hover:text-white transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="https://www.linkedin.com/company/modern-day-roofing" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="text-gray-400 hover:text-white transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="https://nextdoor.com/pages/modern-day-roofing" target="_blank" rel="noopener noreferrer" aria-label="Nextdoor" class="text-gray-400 hover:text-white transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm4.5 14.5h-3v-4.25c0-.69-.56-1.25-1.25-1.25s-1.25.56-1.25 1.25v4.25h-3V9h3v1.5c.56-.84 1.51-1.5 2.75-1.5 1.93 0 2.75 1.36 2.75 3.25v4.25z"/></svg>
          </a>
        </div>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white mb-4">
          Company
        </h3>
        <ul class="flex flex-col gap-2.5">
          {
            companyLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-gray-400 hover:text-white transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white mb-4">
          Services
        </h3>
        <ul class="flex flex-col gap-2.5">
          {
            serviceLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-gray-400 hover:text-white transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Service Areas -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white mb-4">
          Service Areas
        </h3>
        <ul class="flex flex-col gap-2.5">
          {
            areaLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-gray-400 hover:text-white transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div
      class="mt-12 pt-8 border-t border-white/10 flex flex-col md:flex-row items-center justify-between gap-4"
    >
      <p class="text-xs text-gray-500">
        &copy; {currentYear} {companyName}. All rights reserved.
      </p>
      <div class="flex items-center gap-4 text-xs text-gray-500">
        <a href="/privacy" class="hover:text-white transition-colors"
          >Privacy Policy</a
        >
        <a href="/terms" class="hover:text-white transition-colors"
          >Terms of Service</a
        >
        <a href="/sitemap-index.xml" class="hover:text-white transition-colors">Sitemap</a>
      </div>
    </div>
  </div>
</footer>
