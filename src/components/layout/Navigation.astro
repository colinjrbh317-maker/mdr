---
import Button from "@/components/ui/Button.astro";
import Logo from "@/components/common/Logo.astro";

interface Props {
  navigation?: any;
  siteSettings?: any;
}

const { navigation, siteSettings } = Astro.props;

// Helper to resolve a navItem link object to an href string
function resolveLink(link: any): string {
  if (!link) return "#";
  if (link.linkType === "external" && link.externalUrl) return link.externalUrl;
  if (link.linkType === "internal" && link.internalLink) {
    const ref = link.internalLink;
    const slug = ref.slug;
    if (!slug) return "#";
    switch (ref._type) {
      case "page": return `/${slug}`;
      case "service": return `/services/${slug}`;
      case "serviceArea": return `/areas/${slug}`;
      case "blogPost": return `/blog/${slug}`;
      default: return `/${slug}`;
    }
  }
  return "#";
}

// Fallback hardcoded nav
const fallbackNavItems = [
  {
    label: "Services",
    href: "/services",
    children: [
      { label: "Roof Replacement", href: "/services/roof-replacement" },
      { label: "Shingle Roofing", href: "/services/shingle-roofing" },
      { label: "Metal Roofing", href: "/services/metal-roofing" },
      { label: "Timber Seal", href: "/services/timber-seal" },
      { label: "Roof Repair", href: "/services/roof-repair" },
      { label: "Maintenance", href: "/services/roof-maintenance" },
      { label: "Gutters", href: "/services/gutters" },
    ],
  },
  { label: "Financing", href: "/financing" },
  {
    label: "Education Hub",
    href: "/blog",
    children: [
      { label: "Blog", href: "/blog" },
      { label: "FAQ", href: "/faq" },
      { label: "Roofing Systems", href: "/roofing-systems" },
    ],
  },
  { label: "Storm Damage", href: "/services/storm-damage" },
  { label: "About Us", href: "/about" },
  { label: "Contact", href: "/contact" },
];

// Build nav items from CMS or fall back to hardcoded
const navItems = navigation?.items?.length
  ? navigation.items.map((item: any) => ({
      label: item.label,
      href: resolveLink(item.link),
      openInNewTab: item.link?.openInNewTab,
      children: item.children?.map((child: any) => ({
        label: child.label,
        href: resolveLink(child.link),
        openInNewTab: child.link?.openInNewTab,
      })),
    }))
  : fallbackNavItems;

const phone = siteSettings?.phone || "(540) 553-6007";
const ctaText = navigation?.ctaText || "Get a Free Quote";
const ctaLink = navigation?.ctaLink || "/contact";
---

<nav class="flex items-center justify-between w-full" aria-label="Main navigation">
  <!-- Logo -->
  <a href="/" class="flex-shrink-0" aria-label="Modern Day Roofing home">
    <Logo />
  </a>

  <!-- Desktop Nav -->
  <ul class="hidden lg:flex items-center gap-1" role="menubar">
    {
      navItems.map((item: any) => (
        <li class="relative group" role="none">
          <a
            href={item.href}
            role="menuitem"
            class="px-3 py-2 text-sm font-medium transition-colors rounded-lg bg-transparent hover:bg-black/5"
            style="color: var(--nav-text);"
            aria-haspopup={item.children ? "true" : undefined}
            target={item.openInNewTab ? "_blank" : undefined}
            rel={item.openInNewTab ? "noopener noreferrer" : undefined}
          >
            {item.label}
            {item.children && (
              <svg
                class="inline-block w-3.5 h-3.5 ml-1 opacity-50"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M19 9l-7 7-7-7"
                />
              </svg>
            )}
          </a>
          {item.children && (
            <ul
              class="absolute left-0 top-full pt-2 hidden group-hover:block z-50"
              role="menu"
            >
              <li class="bg-bg-darker border border-white/10 rounded-xl shadow-xl py-2 min-w-[200px]">
                {item.children.map((child: any) => (
                  <a
                    href={child.href}
                    role="menuitem"
                    class="block px-4 py-2.5 text-sm text-text-on-dark-muted hover:text-text-on-dark hover:bg-white/10 transition-colors"
                    target={child.openInNewTab ? "_blank" : undefined}
                    rel={child.openInNewTab ? "noopener noreferrer" : undefined}
                  >
                    {child.label}
                  </a>
                ))}
              </li>
            </ul>
          )}
        </li>
      ))
    }
  </ul>

  <!-- Desktop Right: Phone + CTA -->
  <div class="hidden lg:flex items-center gap-4">
    <a
      href={`tel:${phone.replace(/[^0-9+]/g, "")}`}
      class="text-sm font-semibold transition-colors"
      style="color: var(--nav-text)"
    >
      {phone}
    </a>
    <Button href={ctaLink} size="sm">{ctaText}</Button>
  </div>

  <!-- Mobile: Configured to look like Erie Home (Logo | Actions | Hamburger) -->
  <div class="flex lg:hidden items-center gap-3">
    
    {/* 1. Phone Icon (Icon Only to save space) */}
    <a
      href={`tel:${phone.replace(/[^0-9+]/g, "")}`}
      class="p-2 w-11 h-11 flex items-center justify-center rounded-full bg-bg-light text-text-primary border border-border transition-colors hover:bg-gray-100"
      aria-label="Call us"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
      </svg>
    </a>

    {/* 2. Primary CTA "Get Estimate" - Always visible on sticky header */}
    <a
      href={ctaLink}
      class="bg-accent text-white hover:bg-accent-dark px-4 py-2.5 min-h-[44px] flex items-center justify-center rounded-md text-xs font-bold uppercase tracking-wide shadow-sm transition-colors"
    >
      Get Estimate
    </a>

    {/* 3. Hamburger Menu Trigger */}
    <button
      type="button"
      id="mobile-menu-toggle"
      class="p-2 min-w-[44px] min-h-[44px] flex items-center justify-center transition-colors"
      style="color: var(--nav-text)"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </div>
  <!-- Mobile Menu Drawer (Erie Style) -->
  <div
    id="mobile-menu"
    class="fixed inset-0 z-50 transform translate-x-full transition-transform duration-300 lg:hidden"
    aria-hidden="true"
  >
    {/* Backdrop */}
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm transition-opacity opacity-0" id="mobile-menu-backdrop"></div>
    
    {/* Drawer Content */}
    <div class="absolute right-0 top-0 bottom-0 w-[85%] max-w-[320px] bg-white shadow-2xl flex flex-col h-full transform transition-transform duration-300 translate-x-full" id="mobile-menu-content">
      
      {/* Drawer Header */}
      <div class="flex items-center justify-between p-4 border-b border-border-light bg-bg-light">
        <span class="font-display font-bold text-lg text-text-primary uppercase tracking-wider">
          Menu
        </span>
        <button
          type="button"
          id="mobile-menu-close"
          class="p-2 text-text-muted hover:text-accent transition-colors"
          aria-label="Close menu"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      {/* Primary Actions (Erie Style - Top of Drawer) */}
      <div class="p-4 space-y-3 bg-white border-b border-border-light">
        <Button href="/contact" size="lg" class="w-full justify-center shadow-md">
          Get Free Estimate
        </Button>
        <a 
          href={`tel:${phone.replace(/[^0-9+]/g, "")}`}
          class="flex items-center justify-center gap-2 w-full py-3 px-4 rounded-lg border-2 border-accent text-accent font-bold hover:bg-accent hover:text-white transition-all duration-300"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Call {phone}
        </a>
      </div>

      {/* Navigation Links */}
      <div class="flex-1 overflow-y-auto py-2">
        <ul class="space-y-1 p-2">
          {navItems.map((item: any) => (
            <li>
              {item.children ? (
                <details class="group/mobile-sub">
                  <summary class="flex items-center justify-between px-4 py-3 text-text-primary font-medium hover:bg-bg-light rounded-lg cursor-pointer select-none">
                    {item.label}
                    <svg class="w-4 h-4 text-text-muted transition-transform group-open/mobile-sub:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                  </summary>
                  <ul class="pl-4 pr-2 pb-2 space-y-1 bg-bg-light/50 rounded-b-lg">
                    {item.children.map((child: any) => (
                      <li>
                        <a
                          href={child.href}
                          class="block px-4 py-2.5 text-sm text-text-body hover:text-accent hover:bg-white rounded-md transition-colors"
                        >
                          {child.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                </details>
              ) : (
                <a
                  href={item.href}
                  class="block px-4 py-3 text-text-primary font-medium hover:bg-bg-light rounded-lg transition-colors"
                >
                  {item.label}
                </a>
              )}
            </li>
          ))}
        </ul>
      </div>

      {/* Drawer Footer */}
      <div class="p-6 border-t border-border-light bg-bg-light text-center flex flex-col items-center">
        {/* Social Links */}
        <div class="flex items-center justify-center gap-4 mb-4">
          <a href="https://www.facebook.com/ModernDayRoof" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="text-text-muted hover:text-accent transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="https://www.instagram.com/moderndayroofing" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="text-text-muted hover:text-accent transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="https://www.linkedin.com/company/modern-day-roofing" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="text-text-muted hover:text-accent transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="https://nextdoor.com/pages/modern-day-roofing" target="_blank" rel="noopener noreferrer" aria-label="Nextdoor" class="text-text-muted hover:text-accent transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm4.5 14.5h-3v-4.25c0-.69-.56-1.25-1.25-1.25s-1.25.56-1.25 1.25v4.25h-3V9h3v1.5c.56-.84 1.51-1.5 2.75-1.5 1.93 0 2.75 1.36 2.75 3.25v4.25z"/></svg>
          </a>
        </div>
        <p class="text-[11px] text-text-muted">
          &copy; {new Date().getFullYear()} Modern Day Roofing. All rights reserved.
        </p>
      </div>

    </div>
  </div>
</nav>

<script>
  const menu = document.getElementById("mobile-menu");
  const menuContent = document.getElementById("mobile-menu-content");
  const backdrop = document.getElementById("mobile-menu-backdrop");
  const toggle = document.getElementById("mobile-menu-toggle");
  const closeBtn = document.getElementById("mobile-menu-close");

  function toggleMenu() {
    const isExpanded = toggle?.getAttribute("aria-expanded") === "true";
    toggle?.setAttribute("aria-expanded", (!isExpanded).toString());
    
    if (!isExpanded) {
      // Open
      menu?.classList.remove("translate-x-full");
      setTimeout(() => {
          backdrop?.classList.remove("opacity-0");
          menuContent?.classList.remove("translate-x-full");
      }, 10);
      document.body.style.overflow = "hidden";
    } else {
      // Close
      backdrop?.classList.add("opacity-0");
      menuContent?.classList.add("translate-x-full");
      setTimeout(() => {
        menu?.classList.add("translate-x-full");
        document.body.style.overflow = "";
      }, 300);
    }
  }

  toggle?.addEventListener("click", toggleMenu);
  closeBtn?.addEventListener("click", toggleMenu);
  backdrop?.addEventListener("click", toggleMenu);
</script>
