---
import Button from "@/components/ui/Button.astro";
import Logo from "@/components/common/Logo.astro";

const navItems = [
  {
    label: "Services",
    href: "/services",
    children: [
      { label: "Roof Replacement", href: "/services/roof-replacement" },
      { label: "Shingle Roofing", href: "/services/shingle-roofing" },
      { label: "Metal Roofing", href: "/services/metal-roofing" },
      { label: "Timber Seal", href: "/services/timber-seal" },
      { label: "Roof Repair", href: "/services/roof-repair" },
      { label: "Maintenance", href: "/services/maintenance" },
      { label: "Gutters", href: "/services/gutters" },
    ],
  },
  { label: "Financing", href: "/financing" },
  {
    label: "Education Hub",
    href: "/blog",
    children: [
      { label: "Blog", href: "/blog" },
      { label: "FAQ", href: "/faq" },
      { label: "Roofing System", href: "/roofing-system" },
    ],
  },
  { label: "Storm Damage", href: "/storm-damage" },
  { label: "About Us", href: "/about" },
  { label: "Contact", href: "/contact" },
];

const phone = "(540) 204-5597";
---

<nav class="flex items-center justify-between w-full" aria-label="Main navigation">
  <!-- Logo -->
  <a href="/" class="flex-shrink-0" aria-label="Modern Day Roofing home">
    <Logo />
  </a>

  <!-- Desktop Nav -->
  <ul class="hidden lg:flex items-center gap-1" role="menubar">
    {
      navItems.map((item) => (
        <li class="relative group" role="none">
          <a
            href={item.href}
            role="menuitem"
            class="px-3 py-2 text-sm font-medium text-text-muted hover:text-text-primary transition-colors rounded-lg hover:bg-bg-card"
            aria-haspopup={item.children ? "true" : undefined}
          >
            {item.label}
            {item.children && (
              <svg
                class="inline-block w-3.5 h-3.5 ml-1 opacity-50"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M19 9l-7 7-7-7"
                />
              </svg>
            )}
          </a>
          {item.children && (
            <ul
              class="absolute left-0 top-full pt-2 hidden group-hover:block z-50"
              role="menu"
            >
              <li class="bg-bg-card border border-border rounded-xl shadow-xl py-2 min-w-[200px]">
                {item.children.map((child) => (
                  <a
                    href={child.href}
                    role="menuitem"
                    class="block px-4 py-2.5 text-sm text-text-muted hover:text-text-primary hover:bg-bg-card-hover transition-colors"
                  >
                    {child.label}
                  </a>
                ))}
              </li>
            </ul>
          )}
        </li>
      ))
    }
  </ul>

  <!-- Desktop Right: Phone + CTA -->
  <div class="hidden lg:flex items-center gap-4">
    <a
      href={`tel:${phone.replace(/[^0-9+]/g, "")}`}
      class="text-sm font-semibold text-text-muted hover:text-text-primary transition-colors"
    >
      {phone}
    </a>
    <Button href="/contact" size="sm">Get a Free Quote</Button>
  </div>

  <!-- Mobile: Phone + Hamburger -->
  <div class="flex lg:hidden items-center gap-3">
    <a
      href={`tel:${phone.replace(/[^0-9+]/g, "")}`}
      class="p-2 text-text-muted hover:text-text-primary"
      aria-label="Call us"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
        ></path>
      </svg>
    </a>
    <button
      type="button"
      id="mobile-menu-toggle"
      class="p-2 text-text-muted hover:text-text-primary min-w-[48px] min-h-[48px] flex items-center justify-center"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </div>
</nav>
