---
import Navigation from "./Navigation.astro";
import MobileMenu from "./MobileMenu.astro";

interface Props {
  navigation?: any;
  siteSettings?: any;
}

const { navigation, siteSettings } = Astro.props;
---

<!-- Announcement Bar -->
<div id="announcement-bar" class="bg-accent text-white text-center text-xs py-2 px-4 hidden lg:block">
  <span>GAF Master Elite® Contractor — Virginia's most certified roofing team. </span>
  <a href="/financing" class="underline font-semibold hover:text-white/80 transition-colors">Explore Financing Options →</a>
</div>

<header
  id="site-header"
  class="fixed left-0 right-0 z-40 bg-white shadow-sm border-b border-border"
  style="--nav-text: var(--color-text-primary); top: 0;"
>
  <div class="mx-auto max-w-[1400px] px-4 md:px-6 py-3">
    <Navigation navigation={navigation} siteSettings={siteSettings} />
  </div>
</header>

<MobileMenu navigation={navigation} siteSettings={siteSettings} />

<script>
  function initHeader() {
    const header = document.getElementById("site-header");
    if (!header) return;

    // Only pages with a dark hero opt in to transparent header behavior
    const hasTransparentHero = document.querySelector('[data-transparent-header]') !== null;

    const applyState = (transparent: boolean) => {
      if (transparent) {
        header.style.setProperty('--nav-text', 'var(--color-text-on-dark)');
        header.style.backgroundColor = 'transparent';
        header.style.boxShadow = 'none';
        header.style.borderBottomColor = 'transparent';
        header.dataset.scrolled = "false";
      } else {
        header.style.setProperty('--nav-text', 'var(--color-text-primary)');
        header.style.backgroundColor = '';
        header.style.boxShadow = '';
        header.style.borderBottomColor = '';
        header.dataset.scrolled = "true";
      }
    };

    const handleScroll = () => {
      const currentScroll = window.scrollY;
      const isMobile = window.innerWidth < 1024;
      const shouldBeTransparent = hasTransparentHero && !isMobile && currentScroll <= 50;
      applyState(shouldBeTransparent);
    };

    window.addEventListener("scroll", handleScroll, { passive: true });
    window.addEventListener("resize", handleScroll, { passive: true });

    // Set initial state INSTANTLY (no CSS transition) to prevent white-flash
    header.style.transition = 'none';
    handleScroll();
    // Re-enable smooth transitions for scroll events only after paint
    requestAnimationFrame(() => requestAnimationFrame(() => {
      header.style.transition = 'background-color 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease';
    }));
  }

  initHeader();
  document.addEventListener("astro:after-swap", initHeader);
</script>
