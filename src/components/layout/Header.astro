---
import Navigation from "./Navigation.astro";
// MobileMenu is now integrated directly into Navigation.astro (Erie style)
import AnnouncementBar from "./AnnouncementBar.astro";

interface Props {
  navigation?: any;
  siteSettings?: any;
}

const { navigation, siteSettings } = Astro.props;
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-40 bg-white border-b border-border shadow-sm"
  style="--nav-text: var(--color-text-primary);"
  data-scrolled="true"
>
  <AnnouncementBar />

  <!-- Nav -->
  <div class="mx-auto max-w-[1400px] px-3 md:px-6 py-3">
    <Navigation navigation={navigation} siteSettings={siteSettings} />
  </div>
</header>
