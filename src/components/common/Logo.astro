---
interface Props {
  class?: string;
  size?: "sm" | "md" | "lg";
}

const { class: className = "", size = "md" } = Astro.props;

const heights: Record<string, string> = {
  sm: "h-8",
  md: "h-10",
  lg: "h-14",
};
---

<div class={`flex items-center ${className}`}>
  <img
    src="/assets/web/logo-horizontal.png"
    alt="Modern Day Roofing"
    class={`${heights[size]} w-auto header-logo transition-all duration-300`}
    loading="eager"
  />
</div>

<style>
  /* When header is transparent (dark hero), invert logo to white */
  :global(#site-header[data-scrolled="false"]) .header-logo {
    filter: brightness(0) invert(1);
  }
</style>
