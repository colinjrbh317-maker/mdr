---
interface Props {
  class?: string;
  size?: "sm" | "md" | "lg";
}

const { class: className = "", size = "md" } = Astro.props;

const heights: Record<string, string> = {
  sm: "h-10",
  md: "h-14",
  lg: "h-16",
};
---

<div class={`flex items-center ${className}`}>
  <img
    src="/assets/web/logo-full.png"
    alt="Modern Day Roofing"
    class={`${heights[size]} w-auto header-logo`}
    loading="eager"
  />
</div>

<style>
  /* Logo keeps its original colors in all header states */
</style>
