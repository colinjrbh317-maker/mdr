---
interface Props {
  width?: string;
  height?: string;
  aspectRatio?: string;
  description: string;
  class?: string;
}

const {
  width,
  height,
  aspectRatio,
  description,
  class: className = "",
} = Astro.props;

const style = [
  width ? `width: ${width}` : "",
  height ? `height: ${height}` : "",
  aspectRatio ? `aspect-ratio: ${aspectRatio}` : "",
]
  .filter(Boolean)
  .join("; ");
---

<div
  class={`flex items-center justify-center bg-bg-card border border-dashed border-border-light rounded-lg overflow-hidden ${className}`}
  style={style}
  role="img"
  aria-label={description}
>
  <div class="text-center p-4">
    <svg
      class="w-8 h-8 mx-auto mb-2 text-text-dim opacity-40"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="1.5"
        d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
      ></path>
    </svg>
    <p class="text-xs text-text-dim">{description}</p>
  </div>
</div>
