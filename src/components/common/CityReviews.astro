---
/**
 * City-specific Google reviews block, styled to match the homepage
 * GoogleReviews component but filtered to the current city.
 *
 * If the city has fewer than `min` exact-match reviews, the block
 * supplements with reviews from nearby cities so the page never
 * looks empty. Exact matches always render first.
 */
import { reviewsForCityWithFallback } from "@/data/reviews";

interface Props {
  city: string;
  /** Max review cards to render. Default 6. */
  count?: number;
  /** Section heading override. Default "What {city} homeowners are saying". */
  heading?: string;
}

const { city, count = 6, heading } = Astro.props;
const cityReviews = reviewsForCityWithFallback(city, count, 3);
const exactCount = cityReviews.filter((r) => r.city.toLowerCase() === city.toLowerCase()).length;
const hasNearby = cityReviews.length > exactCount;

// JSON-LD Review schema for the top 3 cards. Adding individual Review
// nodes (not just AggregateRating) is what triggers the star-rating
// rich snippet under city-page results in Google SERPs. Significant
// CTR lift when it lands.
const topReviewsSchema = cityReviews.slice(0, 3).map((r) => ({
  "@type": "Review",
  reviewRating: { "@type": "Rating", ratingValue: r.rating, bestRating: 5 },
  author: { "@type": "Person", name: r.name },
  reviewBody: r.quote,
  itemReviewed: { "@type": "RoofingContractor", name: `Modern Day Roofing - ${city}` },
}));

const reviewsBlockSchema = {
  "@context": "https://schema.org",
  "@type": "RoofingContractor",
  name: `Modern Day Roofing - ${city}`,
  url: `https://moderndayroof.com/areas/${city.toLowerCase().replace(/ /g, "-")}`,
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: "5.0",
    reviewCount: 240,
    bestRating: 5,
    worstRating: 1,
  },
  review: topReviewsSchema,
};
---

<script type="application/ld+json" set:html={JSON.stringify(reviewsBlockSchema)} />

<section class="py-14 md:py-20 bg-bg-light">
  <div class="mx-auto max-w-[1200px] px-4 md:px-6">
    {/* Header */}
    <div class="text-center mb-10">
      <h2 class="text-3xl md:text-4xl font-display font-bold text-text-primary mb-4">
        {heading || `What ${city} Homeowners Are Saying`}
      </h2>

      {/* Overall Rating */}
      <div class="flex flex-wrap items-center justify-center gap-3 mb-3">
        <svg class="w-7 h-7 flex-shrink-0" viewBox="0 0 24 24" fill="none">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4" />
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853" />
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05" />
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335" />
        </svg>
        <span class="text-3xl font-bold text-text-primary">5.0</span>
        <div class="flex gap-0.5">
          {[1, 2, 3, 4, 5].map(() => (
            <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </div>
        <span class="text-text-muted text-sm">240+ reviews on Google</span>
      </div>

      {hasNearby && (
        <p class="text-text-muted text-sm">
          Showing {exactCount} review{exactCount === 1 ? "" : "s"} from {city} plus recent reviews from across the New River Valley and Roanoke area.
        </p>
      )}
    </div>

    {/* Review Cards Grid */}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {cityReviews.map((review) => (
        <div class="bg-white rounded-xl p-5 shadow-sm border border-border flex flex-col">
          {/* Reviewer Header */}
          <div class="flex items-center gap-3 mb-3">
            <div class={`w-9 h-9 rounded-full ${review.color} flex items-center justify-center text-white font-semibold text-xs flex-shrink-0`}>
              {review.initials}
            </div>
            <div class="flex-1 min-w-0">
              <p class="font-semibold text-text-primary text-sm leading-tight">{review.name}</p>
              <p class="text-xs text-text-dim">
                {review.city === "Service Area" ? review.date : `${review.city}, VA · ${review.date}`}
              </p>
            </div>
            <svg class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24" fill="none">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4" />
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853" />
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05" />
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335" />
            </svg>
          </div>

          {/* Stars */}
          <div class="flex gap-0.5 mb-2">
            {Array.from({ length: review.rating }).map(() => (
              <svg class="w-3.5 h-3.5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          {/* Quote */}
          <p class="text-text-body text-sm leading-relaxed flex-1">
            {review.quote}
          </p>
        </div>
      ))}
    </div>

    {/* Read All Reviews */}
    <div class="text-center mt-8">
      <a
        href="https://www.google.com/maps?q=place_id:ChIJF1B6XsCTTYgRhBfUE2iAeoI"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-accent font-semibold text-sm hover:underline transition-colors"
      >
        Read All 240+ Reviews on Google
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    </div>
  </div>
</section>
