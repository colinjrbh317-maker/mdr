---
import ServiceGrid from './ServiceGrid';
import BeforeAfter from './BeforeAfter';
import SectionContainer from '@/components/ui/SectionContainer.astro';
import Button from '@/components/ui/Button.astro';

// Real before/after pair from Alicia's Drive — Heritage shingle replacement
const beforeImg = "/assets/drive/mdr-before-heritage.jpg";
const afterImg = "/assets/drive/mdr-after-heritage.jpg";
---

{/* Services Section */}
<SectionContainer background="white" padding="lg">
  <div class="text-center mb-16">
    <p class="text-accent font-semibold text-sm uppercase tracking-wider mb-2">
      The Full GAF System. Installed Right.
    </p>
    <h2 class="text-3xl md:text-5xl font-display font-bold text-text-primary">
      Every Layer. Every Detail. Every Time.
    </h2>
    <p class="mt-4 text-text-muted max-w-2xl mx-auto text-lg">
      A roof is a system — starter strips, underlayment, ventilation, shingles, ridge caps. We install the full GAF system so nothing gets missed.
    </p>
  </div>
  
  <ServiceGrid client:visible />
  
  <div class="text-center mt-12">
    <Button href="/services" variant="outline" size="lg">
      View All Services
    </Button>
  </div>
</SectionContainer>

{/* Before/After Section */}
<SectionContainer background="dark" padding="none">
    <div class="grid grid-cols-1 md:grid-cols-2">
        {/* Content Side */}
        <div class="p-8 md:p-20 flex flex-col justify-center bg-bg-darker text-white">
            <p class="text-accent font-semibold text-sm uppercase tracking-wider mb-4">
                Real Results
            </p>
            <h2 class="text-3xl md:text-5xl font-display font-bold mb-6">
                See The Transformation.
            </h2>
            <p class="text-white/90 text-lg mb-8 leading-relaxed">
                From aging shingles to a complete transformation — slide to see what GAF Master Elite craftsmanship looks like on a real home in the New River Valley.
            </p>
            <div>
              <a href="/gallery" class="inline-flex items-center justify-center px-6 py-3 text-base font-semibold rounded-lg bg-white text-bg-darker hover:bg-gray-100 shadow-lg transition-all min-h-[48px]">
                View Project Gallery
                <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
              </a>
            </div>
        </div>

        {/* Interactive Side */}
        <div class="relative h-[400px] md:h-auto min-h-[500px]">
             <div class="absolute inset-0">
                <BeforeAfter client:visible beforeImage={beforeImg} afterImage={afterImg} />
             </div>
        </div>
    </div>
</SectionContainer>
