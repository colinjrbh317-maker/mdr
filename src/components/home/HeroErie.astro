---
import HeroBackground from './HeroBackground';
import LeadCaptureForm from '@/components/forms/LeadCaptureForm';

const heroVideoUrl = "";
const heroPosterUrl = "/assets/hero/hero-main.jpg";
---

<section class="relative min-h-screen md:min-h-[700px] md:h-[90vh] flex flex-col md:block" data-transparent-header>

  {/* Background Image/Video — full bleed on desktop, half on mobile */}
  <div class="relative w-full h-[45vh] md:absolute md:inset-0 md:h-full z-0 overflow-hidden">
    <HeroBackground client:load videoUrl={heroVideoUrl} posterUrl={heroPosterUrl} />
  </div>

  {/* Mobile: headline overlay on the image */}
  <div class="absolute top-0 left-0 right-0 h-[45vh] z-10 flex items-end md:hidden pointer-events-none">
    <div class="p-6 pb-8 w-full bg-gradient-to-t from-black/80 via-black/40 to-transparent">
      <p class="text-[10px] font-bold text-accent uppercase tracking-[0.15em] mb-2 inline-block bg-white/90 backdrop-blur-sm px-2.5 py-1 rounded">
        GAF Master Elite® Contractor | President's Club 2026
      </p>
      <h1 class="text-3xl font-display font-bold text-white leading-[1.08]">
        Don't Wait for the Leak.<br />
        <span class="text-white">Get Ahead of It.</span>
      </h1>
    </div>
  </div>

  {/* Desktop: Two-column layout */}
  <div class="relative z-10 w-full flex-1 bg-white md:bg-transparent flex items-center md:h-full">
    <div class="w-full max-w-[1280px] mx-auto px-4 md:px-6">

      <div class="md:grid md:grid-cols-12 md:gap-8 md:items-center">

        {/* Left Column — Headline + Trust (desktop only) */}
        <div class="hidden md:block md:col-span-6 lg:col-span-7 animate-fade-in">
          <p class="inline-block text-xs font-bold text-accent uppercase tracking-[0.15em] mb-4 bg-white/90 backdrop-blur-sm px-3 py-1.5 rounded-md">
            Award-Winning GAF Master Elite® Contractor | President's Club 2026
          </p>

          <h1 class="text-4xl lg:text-5xl xl:text-6xl font-display font-bold text-white leading-[1.05] mb-6 hero-headline">
            Don't Wait for the Leak.<br />
            <span class="text-white">Get Ahead of It.</span>
          </h1>

          <p class="text-lg text-white/90 leading-relaxed mb-8 max-w-lg hero-subtext">
            GAF Master Elite certified. 600+ roofs across the NRV and Roanoke.
            The warranty, the craftsmanship, and the crew that shows up on time.
          </p>

          {/* Trust Badges */}
          <div class="flex flex-wrap items-center gap-5">
            <div class="flex items-center gap-2 bg-white/10 backdrop-blur-sm rounded-full px-4 py-2">
              <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
              <span class="text-xs font-bold text-white/90">4.9 Google Rating</span>
            </div>
            <div class="bg-white/10 backdrop-blur-sm rounded-full px-4 py-2">
              <span class="text-xs font-bold text-white/90">150+ 5-Star Reviews</span>
            </div>
            <div class="bg-white/10 backdrop-blur-sm rounded-full px-4 py-2">
              <span class="text-xs font-bold text-white/90">BBB A+ Rated</span>
            </div>
          </div>

          {/* Phone CTA — prominent button style */}
          <div class="mt-8">
            <a href="tel:5405536007" class="inline-flex items-center gap-3 bg-white/10 hover:bg-white/20 backdrop-blur-sm border border-white/25 rounded-xl px-5 py-3 transition-all group">
              <span class="flex items-center justify-center w-10 h-10 rounded-full bg-accent text-white flex-shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              </span>
              <span class="text-left">
                <span class="block text-xs text-white/70">Prefer to talk?</span>
                <span class="block text-lg font-bold text-white group-hover:text-accent-light transition-colors">(540) 553-6007</span>
              </span>
            </a>
          </div>
        </div>

        {/* Right Column — Form Card */}
        <div class="md:col-span-6 lg:col-span-5">
          <div class="bg-white rounded-none md:rounded-2xl md:shadow-2xl md:shadow-black/20 p-6 pt-8 pb-8 md:p-8 md:border md:border-white/20 animate-fade-in relative overflow-hidden">

            {/* Accent top stripe (desktop only) */}
            <div class="hidden md:block absolute top-0 left-0 right-0 h-1 bg-accent"></div>

            {/* Form header */}
            <div class="text-center mb-6">
              <h2 class="text-2xl font-display font-bold text-text-primary">
                Get Your Free Estimate
              </h2>
              <p class="text-sm text-text-muted mt-1">
                No obligation. We'll call within 24 hours.
              </p>
            </div>

            {/* The form */}
            <LeadCaptureForm client:load source="hero-intake" />

            {/* Trust line below form */}
            <div class="mt-5 pt-4 border-t border-border flex items-center justify-center gap-4 text-[11px] text-text-dim">
              <span class="flex items-center gap-1">
                <svg class="w-3.5 h-3.5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
                Free Inspection
              </span>
              <span class="flex items-center gap-1">
                <svg class="w-3.5 h-3.5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
                Info Stays Private
              </span>
              <span class="flex items-center gap-1">
                <svg class="w-3.5 h-3.5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                24hr Response
              </span>
            </div>
          </div>

          {/* Mobile: trust badges below form */}
          <div class="flex flex-wrap items-center justify-center gap-3 mt-6 md:hidden">
            <div class="flex items-center gap-1.5 bg-bg-light rounded-full px-3 py-1.5">
              <svg class="w-3.5 h-3.5 text-yellow-500" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
              <span class="text-[11px] font-bold text-text-muted">4.9 Rating</span>
            </div>
            <div class="bg-bg-light rounded-full px-3 py-1.5">
              <span class="text-[11px] font-bold text-text-muted">150+ Reviews</span>
            </div>
            <div class="bg-bg-light rounded-full px-3 py-1.5">
              <span class="text-[11px] font-bold text-text-muted">BBB A+</span>
            </div>
            <div class="bg-bg-light rounded-full px-3 py-1.5">
              <span class="text-[11px] font-bold text-text-muted">GAF Master Elite</span>
            </div>
          </div>

          {/* Mobile: phone CTA — prominent */}
          <div class="mt-5 md:hidden">
            <a href="tel:5405536007" class="flex items-center justify-center gap-3 bg-bg-light border border-border rounded-xl px-5 py-3 transition-all hover:border-accent/30 hover:shadow-sm">
              <span class="flex items-center justify-center w-9 h-9 rounded-full bg-accent text-white flex-shrink-0">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              </span>
              <span class="text-left">
                <span class="block text-xs text-text-muted">Prefer to talk?</span>
                <span class="block text-base font-bold text-text-primary">(540) 553-6007</span>
              </span>
            </a>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<style>
  .hero-headline {
    text-shadow: 0 2px 12px rgba(0,0,0,0.5), 0 1px 3px rgba(0,0,0,0.3);
  }
  .hero-subtext {
    text-shadow: 0 1px 6px rgba(0,0,0,0.4);
  }
</style>
