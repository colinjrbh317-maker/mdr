---
import SectionContainer from "@/components/ui/SectionContainer.astro";
import ScrollReveal from "@/components/common/ScrollReveal.astro";

const valueProps = [
  {
    icon: "shield",
    title: "Top 1% of Roofers",
    description: "GAF Master Elite certified — fewer than 3% of contractors nationwide earn this distinction.",
  },
  {
    icon: "dollar",
    title: "$0 Down Financing",
    description: "Get your roof now, pay over time. Flexible plans that fit your monthly budget.",
  },
  {
    icon: "bolt",
    title: "24/7 Storm Response",
    description: "Emergency tarping and insurance claim assistance when you need it most.",
  },
  {
    icon: "check",
    title: "Lifetime Warranty",
    description: "GAF Golden Pledge warranty covers materials, labor, and even tear-off — for life.",
  },
];
---

<SectionContainer background="warm" padding="md">
  <ScrollReveal>
    <div class="text-center mb-12">
      <p class="text-accent font-semibold text-sm uppercase tracking-wider mb-2">
        Why Homeowners Choose Us
      </p>
      <h2 class="text-3xl md:text-4xl font-display font-bold text-text-primary">
        The MDR Difference
      </h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-[1200px] mx-auto">
      {valueProps.map((prop) => (
        <div class="bg-white rounded-xl p-6 border border-border text-center shadow-sm hover:shadow-md transition-shadow">
          <div class="w-12 h-12 mx-auto mb-4 bg-accent/10 rounded-full flex items-center justify-center">
            {prop.icon === "shield" && (
              <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            )}
            {prop.icon === "dollar" && (
              <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            )}
            {prop.icon === "bolt" && (
              <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            )}
            {prop.icon === "check" && (
              <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
              </svg>
            )}
          </div>
          <h3 class="text-lg font-display font-bold text-text-primary mb-2">{prop.title}</h3>
          <p class="text-sm text-text-muted leading-relaxed">{prop.description}</p>
        </div>
      ))}
    </div>
  </ScrollReveal>
</SectionContainer>
