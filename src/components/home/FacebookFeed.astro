---
import SectionContainer from "@/components/ui/SectionContainer.astro";
---

<SectionContainer background="light" padding="md">
  <div class="max-w-[1200px] mx-auto">
    <div class="text-center mb-8">
      <p class="text-accent font-semibold text-sm uppercase tracking-wider mb-2">Live from the Crew</p>
      <h2 class="text-3xl md:text-4xl font-display font-bold text-text-primary">
        Latest on Facebook
      </h2>
      <p class="mt-3 text-text-muted max-w-2xl mx-auto">
        Real photos and updates from recent Modern Day Roofing projects across the New River Valley and Roanoke. Follow along on
        <a href="https://www.facebook.com/moderndayroof" target="_blank" rel="noopener" class="text-accent hover:underline font-semibold">
          Facebook
        </a>.
      </p>
    </div>

    <div class="flex justify-center">
      {/* Facebook Page Plugin auto-resizes via data-adapt-container-width. Wrapper caps width on desktop and gives mobile a clean column. */}
      <div class="w-full max-w-[680px]">
        <div id="fb-root"></div>
        <div
          class="fb-page"
          data-href="https://www.facebook.com/moderndayroof"
          data-tabs="timeline"
          data-width="680"
          data-height="720"
          data-small-header="false"
          data-adapt-container-width="true"
          data-hide-cover="false"
          data-show-facepile="true">
          <blockquote cite="https://www.facebook.com/moderndayroof" class="fb-xfbml-parse-ignore">
            <a href="https://www.facebook.com/moderndayroof" class="text-accent font-semibold">Modern Day Roofing on Facebook</a>
          </blockquote>
        </div>
      </div>
    </div>

    <div class="text-center mt-6">
      <a
        href="https://www.facebook.com/moderndayroof"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 px-5 py-3 rounded-lg bg-[#1877F2] text-white font-semibold hover:bg-[#0e63d3] transition-colors no-underline">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
        </svg>
        Follow on Facebook
      </a>
    </div>
  </div>
</SectionContainer>

{/* Facebook SDK loader, deferred so it does not block first paint */}
<script
  is:inline
  async
  defer
  crossorigin="anonymous"
  src="https://connect.facebook.net/en_US/sdk.js#xfbml=1&version=v18.0&appId="></script>
