---
import SectionContainer from "@/components/ui/SectionContainer.astro";
import ScrollReveal from "@/components/common/ScrollReveal.astro";

// Hardcoded reviews — replace with Sanity testimonials or Google Places API later
const reviews = [
  {
    name: "Jake S.",
    city: "Christiansburg, VA",
    service: "Roof Replacement",
    rating: 5,
    quote: "From the initial inspection to the final walkthrough, Modern Day Roofing was professional, thorough, and on time. Our new GAF shingle roof looks incredible. Highly recommend!",
  },
  {
    name: "Megan T.",
    city: "Blacksburg, VA",
    service: "Storm Damage",
    rating: 5,
    quote: "After a bad storm took shingles off our roof, MDR was out the next morning with a tarp and a plan. They handled the entire insurance claim process and our new roof was done in two days.",
  },
  {
    name: "David R.",
    city: "Salem, VA",
    service: "Metal Roofing",
    rating: 5,
    quote: "We went with standing seam metal and couldn't be happier. The crew was respectful of our property, cleaned up every day, and the finished product is stunning. Worth every penny.",
  },
  {
    name: "Lisa M.",
    city: "Roanoke, VA",
    service: "Roof Repair",
    rating: 5,
    quote: "Quick response, fair pricing, and honest about what needed to be fixed vs. what could wait. They patched a tricky valley leak that two other companies couldn't figure out.",
  },
  {
    name: "Chris H.",
    city: "Radford, VA",
    service: "Gutters",
    rating: 5,
    quote: "New seamless gutters and leaf guards installed in a single day. No more ice dams or overflow. The team was friendly and left the property cleaner than they found it.",
  },
  {
    name: "Amanda B.",
    city: "Christiansburg, VA",
    service: "Roof Replacement",
    rating: 5,
    quote: "As a first-time homeowner, I had a lot of questions. The team at MDR took the time to explain every option and helped me choose the best system for my budget. Golden Pledge warranty gives me total peace of mind.",
  },
];
---

<SectionContainer background="darker" padding="lg">
  <ScrollReveal>
    <div class="text-center mb-12">
      {/* Google logo + aggregate rating */}
      <div class="flex items-center justify-center gap-3 mb-4">
        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        <div class="flex gap-0.5">
          {[1,2,3,4,5].map(() => (
            <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </div>
      </div>
      <h2 class="text-3xl md:text-4xl font-display font-bold text-white mb-2">
        4.9 Stars from 150+ Google Reviews
      </h2>
      <p class="text-white/85 text-lg">
        Real feedback from Virginia homeowners we've served.
      </p>
    </div>

    {/* Review Cards - Horizontal Scroll on Mobile, Grid on Desktop */}
    <div class="flex gap-6 overflow-x-auto pb-4 md:pb-0 md:grid md:grid-cols-3 snap-x snap-mandatory scrollbar-hide">
      {reviews.slice(0, 6).map((review) => (
        <div class="min-w-[300px] md:min-w-0 snap-start bg-white/10 backdrop-blur-sm border border-white/15 rounded-xl p-6 flex flex-col">
          {/* Service tag */}
          <span class="inline-block self-start text-xs font-semibold text-accent-light bg-accent/20 px-3 py-1 rounded-full mb-4">
            {review.service}
          </span>

          {/* Stars + Google logo */}
          <div class="flex items-center gap-2 mb-3">
            <div class="flex gap-0.5">
              {Array.from({ length: review.rating }).map(() => (
                <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <svg class="w-4 h-4 ml-auto opacity-40" viewBox="0 0 24 24" fill="none">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
          </div>

          {/* Quote */}
          <p class="text-white/90 text-sm leading-relaxed flex-1 mb-4">
            "{review.quote}"
          </p>

          {/* Name + City */}
          <div class="border-t border-white/10 pt-3 mt-auto">
            <p class="text-white font-semibold text-sm">{review.name}</p>
            <p class="text-white/60 text-xs">{review.city}</p>
          </div>
        </div>
      ))}
    </div>

    {/* Read All Reviews link */}
    <div class="text-center mt-8">
      <a
        href="https://www.google.com/maps/place/Modern+Day+Roofing"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-white/70 hover:text-white text-sm font-medium transition-colors"
      >
        Read All Reviews on Google
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    </div>
  </ScrollReveal>
</SectionContainer>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
