---
const reviews = [
  {
    name: "Dawn M.",
    initials: "DM",
    city: "Christiansburg, VA",
    rating: 5,
    quote: "The crew was on time, actually a few minutes early and they immediately started working. The roof replacement and the gutter cleaning, resealing and screen installation was completed in a day! We are beyond happy with the results.",
  },
  {
    name: "Amory L.",
    initials: "AL",
    city: "Roanoke, VA",
    rating: 5,
    quote: "Working with MDR made this process a breeze. I am a first time homeowner and they really made it easy to understand. They explained everything, the clean up was great, the crew was very respectful. 10/10 recommend.",
  },
  {
    name: "Bonnie D.",
    initials: "BD",
    city: "Blacksburg, VA",
    rating: 5,
    quote: "Our roof looks great and now I no longer have to worry about future roofing projects due to the warranty they were able to offer. Professional and on time. Thanks a lot Modern Day Roofing!",
  },
  {
    name: "Linda S.",
    initials: "LS",
    city: "Salem, VA",
    rating: 5,
    quote: "Modern Day Roofing was very professional and straightforward with what needed to be done on our roof. We ran into a snag with our chimney we weren't expecting and they found someone to address the problem and got it all done.",
  },
  {
    name: "Katelin N.",
    initials: "KN",
    city: "Radford, VA",
    rating: 5,
    quote: "Austin was very professional and extremely kind when he came out to check a spot on our roof that had been leaking. It was a quick, easy fix which was a huge relief! Don't hesitate to check them out.",
  },
  {
    name: "John G.",
    initials: "JG",
    city: "Christiansburg, VA",
    rating: 5,
    quote: "Modern Day Roofing did an excellent job on my roof. They were here only 3 hours and 17 minutes and it was done. Chris came to our house before and after to inspect their work. Would highly recommend.",
  },
];
---

<section class="py-16 md:py-24 bg-bg-light">
  <div class="mx-auto max-w-[1200px] px-4 md:px-6">

    {/* Section Header */}
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-display font-bold text-text-primary mb-6">
        What Our Customers Say
      </h2>

      {/* Overall Rating Row */}
      <div class="flex flex-wrap items-center justify-center gap-4 mb-4">
        {/* Google Logo + Rating */}
        <div class="flex items-center gap-3 bg-white rounded-full px-5 py-2.5 shadow-sm border border-border">
          <svg class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24" fill="none">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          <div class="flex items-center gap-2">
            <span class="text-2xl font-bold text-text-primary">4.9</span>
            <div class="flex gap-0.5">
              {[1,2,3,4,5].map(() => (
                <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
          </div>
          <span class="text-sm text-text-muted">150+ Reviews</span>
        </div>

        {/* Location Ratings */}
        {[
          { city: "Christiansburg", rating: "4.9" },
          { city: "Roanoke", rating: "4.9" },
          { city: "Blacksburg", rating: "4.8" },
          { city: "Salem", rating: "5.0" },
          { city: "Radford", rating: "4.9" },
        ].map((loc) => (
          <div class="flex items-center gap-1.5 bg-white rounded-full px-4 py-2 shadow-sm border border-border text-sm">
            <svg class="w-3.5 h-3.5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <span class="font-semibold text-text-primary">{loc.rating}</span>
            <span class="text-text-muted">{loc.city}</span>
          </div>
        ))}
      </div>

      {/* Write a Review CTA */}
      <a
        href="https://www.google.com/maps?q=place_id:ChIJF1B6XsCTTYgRhBfUE2iAeoI"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-5 py-2 border-2 border-accent text-accent font-semibold text-sm rounded-full hover:bg-accent hover:text-white transition-all"
      >
        Write a Review
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
      </a>
    </div>

    {/* Review Cards Carousel */}
    <div class="relative">
      {/* Navigation Arrows */}
      <button
        id="reviews-prev"
        aria-label="Previous reviews"
        class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-4 z-10 w-10 h-10 rounded-full bg-white shadow-md border border-border flex items-center justify-center hover:bg-bg-light transition-colors hidden md:flex"
      >
        <svg class="w-5 h-5 text-text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
      </button>
      <button
        id="reviews-next"
        aria-label="Next reviews"
        class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-4 z-10 w-10 h-10 rounded-full bg-white shadow-md border border-border flex items-center justify-center hover:bg-bg-light transition-colors hidden md:flex"
      >
        <svg class="w-5 h-5 text-text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
      </button>

      {/* Cards Track */}
      <div id="reviews-track" class="flex gap-6 overflow-x-auto pb-4 snap-x snap-mandatory scrollbar-hide md:overflow-hidden">
        {reviews.map((review) => (
          <div class="min-w-[300px] md:min-w-[calc(33.333%-1rem)] snap-start bg-white rounded-2xl p-6 shadow-sm border border-border flex flex-col">
            {/* Reviewer Header */}
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-full bg-accent/10 flex items-center justify-center text-accent font-bold text-sm flex-shrink-0">
                {review.initials}
              </div>
              <div>
                <p class="font-semibold text-text-primary text-sm">{review.name}</p>
                <p class="text-xs text-text-muted">{review.city}</p>
              </div>
              {/* Google icon right-aligned */}
              <svg class="w-5 h-5 ml-auto flex-shrink-0 opacity-60" viewBox="0 0 24 24" fill="none">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
              </svg>
            </div>

            {/* Stars */}
            <div class="flex gap-0.5 mb-3">
              {Array.from({ length: review.rating }).map(() => (
                <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>

            {/* Quote */}
            <p class="text-text-body text-sm leading-relaxed flex-1 mb-4">
              "{review.quote}"
            </p>

            {/* Read More */}
            <a
              href="https://www.google.com/maps?q=place_id:ChIJF1B6XsCTTYgRhBfUE2iAeoI"
              target="_blank"
              rel="noopener noreferrer"
              class="text-xs text-accent font-semibold hover:underline transition-colors"
            >
              Read more
            </a>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

<style>
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script>
  const track = document.getElementById('reviews-track');
  const prevBtn = document.getElementById('reviews-prev');
  const nextBtn = document.getElementById('reviews-next');

  if (track && prevBtn && nextBtn) {
    const cardWidth = 340; // approx card + gap
    prevBtn.addEventListener('click', () => {
      track.scrollBy({ left: -cardWidth, behavior: 'smooth' });
    });
    nextBtn.addEventListener('click', () => {
      track.scrollBy({ left: cardWidth, behavior: 'smooth' });
    });
  }
</script>
