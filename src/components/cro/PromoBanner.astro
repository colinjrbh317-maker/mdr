---
/**
 * Inline promotional banner for service pages.
 * Date-gated: automatically hidden after May 31, 2026.
 */
---

<div
  id="promo-banner"
  class="bg-gradient-to-r from-accent/10 to-amber-50 border border-accent/20 rounded-xl p-5 md:p-6 my-8"
>
  <div class="flex flex-col sm:flex-row items-center gap-4">
    <div class="flex-1 text-center sm:text-left">
      <span class="inline-block px-2.5 py-0.5 bg-accent text-white text-[10px] font-bold uppercase tracking-wider rounded-full mb-2">
        Spring 2026 Special
      </span>
      <h3 class="text-lg md:text-xl font-bold text-text-primary">
        $500 Off Any Roofing Service
      </h3>
      <p class="text-sm text-text-muted mt-1">
        Schedule your free inspection before May 31 and save. No hidden fees.
      </p>
    </div>
    <a
      href="/offers/500-off"
      class="inline-flex items-center gap-2 px-6 py-3 bg-accent hover:bg-accent-dark text-white font-bold text-sm rounded-lg transition-colors whitespace-nowrap"
    >
      Claim Offer
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </a>
  </div>
</div>

<script>
  // Date-gate: hide after May 31, 2026
  const banner = document.getElementById("promo-banner");
  if (banner && new Date() >= new Date("2026-06-01")) {
    banner.style.display = "none";
  }
</script>
