---
interface Props {
  variant?: "default" | "service" | "testimonial" | "featured" | "compact";
  href?: string;
  class?: string;
}

const { variant = "default", href, class: className = "" } = Astro.props;

const baseStyles =
  "rounded-xl bg-bg-card p-6 transition-all duration-300 border border-border shadow-sm";

const variants: Record<string, string> = {
  default: "hover:shadow-lg hover:scale-[1.02]",
  service:
    "border-t-4 border-t-accent hover:shadow-lg hover:scale-[1.02] hover:shadow-accent/10",
  testimonial: "bg-bg-warm border-border-light",
  featured: "border-2 border-transparent hover:border-warm hover:shadow-xl hover:scale-[1.02]",
  compact: "flex flex-row gap-4 p-4",
};

const classes = `${baseStyles} ${variants[variant]} ${className}`;
---

{
  href ? (
    <a href={href} class={`${classes} block no-underline`}>
      <slot />
    </a>
  ) : (
    <div class={classes}>
      <slot />
    </div>
  )
}
