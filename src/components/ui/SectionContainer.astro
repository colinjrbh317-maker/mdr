---
interface Props {
  background?: "light" | "white" | "warm" | "dark" | "darker" | "accent" | "textured";
  padding?: "xs" | "sm" | "md" | "lg" | "none";
  maxWidth?: "content" | "narrow" | "full";
  id?: string;
  class?: string;
}

const {
  background = "light",
  padding = "md",
  maxWidth = "content",
  id,
  class: className = "",
} = Astro.props;

const isDark = background === "dark" || background === "darker" || background === "accent";

const backgrounds: Record<string, string> = {
  light: "bg-bg-light",
  white: "bg-bg-white",
  warm: "bg-bg-warm",
  dark: "bg-bg-dark dark-section",
  darker: "bg-bg-darker dark-section",
  accent: "bg-accent dark-section",
  textured: "bg-bg-light section-textured",
};

const paddings: Record<string, string> = {
  none: "px-4 md:px-6",
  xs: "py-2 md:py-3 px-4 md:px-6",
  sm: "py-8 md:py-12 px-4 md:px-6",
  md: "py-12 md:py-20 px-4 md:px-6",
  lg: "py-16 md:py-28 px-4 md:px-6",
};

const maxWidths: Record<string, string> = {
  content: "max-w-[1400px]",
  narrow: "max-w-[900px]",
  full: "max-w-full",
};
---

<section id={id} class={`${backgrounds[background]} ${paddings[padding]} ${className}`}>
  <div class={`mx-auto ${maxWidths[maxWidth]}`}>
    <slot />
  </div>
</section>

<style>
  .section-textured {
    position: relative;
  }
  .section-textured::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 256px 256px;
  }
</style>
