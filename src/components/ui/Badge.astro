---
interface Props {
  variant?: "certification" | "rating" | "award" | "warm";
  text: string;
  class?: string;
}

const { variant = "certification", text, class: className = "" } = Astro.props;

const variants: Record<string, string> = {
  certification: "bg-accent/10 text-accent border-accent/20",
  rating: "bg-yellow-500/10 text-yellow-600 border-yellow-500/20",
  award: "bg-emerald-500/10 text-emerald-600 border-emerald-500/20",
  warm: "bg-warm/10 text-warm-dark border-warm/20",
};
---

<span
  class={`inline-flex items-center gap-1.5 rounded-full border px-3 py-1 text-xs font-semibold uppercase tracking-wide ${variants[variant]} ${className}`}
>
  <slot />
  {text}
</span>
