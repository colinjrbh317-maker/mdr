---
interface Props {
  variant?: "certification" | "rating" | "award";
  text: string;
  class?: string;
}

const { variant = "certification", text, class: className = "" } = Astro.props;

const variants: Record<string, string> = {
  certification: "bg-accent/15 text-accent-light border-accent/30",
  rating: "bg-yellow-500/15 text-yellow-400 border-yellow-500/30",
  award: "bg-emerald-500/15 text-emerald-400 border-emerald-500/30",
};
---

<span
  class={`inline-flex items-center gap-1.5 rounded-full border px-3 py-1 text-xs font-semibold uppercase tracking-wide ${variants[variant]} ${className}`}
>
  <slot />
  {text}
</span>
