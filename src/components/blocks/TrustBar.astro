---
interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<div
  class={`flex flex-wrap items-center justify-center gap-x-6 gap-y-3 md:gap-x-10 py-4 ${className}`}
  role="list"
  aria-label="Trust indicators"
>
  {/* GAF President's Club Badge */}
  <div class="flex items-center gap-2" role="listitem">
    <img
      src="/assets/logos/Presidents-Club_3-Star_Residential-with-Year_2026.png"
      alt="GAF President's Club 2026"
      class="h-12 w-auto object-contain"
      loading="eager"
    />
  </div>

  <div class="hidden md:block w-px h-8 bg-border" aria-hidden="true"></div>

  {/* Google Rating */}
  <div class="flex items-center gap-2" role="listitem">
    <div class="flex gap-0.5" aria-label="5 star rating">
      {
        Array.from({ length: 5 }).map(() => (
          <svg class="w-4 h-4 text-yellow-500" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
        ))
      }
    </div>
    <span class="text-lg font-bold text-text-primary">4.9</span>
    <span class="text-xs text-text-muted">150+ Reviews</span>
  </div>

  <div class="hidden md:block w-px h-8 bg-border" aria-hidden="true"></div>

  {/* $0 Down */}
  <div class="flex items-center gap-1.5" role="listitem">
    <span class="text-lg font-bold text-accent">$0 Down</span>
    <span class="text-xs text-text-muted">Financing</span>
  </div>

  <div class="hidden md:block w-px h-8 bg-border" aria-hidden="true"></div>

  {/* 600+ Roofs */}
  <div class="flex items-center gap-1.5" role="listitem">
    <span class="text-lg font-bold text-text-primary">600+</span>
    <span class="text-xs text-text-muted">Roofs Completed</span>
  </div>

  <div class="hidden md:block w-px h-8 bg-border" aria-hidden="true"></div>

  {/* BBB A+ */}
  <div class="flex items-center gap-2" role="listitem">
    <img
      src="/assets/logos/bbb-button.png"
      alt="BBB A+ Accredited"
      class="h-8 w-auto object-contain"
      loading="eager"
    />
  </div>
</div>
