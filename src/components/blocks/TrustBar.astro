---
import Badge from "@/components/ui/Badge.astro";
import ImagePlaceholder from "@/components/common/ImagePlaceholder.astro";

interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<div
  class={`flex items-center gap-6 overflow-x-auto py-4 px-2 scrollbar-hide ${className}`}
  role="list"
  aria-label="Trust indicators"
>
  <!-- GAF Master Elite Badge -->
  <div class="flex-shrink-0" role="listitem">
    <div class="flex items-center gap-3">
      <ImagePlaceholder
        width="60px"
        height="60px"
        description="GAF Master Elite badge"
        class="rounded-lg"
      />
      <div>
        <Badge variant="certification" text="GAF Master Elite" />
        <p class="text-xs text-text-dim mt-1">Top 2% of contractors</p>
      </div>
    </div>
  </div>

  <!-- Divider -->
  <div class="flex-shrink-0 w-px h-12 bg-border hidden sm:block" aria-hidden="true"></div>

  <!-- Google Rating -->
  <div class="flex-shrink-0" role="listitem">
    <div class="flex items-center gap-2">
      <div class="flex gap-0.5" aria-label="5 star rating">
        {
          Array.from({ length: 5 }).map(() => (
            <svg
              class="w-5 h-5 text-yellow-400"
              fill="currentColor"
              viewBox="0 0 20 20"
            >
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))
        }
      </div>
      <div>
        <p class="text-sm font-semibold text-text-primary">5.0</p>
        <p class="text-xs text-text-dim">Google Reviews</p>
      </div>
    </div>
  </div>

  <!-- Divider -->
  <div class="flex-shrink-0 w-px h-12 bg-border hidden sm:block" aria-hidden="true"></div>

  <!-- Years in Business -->
  <div class="flex-shrink-0" role="listitem">
    <p class="text-2xl font-bold text-text-primary">10+</p>
    <p class="text-xs text-text-dim">Years in Business</p>
  </div>

  <!-- Divider -->
  <div class="flex-shrink-0 w-px h-12 bg-border hidden sm:block" aria-hidden="true"></div>

  <!-- Reviews Count -->
  <div class="flex-shrink-0" role="listitem">
    <p class="text-2xl font-bold text-text-primary">100+</p>
    <p class="text-xs text-text-dim">5-Star Reviews</p>
  </div>
</div>

<style>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>
