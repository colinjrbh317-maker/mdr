---
import Badge from "@/components/ui/Badge.astro";

interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<div
  class={`grid grid-cols-2 md:grid-cols-4 gap-4 py-2 ${className}`}
  role="list"
  aria-label="Trust indicators"
>
  <!-- GAF President's Club Badge -->
  <div class="bg-bg-card rounded-xl p-5 shadow-sm border border-border text-center" role="listitem">
    <div class="w-20 h-20 mx-auto flex items-center justify-center">
      <img
        src="/assets/logos/Presidents-Club_3-Star_Residential-with-Year_2026.png"
        alt="GAF President's Club 2026"
        class="w-20 h-20 object-contain"
        loading="eager"
      />
    </div>
  </div>

  <!-- Google Rating -->
  <div class="bg-bg-card rounded-xl p-5 shadow-sm border border-border text-center" role="listitem">
    <div class="flex gap-0.5 justify-center mb-3" aria-label="5 star rating">
      {
        Array.from({ length: 5 }).map(() => (
          <svg
            class="w-5 h-5 text-yellow-500"
            fill="currentColor"
            viewBox="0 0 20 20"
          >
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
        ))
      }
    </div>
    <p class="text-2xl font-bold text-text-primary">4.9</p>
    <p class="text-xs text-text-muted">150+ Google Reviews</p>
  </div>

  <!-- Years in Business -->
  <div class="bg-bg-card rounded-xl p-5 shadow-sm border border-border text-center" role="listitem">
    <p class="text-3xl font-bold text-text-primary mb-1">7+</p>
    <p class="text-xs text-text-muted">Years Serving Virginia</p>
  </div>

  <!-- Reviews Count -->
  <div class="bg-bg-card rounded-xl p-5 shadow-sm border border-border text-center" role="listitem">
    <p class="text-3xl font-bold text-text-primary mb-1">150+</p>
    <p class="text-xs text-text-muted">5-Star Google Reviews</p>
  </div>
</div>
