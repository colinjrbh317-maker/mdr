---
import SectionContainer from "@/components/ui/SectionContainer.astro";

interface Props {
  cityName: string;
}

const { cityName } = Astro.props;
---

<SectionContainer background="white" padding="md">
  <div class="max-w-[1200px] mx-auto">
    <div class="text-center mb-8">
      <h2 class="text-2xl md:text-3xl font-bold text-text-primary">
        Recent {cityName} Projects on the Map
      </h2>
      <p class="mt-2 text-text-muted">
        Live geo-tagged jobs from the Modern Day Roofing crew. Tap a pin to see the work we've done in your neighborhood.
      </p>
    </div>
    {/* Pinparrot widget self-renders adjacent to its script tag. The script must keep id="gb_widget_script". */}
    <div class="rounded-2xl overflow-hidden border border-border bg-bg-light shadow-sm">
      <script
        is:inline
        id="gb_widget_script"
        type="module"
        src="https://team.pinparrot.com/gb-widget.js"
        data-widget-id="o5emvwlw"></script>
    </div>
  </div>
</SectionContainer>
