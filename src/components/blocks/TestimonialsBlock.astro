---
import SectionContainer from "@/components/ui/SectionContainer.astro";
import Card from "@/components/ui/Card.astro";
import { urlForImage } from "@/sanity/lib/url-for-image";

interface TestimonialRef {
  _id: string;
  name: string;
  location?: string;
  rating?: number;
  text: string;
  date?: string;
  image?: any;
}

interface Props {
  heading?: string;
  testimonials?: TestimonialRef[];
}

const { heading, testimonials = [] } = Astro.props;

// Compute aggregate rating from testimonials
const ratedTestimonials = testimonials.filter((t) => t.rating && t.rating > 0);
const avgRating =
  ratedTestimonials.length > 0
    ? (ratedTestimonials.reduce((sum, t) => sum + (t.rating || 0), 0) / ratedTestimonials.length).toFixed(1)
    : null;

const reviewJsonLd = avgRating
  ? {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      name: "Modern Day Roofing",
      aggregateRating: {
        "@type": "AggregateRating",
        ratingValue: avgRating,
        reviewCount: ratedTestimonials.length,
        bestRating: "5",
      },
      review: ratedTestimonials.map((t) => ({
        "@type": "Review",
        author: { "@type": "Person", name: t.name },
        reviewRating: {
          "@type": "Rating",
          ratingValue: String(t.rating),
        },
        reviewBody: t.text,
      })),
    }
  : null;
---

<SectionContainer background="warm" padding="md">
  {reviewJsonLd && (
    <script type="application/ld+json" set:html={JSON.stringify(reviewJsonLd)} />
  )}
  {heading && (
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-text-primary">
        {heading}
      </h2>
    </div>
  )}

  <div class="relative">
    <!-- Carousel container -->
    <div class="testimonial-carousel overflow-x-auto scroll-smooth snap-x snap-mandatory flex gap-6 pb-4 -mx-2 px-2" role="list">
      {testimonials.map((t) => (
        <div class="snap-start flex-shrink-0 w-[340px] md:w-[400px]" role="listitem">
          <Card variant="testimonial">
            {/* Star Rating */}
            {t.rating && (
              <div class="flex gap-0.5 mb-3" aria-label={`${t.rating} star rating`}>
                {Array.from({ length: 5 }).map((_, i) => (
                  <svg
                    class={`w-5 h-5 ${i < t.rating! ? "text-yellow-500" : "text-text-dim/30"}`}
                    fill="currentColor"
                    viewBox="0 0 20 20"
                  >
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
            )}

            {/* Testimonial Text */}
            <p class="text-text-body text-sm leading-relaxed mb-4">"{t.text}"</p>

            {/* Author */}
            <div class="flex items-center gap-3 mt-auto">
              {t.image ? (
                <img
                  src={urlForImage(t.image).width(48).height(48).url()}
                  alt={t.name}
                  class="w-10 h-10 rounded-full object-cover"
                  loading="lazy"
                />
              ) : (
                <div class="w-10 h-10 rounded-full bg-accent/20 flex items-center justify-center text-accent font-semibold text-sm">
                  {t.name.charAt(0)}
                </div>
              )}
              <div>
                <p class="text-sm font-semibold text-text-primary">{t.name}</p>
                {t.location && (
                  <p class="text-xs text-text-muted">{t.location}</p>
                )}
              </div>
            </div>
          </Card>
        </div>
      ))}
    </div>

    <!-- Navigation arrows -->
    {testimonials.length > 3 && (
      <div class="flex justify-center gap-3 mt-6">
        <button
          class="testimonial-prev w-10 h-10 rounded-full border border-border bg-bg-card flex items-center justify-center hover:bg-bg-card-hover transition-colors"
          aria-label="Previous testimonials"
        >
          <svg class="w-5 h-5 text-text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
        </button>
        <button
          class="testimonial-next w-10 h-10 rounded-full border border-border bg-bg-card flex items-center justify-center hover:bg-bg-card-hover transition-colors"
          aria-label="Next testimonials"
        >
          <svg class="w-5 h-5 text-text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </button>
      </div>
    )}
  </div>
</SectionContainer>

<style>
  .testimonial-carousel {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .testimonial-carousel::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  function initTestimonialCarousel() {
    const carousel = document.querySelector<HTMLElement>('.testimonial-carousel');
    const prevBtn = document.querySelector<HTMLButtonElement>('.testimonial-prev');
    const nextBtn = document.querySelector<HTMLButtonElement>('.testimonial-next');

    if (!carousel) return;

    const scrollAmount = 420;

    prevBtn?.addEventListener('click', () => {
      carousel.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
    });

    nextBtn?.addEventListener('click', () => {
      carousel.scrollBy({ left: scrollAmount, behavior: 'smooth' });
    });
  }

  initTestimonialCarousel();
  document.addEventListener('astro:after-swap', initTestimonialCarousel);
</script>
