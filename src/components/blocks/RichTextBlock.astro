---
import SectionContainer from "@/components/ui/SectionContainer.astro";
import { PortableText } from "astro-portabletext";

interface Props {
  content?: any[];
}

const { content } = Astro.props;
---

{content && (
  <SectionContainer background="white" padding="md" maxWidth="narrow">
    <div class="prose prose-lg max-w-none text-text-body prose-headings:text-text-primary prose-headings:mt-10 prose-headings:mb-4 prose-a:text-accent prose-strong:text-text-primary prose-p:leading-relaxed prose-li:leading-relaxed">
      <PortableText value={content} />
    </div>
  </SectionContainer>
)}
