---
import Layout from "@/layouts/Layout.astro";
import SectionContainer from "@/components/ui/SectionContainer.astro";
import Button from "@/components/ui/Button.astro";
import Breadcrumb from "@/components/common/Breadcrumb.astro";
import LeadCaptureForm from "@/components/forms/LeadCaptureForm";

export const prerender = true;

const breadcrumbItems = [
  { label: "Home", href: "/" },
  { label: "Warranty" },
];

const faqs = [
  {
    question: "What is the GAF Golden Pledge Warranty?",
    answer: "The Golden Pledge Warranty is GAF's best warranty — available only through GAF Master Elite contractors. It provides 50-year material coverage and 25-year workmanship coverage, backed by GAF (not just the installer). It's the strongest warranty in the roofing industry.",
  },
  {
    question: "What is the difference between Golden Pledge and System Plus?",
    answer: "Golden Pledge offers 25-year workmanship coverage backed by GAF. System Plus provides 10-year workmanship coverage. Both require a full GAF roofing system to be installed. Golden Pledge is the premium option for maximum peace of mind.",
  },
  {
    question: "What does the warranty NOT cover?",
    answer: "Warranties do not cover damage from acts of nature (hurricanes, tornados, hail beyond design limits), improper modifications by other contractors, normal wear from foot traffic, or cosmetic issues that don't affect performance. Your homeowner's insurance typically covers storm events.",
  },
  {
    question: "Can I transfer the warranty if I sell my home?",
    answer: "Yes. GAF warranties are transferable to the next homeowner within the first 20 years of coverage. This adds real value to your home when you sell. We'll help you with the transfer paperwork.",
  },
  {
    question: "How do I file a warranty claim?",
    answer: "Call us at (540) 553-6007 or contact GAF directly. We recommend calling us first — we'll inspect the issue, determine if it's warranty-covered, and handle the claim process for you. Most claims are resolved within 2-4 weeks.",
  },
  {
    question: "Why does GAF Master Elite status matter for my warranty?",
    answer: "Only GAF Master Elite contractors — the top 3% nationwide — can offer Golden Pledge warranties. If a non-certified contractor installs your roof, you may only get a basic material warranty with no workmanship coverage. The installer's certification directly determines your warranty options.",
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer,
    },
  })),
};
---

<Layout
  title="Roof Warranty Coverage | GAF Golden Pledge | Modern Day Roofing"
  description="Modern Day Roofing offers GAF Golden Pledge warranties with 50-year material and 25-year workmanship coverage. Learn what's covered and how to file a claim."
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  {/* Hero */}
  <section class="relative min-h-[40vh] flex items-center dark-section" data-transparent-header>
    <div class="absolute inset-0 z-0">
      <img
        src="/assets/hero/hero-main.jpg"
        alt="Modern Day Roofing warranty-backed project"
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-bg-darker/95 via-bg-darker/85 to-bg-darker/50"></div>
    </div>
    <div class="relative z-10 mx-auto max-w-[1200px] px-4 md:px-6 py-16 md:py-24 w-full">
      <Breadcrumb items={breadcrumbItems} />
      <div class="mt-6 max-w-3xl">
        <p class="text-accent-light font-semibold text-sm uppercase tracking-wider mb-3">
          Industry-Leading Protection
        </p>
        <h1 class="text-4xl md:text-5xl font-bold text-white">
          50-Year Product Warranty Coverage
        </h1>
        <p class="mt-4 text-lg text-white/85 max-w-2xl leading-relaxed">
          As a GAF Master Elite contractor, we offer the strongest warranties in roofing — backed by the manufacturer, not just the installer.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          <Button href="/contact" size="lg">Get a Free Estimate</Button>
          <Button href="tel:5405536007" variant="outline" size="lg" class="text-white border-white hover:bg-white hover:text-bg-dark">
            Call (540) 553-6007
          </Button>
        </div>
      </div>
    </div>
  </section>

  {/* Warranty Tiers */}
  <SectionContainer background="white" padding="lg">
    <div class="text-center mb-12">
      <h2 class="text-2xl md:text-3xl font-display font-bold text-text-primary">
        GAF Warranty Options
      </h2>
      <p class="mt-3 text-text-muted max-w-xl mx-auto">
        Every roof we install comes with manufacturer-backed warranty coverage.
      </p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
      {/* Golden Pledge */}
      <div class="bg-bg-card border-2 border-accent rounded-xl p-8 relative">
        <div class="absolute -top-3 left-6 bg-accent text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider">
          Our Recommendation
        </div>
        <h3 class="text-xl font-display font-bold text-text-primary mb-4">GAF Golden Pledge</h3>
        <ul class="space-y-3 text-text-body text-sm">
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            <span><strong>50-year</strong> material coverage</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            <span><strong>25-year</strong> workmanship coverage</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            <span>Backed by GAF, not just the installer</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            <span>Transferable to next homeowner</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            <span>Only available from Master Elite contractors</span>
          </li>
        </ul>
      </div>
      {/* System Plus */}
      <div class="bg-bg-card border border-border rounded-xl p-8">
        <h3 class="text-xl font-display font-bold text-text-primary mb-4">GAF System Plus</h3>
        <ul class="space-y-3 text-text-body text-sm">
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            <span><strong>50-year</strong> material coverage</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            <span><strong>10-year</strong> workmanship coverage</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            <span>Backed by GAF</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            <span>Transferable to next homeowner</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-text-muted flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            <span class="text-text-muted">Shorter workmanship period</span>
          </li>
        </ul>
      </div>
    </div>
  </SectionContainer>

  {/* What's Covered */}
  <SectionContainer background="light" padding="md">
    <div class="max-w-4xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div>
          <h2 class="text-2xl font-display font-bold text-text-primary mb-6">What's Covered</h2>
          <ul class="space-y-3">
            {["Manufacturing defects in shingles and materials", "Workmanship errors during installation", "Wind damage up to specified speed rating", "Algae discoloration (Timberline HDZ)", "Labor costs for warranty repairs"].map((item) => (
              <li class="flex items-start gap-3 text-text-body text-sm">
                <svg class="w-5 h-5 text-green-600 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <div>
          <h2 class="text-2xl font-display font-bold text-text-primary mb-6">What's Not Covered</h2>
          <ul class="space-y-3">
            {["Acts of nature beyond design limits", "Damage from unauthorized modifications", "Normal wear from foot traffic", "Cosmetic issues not affecting performance", "Damage caused by other contractors"].map((item) => (
              <li class="flex items-start gap-3 text-text-body text-sm">
                <svg class="w-5 h-5 text-red-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </SectionContainer>

  {/* How to File */}
  <SectionContainer background="white" padding="md">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-2xl md:text-3xl font-display font-bold text-text-primary mb-4">
        How to File a Warranty Claim
      </h2>
      <p class="text-text-muted mb-10 max-w-xl mx-auto">
        We handle the paperwork. Just call us and we'll take it from there.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-accent text-white flex items-center justify-center text-lg font-bold">1</div>
          <h3 class="font-bold text-text-primary mb-2">Call Us</h3>
          <p class="text-sm text-text-muted">Call (540) 553-6007 and describe the issue. We recommend calling us before contacting GAF directly.</p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-accent text-white flex items-center justify-center text-lg font-bold">2</div>
          <h3 class="font-bold text-text-primary mb-2">We Inspect</h3>
          <p class="text-sm text-text-muted">We'll send a crew to inspect the issue, take photos, and determine if it falls under warranty coverage.</p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-accent text-white flex items-center justify-center text-lg font-bold">3</div>
          <h3 class="font-bold text-text-primary mb-2">We Resolve</h3>
          <p class="text-sm text-text-muted">We file the claim with GAF and complete the repair. Most claims are resolved within 2-4 weeks.</p>
        </div>
      </div>
    </div>
  </SectionContainer>

  {/* FAQ */}
  <SectionContainer background="warm" padding="md">
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-10">
        <h2 class="text-2xl md:text-3xl font-bold text-text-primary">Warranty FAQs</h2>
      </div>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="group bg-bg-card border border-border rounded-xl overflow-hidden">
            <summary class="flex items-center justify-between cursor-pointer p-5 text-left">
              <h3 class="text-text-primary font-medium pr-4">{faq.question}</h3>
              <svg class="w-5 h-5 text-text-dim flex-shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-5 pb-5 text-text-muted text-sm leading-relaxed border-t border-border pt-4">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </SectionContainer>

  {/* CTA + Form */}
  <SectionContainer background="white" padding="md">
    <div class="max-w-2xl mx-auto">
      <div class="text-center mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-text-primary">
          Get a Roof Built to Last
        </h2>
        <p class="mt-3 text-text-muted">
          Every roof we install comes with industry-leading warranty coverage. Get your free estimate today.
        </p>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-6 md:p-8">
        <LeadCaptureForm client:load source="warranty" />
      </div>
    </div>
  </SectionContainer>
</Layout>
