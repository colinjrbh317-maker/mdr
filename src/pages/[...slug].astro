---
import Layout from "@/layouts/Layout.astro";
import BlockRenderer from "@/components/blocks/BlockRenderer.astro";
import Breadcrumb from "@/components/common/Breadcrumb.astro";
import { loadQuery } from "@/sanity/lib/load-query";
import { PAGE_BY_SLUG_QUERY, ALL_PAGES_QUERY } from "@/sanity/lib/queries";

export const prerender = true;

export async function getStaticPaths() {
  const pages = await loadQuery<Array<{ slug: string }>>(ALL_PAGES_QUERY);
  return pages.map((page) => ({
    params: { slug: page.slug },
  }));
}

const { slug } = Astro.params;
const page = await loadQuery<any>(PAGE_BY_SLUG_QUERY, { slug });

if (!page) {
  return Astro.redirect("/404");
}

const seoTitle = page.seo?.metaTitle || page.title;
const seoDescription = page.seo?.metaDescription;
const ogImage = page.seo?.ogImage;

const breadcrumbItems = [
  { label: "Home", href: "/" },
  { label: page.title },
];

const siteUrl = Astro.site?.href || "https://moderndayroof.com/";
const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: siteUrl },
    { "@type": "ListItem", position: 2, name: page.title },
  ],
};
---

<Layout
  title={seoTitle}
  description={seoDescription}
  ogImage={ogImage}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  <BlockRenderer blocks={page.pageBuilder || []} />
</Layout>
