---
import Layout from "@/layouts/Layout.astro";
import SectionContainer from "@/components/ui/SectionContainer.astro";
import Button from "@/components/ui/Button.astro";
import Breadcrumb from "@/components/common/Breadcrumb.astro";
import LeadCaptureForm from "@/components/forms/LeadCaptureForm";

export const prerender = true;

const breadcrumbItems = [
  { label: "Home", href: "/" },
  { label: "Community" },
];

const givingAreas = [
  {
    icon: "shield",
    title: "Veterans & First Responders",
    description: "Active military, veterans, police, firefighters, and EMTs receive discounted roofing services. It's a small way to say thank you.",
  },
  {
    icon: "storm",
    title: "Storm Relief",
    description: "Free emergency tarping, priority scheduling for storm-damaged homes, and help navigating insurance claims when families need it most.",
  },
  {
    icon: "trophy",
    title: "Local Sponsorships",
    description: "Youth sports, community festivals, school events — you'll see the MDR name on jerseys and banners across southwest Virginia.",
  },
  {
    icon: "heart",
    title: "Volunteer Build Days",
    description: "Our crew donates time and skills to families in need — Habitat builds, emergency repairs for elderly homeowners, and more.",
  },
];
---

<Layout
  title="Community Involvement | Modern Day Roofing"
  description="Modern Day Roofing gives back to the Roanoke and New River Valley communities. See how we support local families, veterans, and first responders."
>
  {/* Hero */}
  <section class="relative min-h-[45vh] flex items-center dark-section" data-transparent-header>
    <div class="absolute inset-0 z-0">
      <img
        src="/assets/projects/Football-banner.jpeg"
        alt="MDR sponsorship banner at local football field"
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-bg-darker/95 via-bg-darker/80 to-bg-darker/50"></div>
    </div>
    <div class="relative z-10 mx-auto max-w-[1200px] px-4 md:px-6 py-16 md:py-24 w-full">
      <Breadcrumb items={breadcrumbItems} />
      <div class="mt-6 max-w-3xl">
        <p class="text-accent-light font-semibold text-sm uppercase tracking-wider mb-3">
          Rooted in the Valley
        </p>
        <h1 class="text-4xl md:text-5xl font-bold text-white">
          Giving Back to Our Community
        </h1>
        <p class="mt-4 text-lg text-white/85 max-w-2xl leading-relaxed">
          We live here. Our crew serves the same neighborhoods we roof — and we show up for them on and off the job site.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          <Button href="/contact" size="lg">Request Community Support</Button>
          <Button href="tel:5405536007" variant="outline" size="lg" class="text-white border-white hover:bg-white hover:text-bg-dark">
            Call (540) 553-6007
          </Button>
        </div>
      </div>
    </div>
  </section>

  {/* Full-width photo — 5986 */}
  <div class="w-full overflow-hidden" style="max-height: 520px;">
    <img
      src="/assets/projects/mdr-roof-dormers-5986.jpg"
      alt="Modern Day Roofing community — serving southwest Virginia"
      class="w-full h-full object-cover object-top"
      loading="lazy"
      style="max-height: 520px;"
    />
  </div>

  {/* How We Give Back */}
  <SectionContainer background="white" padding="lg">
    <div class="text-center mb-12">
      <h2 class="text-2xl md:text-3xl font-display font-bold text-text-primary">
        How We Give Back
      </h2>
      <p class="mt-3 text-text-muted max-w-xl mx-auto">
        Four ways we show up for southwest Virginia — on the job site and off.
      </p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
      {givingAreas.map((area) => (
        <div class="bg-bg-card border border-border rounded-xl p-6">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center flex-shrink-0">
              {area.icon === "shield" && (
                <svg class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
              )}
              {area.icon === "storm" && (
                <svg class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
              )}
              {area.icon === "trophy" && (
                <svg class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
                </svg>
              )}
              {area.icon === "heart" && (
                <svg class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                </svg>
              )}
            </div>
            <div>
              <h3 class="text-lg font-display font-bold text-text-primary mb-1.5">{area.title}</h3>
              <p class="text-sm text-text-body leading-relaxed">{area.description}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </SectionContainer>

  {/* Community photo — 0146 */}
  <div class="w-full overflow-hidden" style="max-height: 560px;">
    <img
      src="/assets/projects/mdr-community-0146.jpg"
      alt="Modern Day Roofing — community involvement"
      class="w-full h-full object-cover object-top"
      loading="lazy"
      style="max-height: 560px;"
    />
  </div>

  {/* CTA + Form */}
  <SectionContainer background="white" padding="md">
    <div class="max-w-2xl mx-auto">
      <div class="text-center mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-text-primary">
          Partner With Us
        </h2>
        <p class="mt-3 text-text-muted">
          Have a community initiative or know a family that needs help? Reach out.
        </p>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-6 md:p-8">
        <LeadCaptureForm client:load source="community" />
      </div>
    </div>
  </SectionContainer>
</Layout>
