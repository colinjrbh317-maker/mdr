---
import Layout from "@/layouts/Layout.astro";
import SectionContainer from "@/components/ui/SectionContainer.astro";
import Button from "@/components/ui/Button.astro";
import Breadcrumb from "@/components/common/Breadcrumb.astro";
import LeadCaptureForm from "@/components/forms/LeadCaptureForm";
import { loadQuery } from "@/sanity/lib/load-query";
import { BEFORE_AFTER_PROJECTS_QUERY } from "@/sanity/lib/queries";
import { urlForImage } from "@/sanity/lib/url-for-image";

export const prerender = true;

const breadcrumbItems = [
  { label: "Home", href: "/" },
  { label: "Projects" },
];

const categories = [
  { label: "All Projects", value: "all" },
  { label: "Roof Replacement", value: "shingle" },
  { label: "Metal Roofing", value: "metal" },
  { label: "Storm Damage", value: "storm-damage" },
  { label: "Repairs", value: "repair" },
  { label: "Gutters", value: "gutters" },
];

const stats = [
  { number: "600+", label: "Roofs Completed" },
  { number: "231", label: "Five-Star Reviews" },
  { number: "15+", label: "Cities Served" },
];

const projects = await loadQuery<any[]>(BEFORE_AFTER_PROJECTS_QUERY).catch(() => []);

const projectsWithUrls = (projects || []).map((p: any) => ({
  ...p,
  beforeUrl: p.beforeImage ? urlForImage(p.beforeImage).width(600).height(400).url() : null,
  afterUrl: p.afterImage ? urlForImage(p.afterImage).width(600).height(400).url() : null,
}));
---

<Layout
  title="Recent Roofing Projects | Modern Day Roofing"
  description="See our recent roofing projects across Roanoke, Christiansburg, and the New River Valley. Before and after photos, case studies, and customer reviews."
>
  {/* Hero */}
  <section class="relative min-h-[40vh] flex items-center dark-section" data-transparent-header>
    <div class="absolute inset-0 z-0">
      <img
        src="/assets/team/ASP_6536-1.jpg"
        alt="Modern Day Roofing project team"
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-bg-darker/95 via-bg-darker/85 to-bg-darker/50"></div>
    </div>
    <div class="relative z-10 mx-auto max-w-[1200px] px-4 md:px-6 py-16 md:py-24 w-full">
      <Breadcrumb items={breadcrumbItems} />
      <div class="mt-6 max-w-3xl">
        <p class="text-accent-light font-semibold text-sm uppercase tracking-wider mb-3">
          See Our Work
        </p>
        <h1 class="text-4xl md:text-5xl font-bold text-white">
          Our Recent Projects
        </h1>
        <p class="mt-4 text-lg text-white/85 max-w-2xl leading-relaxed">
          Every roof tells a story. Browse our completed projects across the Roanoke and New River Valley region — before and after.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          <Button href="/contact" size="lg">Get a Free Estimate</Button>
          <Button href="tel:5405536007" variant="outline" size="lg" class="text-white border-white hover:bg-white hover:text-bg-dark">
            Call (540) 553-6007
          </Button>
        </div>
      </div>
    </div>
  </section>

  {/* Stats Bar */}
  <SectionContainer background="dark" padding="sm">
    <div class="dark-section">
      <div class="grid grid-cols-3 gap-4 max-w-3xl mx-auto text-center">
        {stats.map((stat) => (
          <div>
            <div class="text-3xl md:text-4xl font-display font-bold text-accent">{stat.number}</div>
            <div class="text-sm text-white/70 mt-1">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </SectionContainer>

  {/* Project Grid */}
  <SectionContainer background="light" padding="lg">
    {/* Category Filters */}
    <div class="flex flex-wrap justify-center gap-2 mb-10" id="project-filters">
      {categories.map((cat) => (
        <button
          data-category={cat.value}
          class:list={[
            "project-filter px-4 py-2 rounded-full text-sm font-medium border transition-colors cursor-pointer",
            cat.value === "all"
              ? "bg-accent text-white border-accent"
              : "bg-bg-card text-text-muted border-border hover:border-accent hover:text-text-primary",
          ]}
        >
          {cat.label}
        </button>
      ))}
    </div>

    {/* Projects from Sanity */}
    {projectsWithUrls.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="projects-grid">
        {projectsWithUrls.map((project: any) => (
          <div
            class="project-card bg-bg-card border border-border rounded-xl overflow-hidden transition-all hover:border-accent/50 hover:shadow-lg hover:shadow-accent/5"
            data-category={project.category || "other"}
          >
            <div class="grid grid-cols-2 gap-0.5 bg-border">
              {project.beforeUrl ? (
                <div class="relative aspect-[4/3] overflow-hidden">
                  <img src={project.beforeUrl} alt={`Before: ${project.title}`} class="w-full h-full object-cover" loading="lazy" />
                  <span class="absolute bottom-2 left-2 text-[10px] font-bold uppercase tracking-wider bg-black/60 text-white px-2 py-0.5 rounded">Before</span>
                </div>
              ) : (
                <div class="aspect-[4/3] bg-bg-light flex items-center justify-center">
                  <span class="text-text-dim text-xs">No image</span>
                </div>
              )}
              {project.afterUrl ? (
                <div class="relative aspect-[4/3] overflow-hidden">
                  <img src={project.afterUrl} alt={`After: ${project.title}`} class="w-full h-full object-cover" loading="lazy" />
                  <span class="absolute bottom-2 left-2 text-[10px] font-bold uppercase tracking-wider bg-accent/80 text-white px-2 py-0.5 rounded">After</span>
                </div>
              ) : (
                <div class="aspect-[4/3] bg-bg-light flex items-center justify-center">
                  <span class="text-text-dim text-xs">No image</span>
                </div>
              )}
            </div>
            <div class="p-4">
              {project.category && (
                <span class="inline-block text-[11px] font-semibold uppercase tracking-wider text-accent bg-accent/10 px-2 py-0.5 rounded-full mb-2">
                  {(project.category || "").replace("-", " ")}
                </span>
              )}
              <h3 class="font-display font-bold text-text-primary">{project.title}</h3>
              {project.location && (
                <p class="text-xs text-text-muted mt-1">{project.location}</p>
              )}
              {project.description && (
                <p class="text-sm text-text-body mt-2 line-clamp-2">{project.description}</p>
              )}
            </div>
          </div>
        ))}
      </div>
    ) : (
      <div class="text-center py-12">
        <p class="text-text-muted text-lg">Projects coming soon. Check back for before and after photos of our latest work.</p>
        <Button href="/gallery" variant="outline" size="md" class="mt-6">View Photo Gallery</Button>
      </div>
    )}
  </SectionContainer>

  {/* CTA + Form */}
  <SectionContainer background="white" padding="md">
    <div class="max-w-2xl mx-auto">
      <div class="text-center mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-text-primary">
          Start Your Project — Free Estimate
        </h2>
        <p class="mt-3 text-text-muted">
          Ready to transform your roof? Fill out the form for a free, no-obligation inspection and estimate.
        </p>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-6 md:p-8">
        <LeadCaptureForm client:load source="projects" />
      </div>
    </div>
  </SectionContainer>
</Layout>

<script>
  function initProjectFilters() {
    const filters = document.querySelectorAll<HTMLButtonElement>(".project-filter");
    const cards = document.querySelectorAll<HTMLElement>(".project-card");

    filters.forEach((btn) => {
      btn.addEventListener("click", () => {
        const category = btn.dataset.category;

        // Update active state
        filters.forEach((f) => {
          f.classList.remove("bg-accent", "text-white", "border-accent");
          f.classList.add("bg-bg-card", "text-text-muted", "border-border");
        });
        btn.classList.remove("bg-bg-card", "text-text-muted", "border-border");
        btn.classList.add("bg-accent", "text-white", "border-accent");

        // Filter cards
        cards.forEach((card) => {
          if (category === "all" || card.dataset.category === category) {
            card.style.display = "";
          } else {
            card.style.display = "none";
          }
        });
      });
    });
  }

  initProjectFilters();
  document.addEventListener("astro:after-swap", initProjectFilters);
</script>
