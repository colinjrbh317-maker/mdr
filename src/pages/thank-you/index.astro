---
import Layout from "@/layouts/Layout.astro";

export const prerender = true;

const phone = "(540) 553-6007";
const phoneTel = "5405536007";
---

<Layout
  title="Thanks — We'll Be in Touch | Modern Day Roofing"
  description="Your request was received. A real person from Modern Day Roofing will call within one business day."
>
  <section class="min-h-[70vh] bg-bg-light py-12 md:py-20">
    <div class="mx-auto max-w-[720px] px-4 md:px-6 text-center">
      <div class="inline-flex items-center justify-center w-16 h-16 md:w-20 md:h-20 mb-6 rounded-full bg-accent text-white">
        <svg class="w-8 h-8 md:w-10 md:h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
        </svg>
      </div>

      <h1 class="text-3xl md:text-5xl font-display font-bold text-text-primary mb-4 leading-tight">
        Thanks<span id="ty-name"></span>. We got it.
      </h1>

      <p class="text-base md:text-lg text-text-muted mb-8 max-w-[560px] mx-auto">
        A real person from our team will call you within one business day. No call center. No pressure.
      </p>

      <div class="bg-white rounded-2xl p-6 md:p-8 mb-8 text-left border border-border shadow-sm">
        <h2 class="text-lg md:text-xl font-bold text-text-primary mb-4">Here's what happens next:</h2>
        <ol class="space-y-3 text-sm md:text-base text-text-primary">
          <li class="flex gap-3">
            <span class="flex-shrink-0 w-6 h-6 rounded-full bg-accent text-white text-xs font-bold flex items-center justify-center">1</span>
            <span>We'll call within one business day to confirm your address and schedule your free inspection.</span>
          </li>
          <li class="flex gap-3">
            <span class="flex-shrink-0 w-6 h-6 rounded-full bg-accent text-white text-xs font-bold flex items-center justify-center">2</span>
            <span>Free inspection. About 20 minutes. Drone photos + written report.</span>
          </li>
          <li class="flex gap-3">
            <span class="flex-shrink-0 w-6 h-6 rounded-full bg-accent text-white text-xs font-bold flex items-center justify-center">3</span>
            <span>Written quote within 24 hours. No pressure. No obligation.</span>
          </li>
        </ol>
      </div>

      <p class="text-sm text-text-muted mb-3">Want to accelerate? Call us now:</p>
      <a
        href={`tel:${phoneTel}`}
        class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-accent hover:bg-accent-dark text-white font-bold rounded-lg transition-colors text-base md:text-lg"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        Call {phone}
      </a>
    </div>
  </section>

  <script is:inline>
    try {
      var name = new URLSearchParams(window.location.search).get("name");
      if (name) {
        var el = document.getElementById("ty-name");
        if (el) el.textContent = ", " + name.replace(/[^a-zA-Z '\-]/g, "").slice(0, 30);
      }
    } catch (e) {}
  </script>
</Layout>
