---
import Layout from "@/layouts/Layout.astro";
import SectionContainer from "@/components/ui/SectionContainer.astro";
import Button from "@/components/ui/Button.astro";
import Breadcrumb from "@/components/common/Breadcrumb.astro";
import { loadQuery } from "@/sanity/lib/load-query";
import { TESTIMONIALS_QUERY } from "@/sanity/lib/queries";

export const prerender = true;

const testimonials = await loadQuery<any[]>(TESTIMONIALS_QUERY).catch(() => []);

const breadcrumbItems = [
  { label: "Home", href: "/" },
  { label: "Customer Reviews" },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "Modern Day Roofing",
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: "5.0",
    reviewCount: "231",
    bestRating: "5",
    worstRating: "1",
  },
};
---

<Layout
  title="Customer Reviews | Modern Day Roofing"
  description="Read 231 five-star reviews from homeowners across Virginia's New River Valley and Roanoke. See why families trust Modern Day Roofing for their roofing projects."
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  {/* Hero */}
  <section class="relative min-h-[40vh] flex items-center dark-section" data-transparent-header>
    <div class="absolute inset-0 z-0">
      <img
        src="/assets/web/dji_fly_20250630_140410_766_1751306661861_photo.jpg"
        alt="Modern Day Roofing completed project"
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-bg-darker/95 via-bg-darker/85 to-bg-darker/50"></div>
    </div>
    <div class="relative z-10 mx-auto max-w-[1200px] px-4 md:px-6 py-16 md:py-24 w-full">
      <Breadcrumb items={breadcrumbItems} />
      <div class="mt-6 max-w-3xl">
        <p class="text-accent-light font-semibold text-sm uppercase tracking-wider mb-3">
          Trusted by Homeowners
        </p>
        <h1 class="text-4xl md:text-5xl font-bold text-white">
          Customer Reviews
        </h1>
        <p class="mt-4 text-lg text-white/85 max-w-2xl leading-relaxed">
          Don't just take our word for it. Hear from the families and homeowners we've helped across the New River Valley and Roanoke.
        </p>
      </div>
    </div>
  </section>

  {/* Stats Strip */}
  <SectionContainer background="white" padding="md">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-3xl mx-auto text-center">
      <div>
        <p class="text-4xl md:text-5xl font-display font-bold text-accent">231</p>
        <p class="text-text-muted mt-1">Five-Star Reviews</p>
      </div>
      <div>
        <p class="text-4xl md:text-5xl font-display font-bold text-accent">5.0</p>
        <p class="text-text-muted mt-1">Average Rating</p>
      </div>
      <div>
        <p class="text-4xl md:text-5xl font-display font-bold text-accent">100%</p>
        <p class="text-text-muted mt-1">Would Recommend</p>
      </div>
    </div>
    <div class="text-center mt-8">
      <Button href="https://www.google.com/maps/place/Modern+Day+Roofing" variant="outline" size="lg">
        See All Reviews on Google
      </Button>
    </div>
  </SectionContainer>

  {/* Review Cards */}
  <SectionContainer background="light" padding="lg">
    <div class="text-center mb-12">
      <h2 class="text-2xl md:text-3xl font-display font-bold text-text-primary">
        What Our Customers Say
      </h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-[1200px] mx-auto">
      {testimonials.map((t: any) => (
        <div class="bg-bg-card border border-border rounded-xl p-6 flex flex-col">
          <div class="flex items-center gap-1 mb-3">
            {Array.from({ length: t.rating || 5 }).map(() => (
              <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="text-text-body text-sm leading-relaxed flex-1">"{t.text}"</p>
          <div class="mt-4 pt-4 border-t border-border">
            <p class="font-semibold text-text-primary text-sm">{t.name}</p>
            {t.location && <p class="text-xs text-text-muted">{t.location}</p>}
          </div>
        </div>
      ))}
    </div>
  </SectionContainer>

  {/* CTA */}
  <SectionContainer background="accent" padding="md">
    <div class="text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white">
        Join Our Happy Customers
      </h2>
      <p class="mt-4 text-white/90 max-w-2xl mx-auto text-lg">
        Get your free, no-obligation roof inspection and see why 231 homeowners gave us five stars.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <Button href="/contact" variant="secondary" size="lg">Get Your Free Estimate</Button>
        <Button href="tel:5405536007" variant="ghost" size="lg" class="text-white border-white/30 hover:bg-white/10">
          Call (540) 553-6007
        </Button>
      </div>
    </div>
  </SectionContainer>
</Layout>
