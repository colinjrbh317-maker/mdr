---
import Layout from "@/layouts/Layout.astro";
import SectionContainer from "@/components/ui/SectionContainer.astro";
import Button from "@/components/ui/Button.astro";
import CertificationStrip from "@/components/home/CertificationStrip.astro";
import Breadcrumb from "@/components/common/Breadcrumb.astro";

const team = [
  { name: "Austin Hungate", title: "CEO & Founder", photo: "/assets/web/team-Austin-Hungate-CEO.jpg" },
  { name: "Alex Bohm", title: "COO", photo: "/assets/web/team-Alex-Bohm-COO.jpg" },
  { name: "Alicia Umberto", title: "Marketing & Outreach Director", photo: "/assets/web/team-Alicia-Umberto-Marketing-and-Outreach-Dirctor.jpg" },
  { name: "AJ Jaklitsch", title: "Sales", photo: "/assets/web/team-AJ-Jaklitsch-sales.jpg" },
  { name: "Chris Duncan", title: "Sales", photo: "/assets/web/team-Chris-Duncan-Sales.jpg" },
  { name: "Cory Clement", title: "Sales", photo: "/assets/web/team-Cory-Clement-Sales.jpg" },
];
---

<Layout title="About Modern Day Roofing | GAF Master Elite Contractor" description="Meet the team behind Modern Day Roofing — a GAF President's Club contractor serving Virginia's New River Valley and Roanoke since 2019. 1,000+ roofs completed.">
  <Breadcrumb items={[{ label: "About Us" }]} />

  {/* Hero Section */}
  <SectionContainer background="white" padding="lg">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div>
        <p class="text-accent font-semibold text-sm uppercase tracking-wider mb-3">Our Story</p>
        <h1 class="text-4xl md:text-5xl font-display font-bold text-text-primary leading-tight mb-6">
          We Started With One Truck<br/>and One Promise.
        </h1>
        <p class="text-text-body text-lg leading-relaxed mb-4">
          In just seven years, Modern Day Roofing has grown from a small crew in
          Christiansburg to one of Virginia's most awarded roofing contractors. The
          promise hasn't changed: do the job right, every time, for every home.
        </p>
        <p class="text-text-body text-lg leading-relaxed mb-6">
          As a GAF President's Club member — a distinction held by only the top 1% of
          roofing contractors nationwide — we don't just install roofs. We protect families,
          preserve property values, and stand behind every project with lifetime warranties.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <Button href="/contact" size="lg">Get a Free Estimate</Button>
          <Button href="/services" variant="outline" size="lg">Our Services</Button>
        </div>
      </div>
      <div class="relative">
        <img
          src="/assets/team/ASP_6346-2-1.jpg"
          alt="Modern Day Roofing team photo"
          class="rounded-2xl shadow-xl w-full"
          loading="lazy"
        />
        <div class="absolute -bottom-4 -left-4 bg-accent text-white px-6 py-3 rounded-xl shadow-lg">
          <p class="text-2xl font-bold">1,000+</p>
          <p class="text-xs opacity-90">Roofs Completed</p>
        </div>
      </div>
    </div>
  </SectionContainer>

  {/* Team Section */}
  <SectionContainer background="light" padding="lg">
    <div class="text-center mb-12">
      <p class="text-accent font-semibold text-sm uppercase tracking-wider mb-2">The Team</p>
      <h2 class="text-3xl md:text-4xl font-display font-bold text-text-primary">
        Meet the People Behind Your Roof
      </h2>
      <p class="mt-4 text-text-muted max-w-2xl mx-auto text-lg">
        Our team combines decades of roofing experience with a commitment to customer service
        that sets us apart.
      </p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
      {team.map((member) => (
        <div class="text-center group">
          <div class="relative w-32 h-32 md:w-40 md:h-40 mx-auto mb-4 overflow-hidden rounded-full ring-4 ring-white shadow-lg">
            <img
              src={member.photo}
              alt={member.name}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
          </div>
          <h3 class="text-lg font-bold text-text-primary">{member.name}</h3>
          <p class="text-sm text-text-muted">{member.title}</p>
        </div>
      ))}
    </div>
  </SectionContainer>

  {/* Values Section */}
  <SectionContainer background="white" padding="lg">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-display font-bold text-text-primary">
        Why Homeowners Choose MDR
      </h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
      <div class="text-center p-6">
        <div class="w-14 h-14 mx-auto mb-4 bg-accent/10 rounded-xl flex items-center justify-center">
          <svg class="w-7 h-7 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
          </svg>
        </div>
        <h3 class="text-xl font-bold text-text-primary mb-2">We'll Tell You the Truth</h3>
        <p class="text-text-muted">If your roof has five more years in it, we'll say so. We'd rather earn your trust now and your business later.</p>
      </div>
      <div class="text-center p-6">
        <div class="w-14 h-14 mx-auto mb-4 bg-accent/10 rounded-xl flex items-center justify-center">
          <svg class="w-7 h-7 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
          </svg>
        </div>
        <h3 class="text-xl font-bold text-text-primary mb-2">The Credentials to Back It Up</h3>
        <p class="text-text-muted">GAF doesn't hand out Master Elite status. We earned it by installing full roofing systems to manufacturer spec on every job.</p>
      </div>
      <div class="text-center p-6">
        <div class="w-14 h-14 mx-auto mb-4 bg-accent/10 rounded-xl flex items-center justify-center">
          <svg class="w-7 h-7 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
          </svg>
        </div>
        <h3 class="text-xl font-bold text-text-primary mb-2">Your Neighbors, Not a 1-800 Number</h3>
        <p class="text-text-muted">Two offices in Christiansburg and Roanoke. We live in the community. When a storm hits the NRV, we're already here.</p>
      </div>
    </div>
  </SectionContainer>

  {/* Certifications */}
  <CertificationStrip />

  {/* CTA */}
  <SectionContainer background="accent" padding="md">
    <div class="text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white">
        Let's See Where Your Roof Stands.
      </h2>
      <p class="mt-4 text-white/90 max-w-2xl mx-auto text-lg">
        Book a free, no-pressure inspection. We'll give you an honest report — even if the answer is "you're fine for now."
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold rounded-lg bg-white text-accent hover:bg-gray-100 shadow-lg transition-all min-h-[56px]">
          Schedule Free Inspection
        </a>
        <a href="tel:5405536007" class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold rounded-lg bg-transparent text-white border-2 border-white hover:bg-white/10 transition-all min-h-[56px]">
          Call (540) 553-6007
        </a>
      </div>
    </div>
  </SectionContainer>
</Layout>
