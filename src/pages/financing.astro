---
import Layout from "@/layouts/Layout.astro";
import SectionContainer from "@/components/ui/SectionContainer.astro";
import Button from "@/components/ui/Button.astro";
import Breadcrumb from "@/components/common/Breadcrumb.astro";
import LeadCaptureForm from "@/components/forms/LeadCaptureForm";
import FinancingFunnel from "@/components/financing/FinancingFunnel";
import LenderCards from "@/components/financing/LenderCards.astro";
import FinancingTimeline from "@/components/financing/FinancingTimeline.astro";

export const prerender = true;

const breadcrumbItems = [
  { label: "Home", href: "/" },
  { label: "Financing" },
];

const benefits = [
  {
    icon: "dollar",
    title: "$0 Down Payment",
    description: "Get your roof replaced today with no upfront costs. Start protecting your home immediately.",
  },
  {
    icon: "calendar",
    title: "Low Monthly Payments",
    description: "Affordable monthly payments that fit your budget. Multiple term options available.",
  },
  {
    icon: "check",
    title: "Quick Approval",
    description: "Apply in minutes and get a decision fast. No impact on your credit score to check rates.",
  },
  {
    icon: "shield",
    title: "Multiple Lenders",
    description: "We work with several lending partners to find the best rate and terms for your situation.",
  },
];

const faqs = [
  {
    question: "Will checking my rate affect my credit score?",
    answer: "No. Our pre-qualification form is a soft inquiry only — it does not affect your credit score in any way. Your actual credit is only checked when you apply directly with a lending partner.",
  },
  {
    question: "What credit score do I need?",
    answer: "We have options for many credit situations. Our lending partners work with a range of credit profiles, from excellent to fair. The best way to find out is to complete our quick form — it takes about 3 minutes and won't affect your score.",
  },
  {
    question: "What is the 10% financing fee?",
    answer: "A 10% dealer fee is added to the project cost by the financing provider. This is industry-standard for contractor financing and covers the cost of offering flexible payment options. Your estimated monthly payment already includes this fee.",
  },
  {
    question: "How long does approval take?",
    answer: "Many homeowners receive a lending decision within the same business day. After completing our form, a team member will reach out within 1 business day to guide you through next steps with the recommended lender.",
  },
  {
    question: "Can I pay off my loan early?",
    answer: "Yes — all of our financing options allow you to pay off your balance early without any prepayment penalties. If you come into extra funds, you can pay down or pay off your loan at any time.",
  },
  {
    question: "What if I'm not approved?",
    answer: "We'll work with you to explore alternatives. We partner with multiple lenders, and our team can often find options for homeowners who may not qualify through the first lender we try.",
  },
  {
    question: "Do I need to be the homeowner?",
    answer: "Financing is typically in the homeowner's name, but we can work with your situation. If you're not the homeowner, complete the form anyway and our team will discuss options with you.",
  },
];
---

<Layout
  title="Roof Financing — $0 Down, Low Monthly Payments"
  description="See your estimated monthly payment in under 3 minutes — no credit impact. Modern Day Roofing partners with Hearth for affordable roofing financing with 12+ lenders."
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map(faq => ({
      "@type": "Question",
      name: faq.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: faq.answer,
      },
    })),
  })} />

  {/* 1. Hero (dark bg) */}
  <section class="relative min-h-[40vh] flex items-center dark-section" data-transparent-header>
    <div class="absolute inset-0 z-0">
      <img
        src="/assets/projects/dji_fly_20241025_170718_583_1729890501648_photo-1.jpg"
        alt="Completed roofing project aerial view"
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-bg-darker/95 via-bg-darker/85 to-bg-darker/50"></div>
    </div>
    <div class="relative z-10 mx-auto max-w-[1200px] px-4 md:px-6 py-16 md:py-24 w-full">
      <Breadcrumb items={breadcrumbItems} />
      <div class="mt-6 max-w-3xl">
        <p class="text-accent-light font-semibold text-sm uppercase tracking-wider mb-3">
          Flexible Financing
        </p>
        <h1 class="text-4xl md:text-5xl font-bold text-white">
          Your New Roof. $0 Down. Payments From $89/mo.
        </h1>
        <p class="mt-4 text-lg text-white/85 max-w-2xl leading-relaxed">
          See your estimated monthly payment in under 3 minutes — no credit impact.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          <Button href="#qualify" size="lg">Check Your Rate</Button>
          <Button href="tel:5405536007" variant="outline" size="lg" class="text-white border-white hover:bg-white hover:text-bg-dark">
            Call (540) 553-6007
          </Button>
        </div>
      </div>
    </div>
  </section>

  {/* 2. Payment Anchor Bar (accent bg) */}
  <div class="bg-accent text-white py-4">
    <div class="mx-auto max-w-[1200px] px-4 md:px-6 text-center">
      <p class="text-base md:text-lg font-semibold">
        Most New River Valley homeowners pay between $89–$149/month for a full roof replacement.
      </p>
    </div>
  </div>

  {/* 3. Benefits Grid (white bg) */}
  <SectionContainer background="white" padding="md">
    <div class="text-center mb-12">
      <h2 class="text-2xl md:text-3xl font-bold text-text-primary">
        Why Finance With Us?
      </h2>
      <p class="mt-3 text-text-muted max-w-xl mx-auto">
        We've partnered with trusted lenders to bring you the best financing options available.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {benefits.map((benefit) => (
        <div class="bg-bg-card border border-border rounded-xl p-6 text-center">
          <div class="w-14 h-14 rounded-full bg-accent/10 flex items-center justify-center mx-auto mb-4">
            {benefit.icon === "dollar" && (
              <svg class="w-7 h-7 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            )}
            {benefit.icon === "calendar" && (
              <svg class="w-7 h-7 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            )}
            {benefit.icon === "check" && (
              <svg class="w-7 h-7 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            )}
            {benefit.icon === "shield" && (
              <svg class="w-7 h-7 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            )}
          </div>
          <h3 class="text-lg font-semibold text-text-primary mb-2">{benefit.title}</h3>
          <p class="text-sm text-text-muted">{benefit.description}</p>
        </div>
      ))}
    </div>
  </SectionContainer>

  {/* 4. Financing Funnel (light bg) */}
  <SectionContainer background="light" padding="md" id="qualify">
    <div class="max-w-2xl mx-auto">
      <div class="text-center mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-text-primary">
          See If You Qualify — No Credit Impact
        </h2>
        <p class="mt-3 text-text-muted max-w-xl mx-auto">
          Answer a few quick questions to see your estimated monthly payment and financing options.
        </p>
      </div>
      <FinancingFunnel client:load />
    </div>
  </SectionContainer>

  {/* 5. Social Proof Strip (white bg) */}
  <SectionContainer background="white" padding="sm">
    <div class="flex flex-col md:flex-row items-center justify-center gap-6 md:gap-10 text-center">
      <div class="flex items-center gap-2">
        <div class="flex -space-x-1">
          {[1,2,3,4,5].map(() => (
            <svg class="w-5 h-5 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </div>
        <p class="text-sm font-medium text-text-primary">Trusted by 231+ homeowners</p>
      </div>
      <div class="flex items-center gap-2 text-sm text-text-muted">
        <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
        Lending partner: Hearth &bull; 12+ lenders
      </div>
    </div>
  </SectionContainer>

  {/* 6. Hearth Payment Calculator (light bg) */}
  <SectionContainer background="light" padding="md">
    <div class="max-w-2xl mx-auto">
      <div class="text-center mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-text-primary">
          Estimate Your Monthly Payment
        </h2>
        <p class="mt-3 text-text-muted">
          See what your project could cost per month — click through to request financing options.
        </p>
      </div>
      <iframe id="hearth-widget_calculator_v1" class="w-full border-0" style="min-height: 600px;"></iframe>
      <script
        is:inline
        src="https://widget.gethearth.com/script.js"
        id="hearth-script"
        data-orgid="57208"
        data-partner="modern-day-roofing"
      ></script>
    </div>
  </SectionContainer>

  {/* 7. What to Expect / Timeline (warm bg) */}
  <SectionContainer background="warm" padding="md">
    <FinancingTimeline />
  </SectionContainer>

  {/* 8. Lender Comparison (white bg) */}
  <SectionContainer background="white" padding="md">
    <div class="text-center mb-10">
      <h2 class="text-2xl md:text-3xl font-bold text-text-primary">
        Our Lending Partner
      </h2>
      <p class="mt-3 text-text-muted max-w-xl mx-auto">
        We've partnered with Hearth to connect you with 12+ lenders and find the right fit for your budget.
      </p>
    </div>
    <div class="max-w-3xl mx-auto">
      <LenderCards />
    </div>
  </SectionContainer>

  {/* 9. Transparency Notice (light bg) */}
  <SectionContainer background="light" padding="md">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-text-primary mb-4">
        Honest Pricing, No Surprises
      </h2>
      <p class="text-text-muted leading-relaxed mb-4">
        Like most contractor financing, a 10% dealer fee is added to the project cost by the lending provider. This is standard across the industry and covers the cost of offering flexible payment options.
      </p>
      <p class="text-text-muted leading-relaxed">
        Your estimated monthly payment — shown in both our calculator and results — already includes this fee. No hidden charges.
      </p>
    </div>
  </SectionContainer>

  {/* 10. FAQ (warm bg) */}
  <SectionContainer background="warm" padding="md">
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-10">
        <h2 class="text-2xl md:text-3xl font-bold text-text-primary">
          Financing FAQs
        </h2>
        <p class="mt-3 text-text-muted">
          Common questions about our roofing financing options.
        </p>
      </div>

      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="group bg-bg-card border border-border rounded-xl overflow-hidden">
            <summary class="flex items-center justify-between cursor-pointer p-5 text-left">
              <h3 class="text-text-primary font-medium pr-4">{faq.question}</h3>
              <svg
                class="w-5 h-5 text-text-dim flex-shrink-0 transition-transform group-open:rotate-180"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-5 pb-5 text-text-muted text-sm leading-relaxed border-t border-border pt-4">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </SectionContainer>

  {/* 11. Fallback CTA + Form (white bg) */}
  <SectionContainer background="white" padding="md" id="financing-form">
    <div class="max-w-2xl mx-auto">
      <div class="text-center mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-text-primary">
          Prefer to Talk to Someone?
        </h2>
        <p class="mt-3 text-text-muted">
          Call us at <a href="tel:5405536007" class="text-accent font-semibold hover:underline">(540) 553-6007</a> or fill out the form below.
        </p>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-6 md:p-8" id="fallback-form">
        <LeadCaptureForm client:load source="financing" />
      </div>
    </div>
  </SectionContainer>

  {/* Hide fallback form if already submitted */}
  <script>
    if (sessionStorage.getItem("form_submitted") === "1") {
      const fallback = document.getElementById("fallback-form");
      if (fallback) {
        fallback.innerHTML = '<div class="text-center py-8"><p class="text-xl font-bold text-text-primary mb-2">You\'ve already submitted your information!</p><p class="text-text-muted">Our team will reach out within 1 business day.</p></div>';
      }
    }
  </script>
</Layout>
