---
import Layout from "@/layouts/Layout.astro";
import SectionContainer from "@/components/ui/SectionContainer.astro";
import Button from "@/components/ui/Button.astro";
import Breadcrumb from "@/components/common/Breadcrumb.astro";
import LeadCaptureForm from "@/components/forms/LeadCaptureForm";

export const prerender = true;

const breadcrumbItems = [
  { label: "Home", href: "/" },
  { label: "Financing" },
];

const benefits = [
  {
    icon: "dollar",
    title: "$0 Down Payment",
    description: "Get your roof replaced today with no upfront costs. Start protecting your home immediately.",
  },
  {
    icon: "calendar",
    title: "Low Monthly Payments",
    description: "Affordable monthly payments that fit your budget. Multiple term options available.",
  },
  {
    icon: "check",
    title: "Quick Approval",
    description: "Apply in minutes and get a decision fast. No impact on your credit score to check rates.",
  },
  {
    icon: "shield",
    title: "Multiple Lenders",
    description: "We work with several lending partners to find the best rate and terms for your situation.",
  },
];

const faqs = [
  {
    question: "How does roofing financing work?",
    answer: "Roofing financing allows you to pay for your roof replacement or repair over time with fixed monthly payments. Once approved, we complete the work and you make payments according to your plan terms. It's similar to any other home improvement loan.",
  },
  {
    question: "What credit score do I need to qualify?",
    answer: "Our lending partners work with a range of credit profiles. While better credit scores typically receive lower rates, we have options available for many credit situations. The best way to find out is to apply — checking your rate won't affect your credit score.",
  },
  {
    question: "How long are the financing terms?",
    answer: "We offer flexible terms ranging from 12 months to 144 months (12 years), depending on the lender and your qualifications. Shorter terms generally mean lower total cost, while longer terms provide lower monthly payments.",
  },
  {
    question: "Is there a prepayment penalty?",
    answer: "No. All of our financing options allow you to pay off your balance early without any penalties. If you come into extra funds, you can pay down or pay off your loan at any time.",
  },
  {
    question: "Can I finance insurance deductibles?",
    answer: "Yes, in many cases you can finance the portion of your roof replacement not covered by insurance, including your deductible. Contact us to discuss your specific situation.",
  },
  {
    question: "How quickly can I get started after approval?",
    answer: "Once approved, we can typically schedule your project within 1-2 weeks. For storm damage or emergency situations, we'll work to accommodate you as quickly as possible.",
  },
];
---

<Layout
  title="Roof Financing Options"
  description="Affordable roofing financing with $0 down, low monthly payments, and quick approval. Modern Day Roofing partners with top lenders to make your new roof affordable."
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map(faq => ({
      "@type": "Question",
      name: faq.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: faq.answer,
      },
    })),
  })} />
  {/* Hero with Photo Background */}
  <section class="relative min-h-[40vh] flex items-center dark-section" data-transparent-header>
    <div class="absolute inset-0 z-0">
      <img
        src="/assets/web/dji_fly_20250630_140410_766_1751306661861_photo.jpg"
        alt="Completed roofing project"
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-bg-darker/95 via-bg-darker/85 to-bg-darker/50"></div>
    </div>
    <div class="relative z-10 mx-auto max-w-[1200px] px-4 md:px-6 py-16 md:py-24 w-full">
      <Breadcrumb items={breadcrumbItems} />
      <div class="mt-6 max-w-3xl">
        <p class="text-accent-light font-semibold text-sm uppercase tracking-wider mb-3">
          Affordable Options
        </p>
        <h1 class="text-4xl md:text-5xl font-bold text-white">
          Get Your Roof Now. Pay Over Time.
        </h1>
        <p class="mt-4 text-lg text-white/85 max-w-2xl leading-relaxed">
          A leaking roof doesn't wait for your savings account. $0 down, low monthly payments, and no credit impact to check your rate.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          <Button href="#apply" size="lg">Check Your Rate</Button>
          <Button href="tel:5405536007" variant="outline" size="lg" class="text-white border-white hover:bg-white hover:text-bg-dark">
            Call (540) 553-6007
          </Button>
        </div>
      </div>
    </div>
  </section>

  {/* Benefits Grid */}
  <SectionContainer background="white" padding="md">
    <div class="text-center mb-12">
      <h2 class="text-2xl md:text-3xl font-bold text-text-primary">
        Why Finance With Us?
      </h2>
      <p class="mt-3 text-text-muted max-w-xl mx-auto">
        We've partnered with trusted lenders to bring you the best financing options available.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {benefits.map((benefit) => (
        <div class="bg-bg-card border border-border rounded-xl p-6 text-center">
          <div class="w-14 h-14 rounded-full bg-accent/10 flex items-center justify-center mx-auto mb-4">
            {benefit.icon === "dollar" && (
              <svg class="w-7 h-7 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            )}
            {benefit.icon === "calendar" && (
              <svg class="w-7 h-7 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            )}
            {benefit.icon === "check" && (
              <svg class="w-7 h-7 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            )}
            {benefit.icon === "shield" && (
              <svg class="w-7 h-7 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            )}
          </div>
          <h3 class="text-lg font-semibold text-text-primary mb-2">{benefit.title}</h3>
          <p class="text-sm text-text-muted">{benefit.description}</p>
        </div>
      ))}
    </div>
  </SectionContainer>

  {/* Hearth Widget Placeholder */}
  <SectionContainer background="light" padding="md" id="apply">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-text-primary mb-4">
        Check Your Rate in Minutes
      </h2>
      <p class="text-text-muted mb-8">
        See your personalized financing options without affecting your credit score.
      </p>

      {/* Hearth widget will be embedded here when partner ID is provided */}
      <div class="bg-bg-card border-2 border-dashed border-border rounded-xl p-8 md:p-12">
        <div class="space-y-4">
          <div class="w-16 h-16 rounded-full bg-accent/10 flex items-center justify-center mx-auto">
            <svg class="w-8 h-8 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
            </svg>
          </div>
          <p class="text-text-primary font-semibold text-lg">Online Financing Application</p>
          <p class="text-text-muted text-sm max-w-md mx-auto">
            Our online financing application is coming soon. In the meantime, call us or fill out the form below to discuss financing options.
          </p>
          <Button href="tel:5405536007" variant="primary" size="lg">
            Call to Discuss Financing
          </Button>
        </div>
      </div>
    </div>
  </SectionContainer>

  {/* Financing FAQ */}
  <SectionContainer background="warm" padding="md">
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-10">
        <h2 class="text-2xl md:text-3xl font-bold text-text-primary">
          Financing FAQs
        </h2>
        <p class="mt-3 text-text-muted">
          Common questions about our roofing financing options.
        </p>
      </div>

      <div class="space-y-4">
        {faqs.map((faq, i) => (
          <details class="group bg-bg-card border border-border rounded-xl overflow-hidden">
            <summary class="flex items-center justify-between cursor-pointer p-5 text-left">
              <h3 class="text-text-primary font-medium pr-4">{faq.question}</h3>
              <svg
                class="w-5 h-5 text-text-dim flex-shrink-0 transition-transform group-open:rotate-180"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-5 pb-5 text-text-muted text-sm leading-relaxed border-t border-border pt-4">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </SectionContainer>

  {/* CTA + Form */}
  <SectionContainer background="white" padding="md" id="financing-form">
    <div class="max-w-2xl mx-auto">
      <div class="text-center mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-text-primary">
          Ready to Get Started?
        </h2>
        <p class="mt-3 text-text-muted">
          Contact us to discuss financing options for your roofing project. Free estimates, no obligation.
        </p>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-6 md:p-8">
        <LeadCaptureForm client:load source="financing" />
      </div>
    </div>
  </SectionContainer>
</Layout>
