---
import Layout from "@/layouts/Layout.astro";
import SectionContainer from "@/components/ui/SectionContainer.astro";
import Breadcrumb from "@/components/common/Breadcrumb.astro";

export const prerender = true;

const breadcrumbItems = [
  { label: "Home", href: "/" },
  { label: "Terms of Service" },
];

const lastUpdated = "February 15, 2026";
---

<Layout
  title="Terms of Service"
  description="Modern Day Roofing terms of service. Review our website usage terms, service conditions, and legal information."
>
  <SectionContainer background="warm" padding="lg">
    <Breadcrumb items={breadcrumbItems} />
    <div class="mt-6 max-w-3xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold text-text-primary">Terms of Service</h1>
      <p class="mt-3 text-text-dim text-sm">Last updated: {lastUpdated}</p>
    </div>
  </SectionContainer>

  <SectionContainer background="white" padding="md">
    <div class="max-w-3xl mx-auto prose-dark">
      <div class="space-y-8">
        <section>
          <h2 class="text-xl font-bold text-text-primary mb-3">Acceptance of Terms</h2>
          <p class="text-text-muted leading-relaxed">
            By accessing and using the Modern Day Roofing website (moderndayroof.com), you accept and agree to be bound by these Terms of Service. If you do not agree to these terms, please do not use our website.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-bold text-text-primary mb-3">Services Description</h2>
          <p class="text-text-muted leading-relaxed">
            Modern Day Roofing provides roofing and exterior contracting services in the New River Valley, Roanoke, and surrounding areas of Virginia. Our website provides information about our services, allows you to request estimates, and offers educational content about roofing.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-bold text-text-primary mb-3">Estimates & Pricing</h2>
          <p class="text-text-muted leading-relaxed mb-3">
            All estimates provided through our website or during inspections are non-binding until a formal written contract is signed by both parties. Pricing may vary based on:
          </p>
          <ul class="list-disc list-inside text-text-muted space-y-1.5 ml-2">
            <li>Actual condition discovered during the project</li>
            <li>Material costs at time of installation</li>
            <li>Scope changes requested by the homeowner</li>
            <li>Code compliance requirements</li>
          </ul>
          <p class="text-text-muted leading-relaxed mt-3">
            Final pricing will be confirmed in your service agreement before work begins.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-bold text-text-primary mb-3">Warranties</h2>
          <p class="text-text-muted leading-relaxed">
            Warranty terms vary by product and service type. As a GAF Master Elite contractor, we offer enhanced manufacturer warranties on qualifying GAF roofing systems. Specific warranty details will be provided in your service contract. Warranties are subject to the manufacturer's terms and conditions and require proper maintenance as outlined in your warranty documentation.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-bold text-text-primary mb-3">Website Content</h2>
          <p class="text-text-muted leading-relaxed">
            The content on our website is provided for general informational purposes only. While we strive to keep information accurate and up-to-date, we make no warranties about the completeness, reliability, or accuracy of this information. Any action you take based on the information on our website is at your own risk.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-bold text-text-primary mb-3">Intellectual Property</h2>
          <p class="text-text-muted leading-relaxed">
            All content on this website, including text, graphics, logos, images, and software, is the property of Modern Day Roofing or its content suppliers and is protected by United States copyright laws. You may not reproduce, distribute, or create derivative works from our content without express written permission.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-bold text-text-primary mb-3">Limitation of Liability</h2>
          <p class="text-text-muted leading-relaxed">
            Modern Day Roofing shall not be liable for any indirect, incidental, special, or consequential damages arising from the use of our website or services. Our total liability for any claim arising from these terms shall not exceed the amount you paid for the specific service giving rise to the claim.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-bold text-text-primary mb-3">Insurance Claims</h2>
          <p class="text-text-muted leading-relaxed">
            While we assist homeowners with the insurance claim process for storm damage and covered events, we do not guarantee the outcome of any insurance claim. Final decisions regarding coverage and payment amounts are made by your insurance company. We recommend reviewing your homeowner's insurance policy for specific coverage details.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-bold text-text-primary mb-3">Governing Law</h2>
          <p class="text-text-muted leading-relaxed">
            These terms shall be governed by and construed in accordance with the laws of the Commonwealth of Virginia, without regard to its conflict of law provisions.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-bold text-text-primary mb-3">Contact Us</h2>
          <p class="text-text-muted leading-relaxed">
            If you have questions about these Terms of Service, contact us:
          </p>
          <div class="mt-3 text-text-muted">
            <p><strong class="text-text-primary">Modern Day Roofing</strong></p>
            <p>Christiansburg, VA 24073</p>
            <p>Phone: <a href="tel:5405536007" class="text-accent hover:underline">(540) 553-6007</a></p>
            <p>Email: <a href="mailto:info@moderndayroof.com" class="text-accent hover:underline">info@moderndayroof.com</a></p>
          </div>
        </section>

        <section>
          <h2 class="text-xl font-bold text-text-primary mb-3">Changes to These Terms</h2>
          <p class="text-text-muted leading-relaxed">
            We reserve the right to modify these terms at any time. Changes will be posted on this page with an updated revision date. Your continued use of our website following any changes constitutes acceptance of the updated terms.
          </p>
        </section>
      </div>
    </div>
  </SectionContainer>
</Layout>
