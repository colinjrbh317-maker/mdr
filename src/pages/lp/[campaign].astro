---
import LandingPageLayout from "@/layouts/LandingPageLayout.astro";
import LeadCaptureForm from "@/components/forms/LeadCaptureForm";

export const prerender = true;

const campaigns: Record<string, {
  headline: string;
  subheadline: string;
  cta: string;
  service: string;
  location?: string;
}> = {
  "roof-repair": {
    headline: "Fast, Reliable Roof Repair in [Location]",
    subheadline: "Book your free inspection today — most repairs diagnosed same day.",
    cta: "Book Free Inspection",
    service: "Roof Repair",
  },
  "roof-replacement": {
    headline: "Full Roof Replacement in [Location]",
    subheadline: "0% down financing available. Payments from $89/mo. Free estimate.",
    cta: "Get Free Estimate",
    service: "Roof Replacement",
  },
  "roof-inspection-christiansburg": {
    headline: "Free Roof Inspection in Christiansburg, VA",
    subheadline: "GAF Master Elite certified. No obligation. Honest assessment guaranteed.",
    cta: "Book Free Inspection",
    service: "Roof Inspection",
    location: "Christiansburg",
  },
  "roof-inspection-roanoke": {
    headline: "Free Roof Inspection in Roanoke, VA",
    subheadline: "GAF Master Elite certified. No obligation. Honest assessment guaranteed.",
    cta: "Book Free Inspection",
    service: "Roof Inspection",
    location: "Roanoke",
  },
  "roof-financing": {
    headline: "Roof Financing in [Location] — $0 Down",
    subheadline: "Payments from $89/mo. Apply in minutes — no credit impact to check your rate.",
    cta: "Check If I Qualify",
    service: "Roof Financing",
  },
  "branded": {
    headline: "Modern Day Roofing — [Location]'s Most Trusted Roofer",
    subheadline: "GAF Master Elite certified. 5.0 stars. 1,000+ roofs completed.",
    cta: "Get Free Quote",
    service: "General",
  },
  "roofing-company": {
    headline: "Top-Rated Roofing Company in [Location]",
    subheadline: "5.0 Google rating. 1,000+ roofs. GAF Master Elite certified.",
    cta: "Get Free Estimate",
    service: "General",
  },
  "competitors": {
    headline: "Why [Location] Homeowners Choose MDR",
    subheadline: "5.0 stars. Lifetime warranties. GAF Master Elite. See the difference.",
    cta: "Get Free Quote",
    service: "General",
  },
};

export function getStaticPaths() {
  return [
    "roof-repair",
    "roof-replacement",
    "roof-inspection-christiansburg",
    "roof-inspection-roanoke",
    "roof-financing",
    "branded",
    "roofing-company",
    "competitors",
  ].map((slug) => ({ params: { campaign: slug } }));
}

const { campaign } = Astro.params;
const config = campaigns[campaign as string];

if (!config) {
  return Astro.redirect("/contact");
}

const defaultLocation = config.location || "Southwest Virginia";
const headline = config.headline.replace("[Location]", defaultLocation);
const subheadline = config.subheadline;

const phone = "(540) 553-6007";
const phoneTel = "5405536007";
---

<LandingPageLayout
  title={`${config.service} | Modern Day Roofing`}
  description={subheadline}
>
  {/* Minimal Header — logo + phone only */}
  <header class="bg-white border-b border-border">
    <div class="mx-auto max-w-[1200px] px-4 md:px-6 py-4 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2" aria-label="Modern Day Roofing home">
        <img
          src="/assets/logos/mdr-logo-dark.svg"
          alt="Modern Day Roofing"
          width="180"
          height="48"
          class="h-10 w-auto"
          onerror="this.onerror=null;this.alt='Modern Day Roofing';this.style.display='none';this.parentElement.insertAdjacentHTML('beforeend','<span class=\'font-display font-bold text-xl text-text-primary\'>Modern Day Roofing</span>');"
        />
      </a>
      <a
        href={`tel:${phoneTel}`}
        class="flex items-center gap-2 text-text-primary hover:text-accent transition-colors font-semibold text-sm md:text-base"
      >
        <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        <span class="hidden sm:inline">{phone}</span>
        <span class="sm:hidden">Call Now</span>
      </a>
    </div>
  </header>

  {/* Hero Section */}
  <section class="relative py-14 md:py-20 dark-section">
    <div class="absolute inset-0 z-0">
      <img
        src="/assets/projects/dji_fly_20251105_160154_425_1762438973026_photo.JPG"
        alt="Roof project by Modern Day Roofing"
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-bg-darker/90"></div>
    </div>
    <div class="relative z-10 mx-auto max-w-[1200px] px-4 md:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-start">
        {/* Left — headline + subheadline */}
        <div class="pt-4 md:pt-8">
          <h1
            class="text-3xl md:text-4xl lg:text-5xl font-display font-bold mb-5 leading-tight lp-headline"
            style="color: #fff;"
            data-location-template={config.headline}
          >
            {headline}
          </h1>
          <p class="text-lg md:text-xl leading-relaxed mb-8" style="color: rgba(255,255,255,0.85);">
            {subheadline}
          </p>
          {/* Trust signals under headline on desktop */}
          <div class="hidden lg:flex flex-wrap gap-x-6 gap-y-3 text-sm" style="color: rgba(255,255,255,0.7);">
            <span class="flex items-center gap-1.5">
              <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
              5.0 Google Rating
            </span>
            <span>1,000+ Roofs Completed</span>
            <span>GAF Master Elite Certified</span>
            <span>$0 Down Financing</span>
          </div>
        </div>

        {/* Right — form */}
        <div class="bg-white rounded-2xl shadow-xl p-6 md:p-8">
          <h2 class="text-xl font-display font-bold text-text-primary mb-1 text-center">
            {config.cta}
          </h2>
          <p class="text-sm text-text-muted mb-5 text-center">
            Free, no-obligation — takes 30 seconds.
          </p>
          <LeadCaptureForm client:load source={`lp-${campaign}`} />
        </div>
      </div>
    </div>
  </section>

  {/* Trust Bar — visible on all screens */}
  <section class="bg-bg-light border-b border-border py-5">
    <div class="mx-auto max-w-[1200px] px-4 md:px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
        <div class="flex flex-col items-center gap-1">
          <div class="flex items-center gap-1">
            <svg class="w-5 h-5 text-yellow-500" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
            <span class="font-bold text-text-primary">5.0</span>
          </div>
          <span class="text-xs text-text-muted">Google Rating</span>
        </div>
        <div class="flex flex-col items-center gap-1">
          <span class="font-bold text-text-primary">1,000+</span>
          <span class="text-xs text-text-muted">Roofs Completed</span>
        </div>
        <div class="flex flex-col items-center gap-1">
          <span class="font-bold text-text-primary text-sm">GAF Master Elite</span>
          <span class="text-xs text-text-muted">Top 2% of Roofers</span>
        </div>
        <div class="flex flex-col items-center gap-1">
          <span class="font-bold text-text-primary">$0 Down</span>
          <span class="text-xs text-text-muted">Financing Available</span>
        </div>
      </div>
    </div>
  </section>

  {/* What to Expect — builds trust */}
  <section class="bg-white py-12 md:py-16">
    <div class="mx-auto max-w-[900px] px-4 md:px-6">
      <h2 class="text-2xl md:text-3xl font-display font-bold text-text-primary text-center mb-10">
        What Happens After You Reach Out
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-accent text-white flex items-center justify-center text-lg font-bold">1</div>
          <h3 class="font-bold text-text-primary mb-2">We Call Within 24 Hours</h3>
          <p class="text-sm text-text-muted">A real person from our team reaches out to discuss your project and answer any questions.</p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-accent text-white flex items-center justify-center text-lg font-bold">2</div>
          <h3 class="font-bold text-text-primary mb-2">Free On-Site Inspection</h3>
          <p class="text-sm text-text-muted">Our certified inspector checks your roof thoroughly with photos and an honest assessment.</p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-accent text-white flex items-center justify-center text-lg font-bold">3</div>
          <h3 class="font-bold text-text-primary mb-2">Transparent Quote</h3>
          <p class="text-sm text-text-muted">You get a detailed, itemized estimate. No surprises, no pressure, no obligation.</p>
        </div>
      </div>
    </div>
  </section>

  {/* Minimal Footer */}
  <footer class="bg-bg-darker py-8 dark-section">
    <div class="mx-auto max-w-[1200px] px-4 md:px-6 text-center">
      <p class="text-sm mb-2" style="color: rgba(255,255,255,0.7);">
        Modern Day Roofing &mdash; 80 College St. STE R, Christiansburg, VA 24073
      </p>
      <a
        href={`tel:${phoneTel}`}
        class="text-lg font-bold hover:text-accent transition-colors"
        style="color: #fff;"
      >
        {phone}
      </a>
      <p class="text-xs mt-4" style="color: rgba(255,255,255,0.4);">
        &copy; {new Date().getFullYear()} Modern Day Roofing. All rights reserved.
      </p>
    </div>
  </footer>

  {/* Sticky Bottom Bar — Mobile Only */}
  <div
    id="lp-sticky-bar"
    class="fixed bottom-0 left-0 right-0 z-50 bg-accent text-white py-3 px-4 text-center lg:hidden shadow-[0_-2px_10px_rgba(0,0,0,0.15)]"
  >
    <p class="text-sm font-bold mb-1">$500 Off Any Roofing Project</p>
    <p class="text-xs opacity-90">Limited time — mention this offer when you call</p>
    <a
      href={`tel:${phoneTel}`}
      class="inline-block mt-2 px-5 py-2 bg-white text-accent font-bold text-sm rounded-lg hover:bg-gray-100 transition-colors"
    >
      Call Now: {phone}
    </a>
  </div>

  {/* Bottom padding on mobile so content isn't hidden behind sticky bar */}
  <div class="h-28 lg:hidden" aria-hidden="true"></div>

  {/* Client-side location replacement script */}
  <script is:inline>
    (function() {
      try {
        var location = sessionStorage.getItem("mdr_location");
        if (location) {
          var el = document.querySelector(".lp-headline");
          if (el) {
            var template = el.getAttribute("data-location-template");
            if (template && template.indexOf("[Location]") !== -1) {
              el.textContent = template.replace(/\[Location\]/g, location);
            }
          }
        }
      } catch(e) {}
    })();
  </script>
</LandingPageLayout>
