    faqs: [
      { q: "Is the second opinion really free?", a: "Yes. Bring us the quote, we'll inspect the roof, and give you an honest written comparison." },
      { q: "What if the other quote is fair?", a: "We'll tell you. We'd rather be honest than win every comparison." },
      { q: "Do you handle insurance claims?", a: "Yes. If storm damage is in play, we'll meet the adjuster on-roof and help document supplements." },
      { q: "What's the warranty?", a: "Lifetime workmanship. 50-year material. Transferable upgrade available." },
      ...SHARED_FAQS_END,
    ],
    finalCtaHeadline: "A roof is a 30-year decision. Pick a roofer who'll still be here in 30 years.",
    finalCtaSubhead: "Free second opinion. No obligation. Written comparison.",
  },
};

export function getStaticPaths() {
  return [
    "roof-repair",
    "roof-replacement",
    "roof-inspection-christiansburg",
    "roof-inspection-roanoke",
    "roof-financing",
    "branded",
    "roofing-company",
    "competitors",
  ].map((slug) => ({ params: { campaign: slug } }));
}

const { campaign } = Astro.params;
const config = campaigns[campaign as string];

if (!config) {
  return Astro.redirect("/contact");
}

const defaultLocation = config.location || "Southwest Virginia";
const headline = config.headline.replaceAll("[Location]", defaultLocation);
const subheadline = config.subheadline;
const finalCtaHeadline = config.finalCtaHeadline.replaceAll("[Location]", defaultLocation);

// Channel detection: ?channel=google|meta, or hostname-based (go.* = meta, lp.* = google)
const hostname = Astro.request.headers.get("host") || "";
const urlChannel = Astro.url.searchParams.get("channel");
let channel: "google" | "meta" | "direct" = "direct";
if (urlChannel === "meta" || urlChannel === "google") {
  channel = urlChannel;
} else if (hostname.startsWith("go.")) {
  channel = "meta";
} else if (hostname.startsWith("lp.")) {
  channel = "google";
}

const phone = "(540) 553-6007";
const phoneTel = "5405536007";
const heroImg = config.heroImage || "/assets/projects/dji_fly_20251105_160154_425_1762438973026_photo.JPG";
---

<LandingPageLayout
  title={`${config.service} | Modern Day Roofing`}
  description={subheadline}
  channel={channel}
>
  {/* Minimal header: logo + click-to-call */}
  <header class="bg-white border-b border-border">
    <div class="mx-auto max-w-[1200px] px-4 md:px-6 py-3 md:py-4 flex items-center justify-between">
      <a href="/" aria-label="Modern Day Roofing home">
        <Logo size="md" />
      </a>
      <a
        href={`tel:${phoneTel}`}
        data-lp-phone-cta="header"
        class="flex items-center gap-2 text-text-primary hover:text-accent transition-colors font-bold text-sm md:text-base"
      >
        <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        <span class="hidden sm:inline">{phone}</span>
        <span class="sm:hidden">Call Now</span>
      </a>
    </div>
  </header>

  {/* Hero */}
  <section class="relative">
    <div class="absolute inset-0 z-0">
      <img src={heroImg} alt="" class="w-full h-full object-cover" loading="eager" fetchpriority="high" />
      <div class="absolute inset-0 bg-bg-darker/85"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-[1200px] px-4 md:px-6 py-6 md:py-12 lg:py-16">
      <div class="grid grid-cols-1 lg:grid-cols-[1.1fr_1fr] gap-6 lg:gap-12 items-center">
        <div class="order-2 lg:order-1 pt-2 lg:pt-0 dark-section">
          <h1
            class="text-2xl md:text-4xl lg:text-5xl font-display font-bold mb-3 md:mb-5 leading-[1.15] lp-headline"
            style="color: #fff;"
            data-location-template={config.headline}
          >
            {headline}
          </h1>
          <p
            class="text-base md:text-lg lg:text-xl leading-relaxed mb-4 md:mb-6 lp-subheadline"
            style="color: rgba(255,255,255,0.9);"
            data-location-template={config.subheadline}
          >
            {subheadline}
          </p>
          <ul class="flex flex-col gap-2 md:gap-2.5 text-sm md:text-base" style="color: rgba(255,255,255,0.85);">
            {config.proofPoints.map((point) => (
              <li class="flex items-center gap-2">
                <svg class="w-5 h-5 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                </svg>
                <span>{point}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="order-1 lg:order-2 bg-white rounded-2xl shadow-2xl p-5 md:p-7">
          <h2 class="text-lg md:text-xl font-display font-bold text-text-primary mb-1 text-center">
            {config.formCardTitle}
          </h2>
          <p class="text-xs md:text-sm text-text-muted mb-4 text-center">
            Free, no obligation. Takes 30 seconds.
          </p>
          <LeadCaptureForm client:load source={`lp-${campaign}`} channel={channel} />
        </div>
      </div>
    </div>
  </section>

  {/* Authority / certification row */}
  <CertificationStrip />

  {/* Risk reversal + 3-step (kept from original) */}
  <section class="bg-white py-8 md:py-12">
    <div class="mx-auto max-w-[900px] px-4 md:px-6">
      <p class="text-center text-text-muted text-sm md:text-base mb-6 md:mb-8">
        {config.riskReversal}
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
        <div class="text-center">
          <div class="w-10 h-10 md:w-12 md:h-12 mx-auto mb-3 rounded-full bg-accent text-white flex items-center justify-center text-lg font-bold">1</div>
          <h3 class="font-bold text-text-primary mb-1.5">We Call Within 24 Hours</h3>
          <p class="text-sm text-text-muted">A real person answers. No call center.</p>
        </div>
        <div class="text-center">
          <div class="w-10 h-10 md:w-12 md:h-12 mx-auto mb-3 rounded-full bg-accent text-white flex items-center justify-center text-lg font-bold">2</div>
          <h3 class="font-bold text-text-primary mb-1.5">Free Roof Inspection</h3>
          <p class="text-sm text-text-muted">Drone photos and a written assessment.</p>
        </div>
        <div class="text-center">
          <div class="w-10 h-10 md:w-12 md:h-12 mx-auto mb-3 rounded-full bg-accent text-white flex items-center justify-center text-lg font-bold">3</div>
          <h3 class="font-bold text-text-primary mb-1.5">Honest, Itemized Quote</h3>
          <p class="text-sm text-text-muted">No surprises. No pressure. No obligation.</p>
        </div>
      </div>
    </div>
  </section>

  {/* Social proof strip */}
  <section class="bg-bg-warm py-6 md:py-8">
    <div class="mx-auto max-w-[1200px] px-4 md:px-6 text-center">
      <p class="text-sm md:text-base font-semibold text-text-primary">{config.socialProofLine}</p>
    </div>
  </section>

  {/* Benefits grid */}
  <section class="bg-white py-12 md:py-20">
    <div class="mx-auto max-w-[1200px] px-4 md:px-6">
      <div class="text-center mb-8 md:mb-12">
        <h2 class="text-2xl md:text-4xl font-display font-bold text-text-primary mb-3">
          Why <span data-location-template={`[Location]`}>{defaultLocation}</span> homeowners pick Modern Day Roofing
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
        {config.benefits.map((b) => (
          <div class="bg-bg-light rounded-xl p-5 md:p-6 border-t-4 border-t-accent">
            <h3 class="font-display font-bold text-lg text-text-primary mb-2">{b.title}</h3>
            <p class="text-sm md:text-base text-text-muted leading-relaxed">{b.body}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-8 md:mt-10">
        <a href="#top" class="inline-flex items-center justify-center px-7 py-3.5 bg-accent hover:bg-accent-dark text-white font-bold rounded-lg transition-colors text-sm md:text-base">
          {config.cta} →
        </a>
      </div>
    </div>
  </section>

  {/* Service details */}
  <section class="bg-bg-light py-12 md:py-20">
    <div class="mx-auto max-w-[1000px] px-4 md:px-6">
      <h2 class="text-2xl md:text-4xl font-display font-bold text-text-primary mb-6 md:mb-10 text-center">
        {config.detailsTitle}
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6">
        {config.details.map((d) => (
          <div class="bg-white rounded-xl p-5 md:p-6 border border-border shadow-sm">
            <h3 class="font-display font-bold text-base md:text-lg text-text-primary mb-2">{d.title}</h3>
            <p class="text-sm md:text-base text-text-muted leading-relaxed">{d.body}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-8 md:mt-10">
        <a href="#top" class="inline-flex items-center justify-center px-7 py-3.5 bg-accent hover:bg-accent-dark text-white font-bold rounded-lg transition-colors text-sm md:text-base">
          {config.cta} →
        </a>
      </div>
    </div>
  </section>

  {/* Process */}
  <section class="bg-white py-12 md:py-20">
    <div class="mx-auto max-w-[1000px] px-4 md:px-6">
      <div class="text-center mb-8 md:mb-12">
        <h2 class="text-2xl md:text-4xl font-display font-bold text-text-primary mb-2">How it works</h2>
        <p class="text-sm md:text-base text-text-muted">{config.processIntro}</p>
      </div>
      <ol class="space-y-4 md:space-y-6">
        {PROCESS_STEPS.map((s) => (
          <li class="flex gap-4 md:gap-6 items-start">
            <div class="flex-shrink-0 w-10 h-10 md:w-12 md:h-12 rounded-full bg-accent text-white font-bold text-base md:text-lg flex items-center justify-center">{s.n}</div>
            <div>
              <h3 class="font-display font-bold text-base md:text-lg text-text-primary mb-1">{s.t}</h3>
              <p class="text-sm md:text-base text-text-muted leading-relaxed">{s.b}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  {/* Testimonials — reuse real reviews from GoogleReviews */}
  <GoogleReviews />

  {/* FAQ */}
  <section class="bg-white py-12 md:py-20">
    <div class="mx-auto max-w-[900px] px-4 md:px-6">
      <h2 class="text-2xl md:text-4xl font-display font-bold text-text-primary mb-6 md:mb-10 text-center">
        Frequently asked questions
      </h2>
      <div class="flex flex-col gap-3">
        {config.faqs.map((f) => (
          <details class="group bg-bg-light rounded-xl border border-border overflow-hidden">
            <summary class="cursor-pointer list-none px-5 md:px-6 py-4 md:py-5 flex items-center justify-between gap-4 hover:bg-bg-warm transition-colors">
              <span class="font-display font-bold text-base md:text-lg text-text-primary" data-location-template={f.q}>{f.q.replaceAll("[Location]", defaultLocation)}</span>
              <svg class="w-5 h-5 flex-shrink-0 text-accent transition-transform group-open:rotate-45" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
              </svg>
            </summary>
            <div class="px-5 md:px-6 pb-5 md:pb-6 text-sm md:text-base text-text-muted leading-relaxed">
              {f.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  {/* Final CTA */}
  <section class="bg-bg-darker py-12 md:py-20 dark-section">
    <div class="mx-auto max-w-[900px] px-4 md:px-6 text-center">
      <h2 class="text-3xl md:text-5xl font-display font-bold mb-3 md:mb-5 leading-tight" style="color: #fff;">
        {finalCtaHeadline}
      </h2>
      <p class="text-base md:text-lg mb-8" style="color: rgba(255,255,255,0.85);">
        {config.finalCtaSubhead}
      </p>
      <div class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-4 md:gap-6 items-start max-w-[700px] mx-auto">
        <div class="bg-white rounded-2xl shadow-2xl p-5 md:p-6">
          <LeadCaptureForm client:visible source={`lp-${campaign}-bottom`} channel={channel} />
        </div>
        <a
          href={`tel:${phoneTel}`}
          data-lp-phone-cta="final"
          class="inline-flex items-center justify-center gap-2 px-6 py-4 md:px-7 md:py-5 bg-accent hover:bg-accent-dark text-white font-bold rounded-lg transition-colors text-base md:text-lg whitespace-nowrap"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Call {phone}
        </a>
      </div>
      <p class="text-xs md:text-sm mt-6" style="color: rgba(255,255,255,0.6);">
        Open Monday–Saturday. Real humans answer.
      </p>
    </div>
  </section>

  {/* Minimal footer */}
  <footer class="bg-bg-dark py-6 md:py-8 dark-section">
    <div class="mx-auto max-w-[1200px] px-4 md:px-6 text-center">
      <p class="text-xs md:text-sm mb-2" style="color: rgba(255,255,255,0.7);">
        Modern Day Roofing · 80 College St. STE R, Christiansburg, VA 24073 · VA Class A Contractor · Fully insured
      </p>
      <a
        href={`tel:${phoneTel}`}
        data-lp-phone-cta="footer"
        class="text-base md:text-lg font-bold hover:text-accent transition-colors"
        style="color: #fff;"
      >
        {phone}
      </a>
      <p class="text-[11px] md:text-xs mt-3" style="color: rgba(255,255,255,0.4);">
        &copy; {new Date().getFullYear()} Modern Day Roofing. All rights reserved.
      </p>
    </div>
  </footer>

  {/* Sticky mobile call bar */}
  <a
    href={`tel:${phoneTel}`}
    data-lp-phone-cta="sticky"
    class="fixed bottom-0 left-0 right-0 z-50 bg-accent hover:bg-accent-dark text-white py-3.5 px-4 text-center font-bold lg:hidden shadow-[0_-2px_10px_rgba(0,0,0,0.2)] flex items-center justify-center gap-2"
  >
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
    </svg>
    <span>Call Now: {phone}</span>
  </a>
  <div class="h-14 lg:hidden" aria-hidden="true"></div>

  {/* Dynamic location + keyword insertion */}
  <script is:inline>
    (function() {
      function sanitize(s) { return (s || "").replace(/[^a-zA-Z .'\-+]/g, "").trim().slice(0, 60); }

      function applyCity(city) {
        if (!city) return;
        document.querySelectorAll("[data-location-template]").forEach(function(el) {
          var template = el.getAttribute("data-location-template");
          if (template && template.indexOf("[Location]") !== -1) {
            var filled = template.replace(/\[Location\]/g, city);
            // If the element already has [Keyword] placeholders too, preserve them to be filled below
            el.textContent = filled;
          }
        });
      }

      function applyKeyword(kw) {
        if (!kw) return;
        var pretty = kw.replace(/\+/g, " ").replace(/\s+/g, " ").trim();
        document.querySelectorAll("[data-location-template]").forEach(function(el) {
          if (el.textContent && el.textContent.indexOf("[Keyword]") !== -1) {
            el.textContent = el.textContent.replace(/\[Keyword\]/g, pretty);
          }
        });
      }

      try {
        var params = new URLSearchParams(window.location.search);
        var paramCity = sanitize(params.get("city") || params.get("loc"));
        var paramKw = sanitize(params.get("kw") || params.get("keyword"));

        if (paramCity) {
          sessionStorage.setItem("mdr_location", paramCity);
          sessionStorage.setItem("mdr_location_src", "param");
          applyCity(paramCity);
        } else if (sessionStorage.getItem("mdr_location_src") === "param") {
          var stored = sanitize(sessionStorage.getItem("mdr_location"));
          if (stored) applyCity(stored);
        } else {
          sessionStorage.removeItem("mdr_location");
          sessionStorage.removeItem("mdr_location_src");
          fetch("/api/geo", { cache: "no-store" })
            .then(function(r) { return r.ok ? r.json() : null; })
            .then(function(data) {
              if (data && data.city) applyCity(sanitize(data.city));
              if (paramKw) applyKeyword(paramKw);
            })
            .catch(function() {});
        }

        if (paramKw) applyKeyword(paramKw);
      } catch (e) {}
    })();
  </script>

  {/* Phone click conversion tracking */}
  <script is:inline>
    document.querySelectorAll("[data-lp-phone-cta]").forEach(function(el) {
      el.addEventListener("click", function() {
        var source = el.getAttribute("data-lp-phone-cta") || "lp";
        try { window.hj && window.hj("event", "phone_click_lp"); } catch (e) {}
        try { window.gtag && window.gtag("event", "phone_click", { event_category: "cro", event_label: source }); } catch (e) {}
        try {
          var convVal = (window.__GADS_CALL_CONVERSION__ || "");
          if (window.gtag && convVal) {
            window.gtag("event", "conversion", { send_to: convVal });
          }
        } catch (e) {}
        try { window.fbq && window.fbq("trackCustom", "phone_click", { source: source }); } catch (e) {}
      });
    });
  </script>
</LandingPageLayout>
