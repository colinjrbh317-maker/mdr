export function getStaticPaths() {
  return [
    "roof-repair",
    "roof-replacement",
    "roof-inspection-christiansburg",
    "roof-inspection-roanoke",
    "roof-financing",
    "branded",
    "roofing-company",
    "competitors",
  ].map((slug) => ({ params: { campaign: slug } }));
}

const { campaign } = Astro.params;
const config = campaigns[campaign as string];

if (!config) {
  return Astro.redirect("/contact");
}

const defaultLocation = config.location || "Southwest Virginia";
const headline = config.headline.replaceAll("[Location]", defaultLocation);
const subheadline = config.subheadline;
const finalCtaHeadline = config.finalCtaHeadline.replaceAll("[Location]", defaultLocation);

// Channel detection: ?channel=google|meta, or hostname-based (go.* = meta, lp.* = google)
const hostname = Astro.request.headers.get("host") || "";
const urlChannel = Astro.url.searchParams.get("channel");
let channel: "google" | "meta" | "direct" = "direct";
if (urlChannel === "meta" || urlChannel === "google") {
  channel = urlChannel;
} else if (hostname.startsWith("go.")) {
  channel = "meta";
} else if (hostname.startsWith("lp.")) {
  channel = "google";
}

const phone = "(540) 553-6007";
const phoneTel = "5405536007";
const heroImg = config.heroImage || "/assets/projects/dji_fly_20251105_160154_425_1762438973026_photo.JPG";
const photoSet = PHOTO_SETS[campaign as string] || PHOTO_SETS["default"];
