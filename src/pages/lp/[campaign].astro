            <div class="flex-shrink-0 w-10 h-10 md:w-12 md:h-12 rounded-full bg-accent text-white font-bold text-base md:text-lg flex items-center justify-center">{s.n}</div>
            <div>
              <h3 class="font-display font-bold text-base md:text-lg text-text-primary mb-1">{s.t}</h3>
              <p class="text-sm md:text-base text-text-muted leading-relaxed">{s.b}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  {/* FAQ */}
  <section class="bg-white py-12 md:py-20">
    <div class="mx-auto max-w-[900px] px-4 md:px-6">
      <h2 class="text-2xl md:text-4xl font-display font-bold text-text-primary mb-6 md:mb-10 text-center">
        Frequently asked questions
      </h2>
      <div class="flex flex-col gap-3">
        {config.faqs.map((f) => (
          <details class="group bg-bg-light rounded-xl border border-border overflow-hidden">
            <summary class="cursor-pointer list-none px-5 md:px-6 py-4 md:py-5 flex items-center justify-between gap-4 hover:bg-bg-warm transition-colors">
              <span class="font-display font-semibold text-base md:text-lg text-text-primary" data-location-template={f.q}>{f.q.replaceAll("[Location]", defaultLocation)}</span>
              <svg class="w-5 h-5 flex-shrink-0 text-accent transition-transform group-open:rotate-45" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
              </svg>
            </summary>
            <div class="px-5 md:px-6 pb-5 md:pb-6 text-sm md:text-base text-text-muted leading-relaxed">
              {f.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  {/* Final CTA */}
  <section class="bg-bg-darker py-12 md:py-20 dark-section">
    <div class="mx-auto max-w-[900px] px-4 md:px-6 text-center">
      <h2 class="text-3xl md:text-5xl font-display font-bold mb-3 md:mb-5 leading-tight" style="color: #fff;">
        {finalCtaHeadline}
      </h2>
      <p class="text-base md:text-lg mb-8" style="color: rgba(255,255,255,0.85);">
        {config.finalCtaSubhead}
      </p>
      <div class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-4 md:gap-6 items-start max-w-[700px] mx-auto">
        <div class="lp-form-light bg-white rounded-2xl shadow-2xl p-5 md:p-6">
          <LeadCaptureForm client:visible source={`lp-${campaign}-bottom`} channel={channel} />
        </div>
        <a
          href={`tel:${phoneTel}`}
          data-lp-phone-cta="final"
          class="inline-flex items-center justify-center gap-2 px-6 py-4 md:px-7 md:py-5 bg-accent hover:bg-accent-dark text-white font-bold rounded-lg transition-colors text-base md:text-lg whitespace-nowrap"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Call {phone}
        </a>
      </div>
      <p class="text-xs md:text-sm mt-6" style="color: rgba(255,255,255,0.6);">
        Open Monday to Friday, 8:30am to 5:00pm. 24/7 emergency storm damage service.
      </p>
    </div>
  </section>

  {/* Minimal footer */}
  <footer class="bg-bg-dark py-6 md:py-8 dark-section">
    <div class="mx-auto max-w-[1200px] px-4 md:px-6 text-center">
      <p class="text-xs md:text-sm mb-2" style="color: rgba(255,255,255,0.7);">
        Modern Day Roofing · 80 College St. STE R, Christiansburg, VA 24073 · VA Class A Contractor · Fully insured
      </p>
      <a
        href={`tel:${phoneTel}`}
        data-lp-phone-cta="footer"
        class="text-base md:text-lg font-bold hover:text-accent transition-colors"
        style="color: #fff;"
      >
        {phone}
      </a>
      <p class="text-[11px] md:text-xs mt-3" style="color: rgba(255,255,255,0.4);">
        &copy; {new Date().getFullYear()} Modern Day Roofing. All rights reserved.
      </p>
    </div>
  </footer>

  {/* Sticky mobile call bar */}
  <a
    href={`tel:${phoneTel}`}
    data-lp-phone-cta="sticky"
    class="fixed bottom-0 left-0 right-0 z-50 bg-accent hover:bg-accent-dark text-white py-3.5 px-4 text-center font-bold lg:hidden shadow-[0_-2px_10px_rgba(0,0,0,0.2)] flex items-center justify-center gap-2"
  >
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
    </svg>
    <span>Call Now: {phone}</span>
  </a>
  <div class="h-14 lg:hidden" aria-hidden="true"></div>

  {/* Dynamic location + keyword insertion */}
  <script is:inline>
    (function() {
      function sanitize(s) { return (s || "").replace(/[^a-zA-Z .'\-+]/g, "").trim().slice(0, 60); }

      function applyCity(city) {
        if (!city) return;
        document.querySelectorAll("[data-location-template]").forEach(function(el) {
          var template = el.getAttribute("data-location-template");
          if (template && template.indexOf("[Location]") !== -1) {
            var filled = template.replace(/\[Location\]/g, city);
            // If the element already has [Keyword] placeholders too, preserve them to be filled below
            el.textContent = filled;
          }
        });
      }

      function applyKeyword(kw) {
        if (!kw) return;
        var pretty = kw.replace(/\+/g, " ").replace(/\s+/g, " ").trim();
        document.querySelectorAll("[data-location-template]").forEach(function(el) {
          if (el.textContent && el.textContent.indexOf("[Keyword]") !== -1) {
            el.textContent = el.textContent.replace(/\[Keyword\]/g, pretty);
          }
        });
      }

      try {
        var params = new URLSearchParams(window.location.search);
        var paramCity = sanitize(params.get("city") || params.get("loc"));
        var paramKw = sanitize(params.get("kw") || params.get("keyword"));

        if (paramCity) {
          sessionStorage.setItem("mdr_location", paramCity);
          sessionStorage.setItem("mdr_location_src", "param");
          applyCity(paramCity);
        } else if (sessionStorage.getItem("mdr_location_src") === "param") {
          var stored = sanitize(sessionStorage.getItem("mdr_location"));
          if (stored) applyCity(stored);
        } else {
          sessionStorage.removeItem("mdr_location");
          sessionStorage.removeItem("mdr_location_src");
          fetch("/api/geo", { cache: "no-store" })
            .then(function(r) { return r.ok ? r.json() : null; })
            .then(function(data) {
              if (data && data.city) applyCity(sanitize(data.city));
              if (paramKw) applyKeyword(paramKw);
            })
            .catch(function() {});
        }

        if (paramKw) applyKeyword(paramKw);
      } catch (e) {}
    })();
  </script>

  {/* Phone click conversion tracking */}
  <script is:inline>
    document.querySelectorAll("[data-lp-phone-cta]").forEach(function(el) {
      el.addEventListener("click", function() {
        var source = el.getAttribute("data-lp-phone-cta") || "lp";
        try { window.hj && window.hj("event", "phone_click_lp"); } catch (e) {}
        try { window.gtag && window.gtag("event", "phone_click", { event_category: "cro", event_label: source }); } catch (e) {}
        try {
          var convVal = (window.__GADS_CALL_CONVERSION__ || "");
          if (window.gtag && convVal) {
            window.gtag("event", "conversion", { send_to: convVal });
          }
        } catch (e) {}
        try { window.fbq && window.fbq("trackCustom", "phone_click", { source: source }); } catch (e) {}
      });
    });
  </script>

  <style is:global>
    /* Prevent .dark-section cascade from whitening the final-CTA form card */
    .dark-section .lp-form-light,
    .dark-section .lp-form-light * { color: #1B1B1B; }
    .dark-section .lp-form-light .text-text-muted { color: #6B7280; }
    .dark-section .lp-form-light .text-text-dim { color: #9CA3AF; }
    .dark-section .lp-form-light a { color: #1B1B1B; }
    .dark-section .lp-form-light a:hover { color: #C0392B; }
    .dark-section .lp-form-light button { color: #FFFFFF; }
  </style>
</LandingPageLayout>
