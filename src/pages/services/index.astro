---
import Layout from "@/layouts/Layout.astro";
import SectionContainer from "@/components/ui/SectionContainer.astro";
import Card from "@/components/ui/Card.astro";
import Button from "@/components/ui/Button.astro";
import Breadcrumb from "@/components/common/Breadcrumb.astro";
import ImagePlaceholder from "@/components/common/ImagePlaceholder.astro";
import { loadQuery } from "@/sanity/lib/load-query";
import { SERVICES_QUERY } from "@/sanity/lib/queries";
import { urlForImage } from "@/sanity/lib/url-for-image";

export const prerender = true;

interface Service {
  _id: string;
  name: string;
  slug: string;
  description?: string;
  icon?: string;
  featuredImage?: any;
  sortOrder?: number;
  isParent: boolean;
  parentService?: {
    _id: string;
    name: string;
    slug: string;
  };
}

const services = await loadQuery<Service[]>(SERVICES_QUERY);
const parentServices = services.filter((s) => s.isParent);
const childServices = services.filter((s) => !s.isParent);

function getChildren(parentId: string) {
  return childServices.filter((c) => c.parentService?._id === parentId);
}

// Fallback images for services without CMS photos
const fallbackImages: Record<string, string> = {
  "roof-replacement": "/assets/web/Untitled-1800-x-1440-px.jpg",
  "shingle-roofing": "/assets/web/Untitled-1800-x-1440-px-1.jpg",
  "metal-roofing": "/assets/web/dji_fly_20250630_135406_726_1751306060507_photo.jpg",
  "timber-seal": "/assets/web/Untitled-1800-x-1440-px-4.jpg",
  "roof-repair": "/assets/web/Untitled-1800-x-1440-px-2.jpg",
  "roof-maintenance": "/assets/web/dji_fly_20250630_135554_733_1751306170083_photo.jpg",
  "gutters": "/assets/web/dji_fly_20250630_140410_766_1751306661861_photo.jpg",
  "storm-damage": "/assets/web/Untitled-1800-x-1440-px-3.jpg",
};

function getServiceImage(service: Service): string | null {
  if (service.featuredImage) return urlForImage(service.featuredImage).width(600).height(400).url();
  return fallbackImages[service.slug] || "/assets/web/dji_fly_20251105_160244_430_1762438961614_photo.jpg";
}
---

<Layout
  title="Roofing Services"
  description="Complete roofing services in Christiansburg & Roanoke VA. Roof replacement, shingle roofing, metal roofing, repairs, maintenance, gutters, and storm damage restoration."
>
  {/* Dark Hero with Project Photo */}
  <section class="relative min-h-[40vh] flex items-center dark-section" data-transparent-header>
    <div class="absolute inset-0 z-0">
      <img
        src="/assets/web/dji_fly_20251105_160154_425_1762438973026_photo.jpg"
        alt="Aerial view of a completed Modern Day Roofing project"
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-bg-darker/95 via-bg-darker/80 to-bg-darker/50"></div>
    </div>
    <div class="relative z-10 mx-auto max-w-[1200px] px-4 md:px-6 py-16 md:py-24 w-full">
      <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Services" }]} />
      <h1 class="mt-6 text-3xl md:text-4xl lg:text-5xl font-bold text-white">
        Our Roofing Services
      </h1>
      <p class="mt-6 text-lg text-white/85 max-w-2xl leading-relaxed">
        From full roof replacements to emergency storm damage repairs, Modern Day Roofing
        delivers expert craftsmanship backed by manufacturer warranties across Christiansburg,
        Roanoke, and the New River Valley.
      </p>
    </div>
  </section>

  <SectionContainer background="white" padding="md">
    {parentServices.length === 0 && (
      <p class="text-center text-text-dim py-12">No services available yet.</p>
    )}

    <div class="space-y-16">
      {parentServices.map((parent) => {
        const children = getChildren(parent._id);
        return (
          <div>
            {/* Parent service - wide horizontal card */}
            <a
              href={`/services/${parent.slug}`}
              class="group grid grid-cols-1 md:grid-cols-5 gap-6 bg-bg-card border border-border rounded-xl overflow-hidden hover:border-accent/30 transition-colors"
            >
              <div class="md:col-span-2 aspect-video md:aspect-auto">
                <img
                  src={getServiceImage(parent)}
                  alt={parent.name}
                  class="w-full h-full object-cover"
                />
              </div>
              <div class="md:col-span-3 p-6 md:py-8 flex flex-col justify-center">
                <h2 class="text-2xl md:text-3xl font-bold text-text-primary group-hover:text-accent transition-colors">
                  {parent.name}
                </h2>
                {parent.description && (
                  <p class="mt-3 text-text-muted leading-relaxed">
                    {parent.description}
                  </p>
                )}
                <div class="mt-4">
                  <span class="text-accent font-semibold text-sm group-hover:underline">
                    Learn More &rarr;
                  </span>
                </div>
              </div>
            </a>

            {/* Child services grid */}
            {children.length > 0 && (
              <div class="mt-6 ml-0 md:ml-8">
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                  {children.map((child) => (
                    <Card variant="service" href={`/services/${child.slug}`}>
                      <div class="mb-4">
                        <img
                          src={getServiceImage(child)}
                          alt={child.name}
                          class="w-full rounded-lg object-cover"
                          style="aspect-ratio: 16/9;"
                        />
                      </div>
                      <h3 class="text-lg font-semibold text-text-primary mb-2">
                        {child.name}
                      </h3>
                      {child.description && (
                        <p class="text-sm text-text-muted">{child.description}</p>
                      )}
                    </Card>
                  ))}
                </div>
              </div>
            )}
          </div>
        );
      })}
    </div>

    <div class="text-center mt-16">
      <Button href="/contact" size="lg">Get Your Free Estimate</Button>
    </div>
  </SectionContainer>
</Layout>
