---
import Layout from "@/layouts/Layout.astro";
import SectionContainer from "@/components/ui/SectionContainer.astro";
import Card from "@/components/ui/Card.astro";
import Button from "@/components/ui/Button.astro";
import Breadcrumb from "@/components/common/Breadcrumb.astro";
import ImagePlaceholder from "@/components/common/ImagePlaceholder.astro";
import { loadQuery } from "@/sanity/lib/load-query";
import { SERVICES_QUERY } from "@/sanity/lib/queries";
import { urlForImage } from "@/sanity/lib/url-for-image";

export const prerender = true;

interface Service {
  _id: string;
  name: string;
  slug: string;
  description?: string;
  icon?: string;
  featuredImage?: any;
  sortOrder?: number;
  isParent: boolean;
  parentService?: {
    _id: string;
    name: string;
    slug: string;
  };
}

const services = await loadQuery<Service[]>(SERVICES_QUERY);
const parentServices = services.filter((s) => s.isParent);
const childServices = services.filter((s) => !s.isParent);

function getChildren(parentId: string) {
  return childServices.filter((c) => c.parentService?._id === parentId);
}

// Fallback images for services without CMS photos — each service gets a unique image
const fallbackImages: Record<string, string> = {
  "roof-replacement": "/assets/projects/Untitled-1800-x-1440-px.jpg",
  "shingle-roofing": "/assets/projects/Untitled-1800-x-1440-px-1.jpg",
  "metal-roofing": "/assets/projects/dji_fly_20250630_135406_726_1751306060507_photo.JPG",
  "timber-seal": "/assets/projects/Untitled-1800-x-1440-px-4.jpg",
  "roof-repair": "/assets/projects/Untitled-1800-x-1440-px-2.jpg",
  "roof-maintenance": "/assets/projects/dji_fly_20250630_135554_733_1751306170083_photo.JPG",
  "gutters": "/assets/projects/dji_fly_20251105_160008_416_1762439005458_photo.JPG",
  "storm-damage": "/assets/projects/Untitled-1800-x-1440-px-3.jpg",
  "commercial-roofing": "/assets/projects/dji_fly_20251105_155920_411_1762439016516_photo.JPG",
  "flat-roofing": "/assets/projects/dji_fly_20250630_140410_766_1751306661861_photo.JPG",
  "siding": "/assets/projects/dji_fly_20251105_160046_419_1762438984409_photo-1.JPG",
  "skylights": "/assets/projects/IMG_5558-1.jpg",
  "roof-coatings": "/assets/projects/dji_fly_20250630_135844_746_1751306349301_photo.JPG",
  "roof-inspection": "/assets/projects/dji_fly_20251105_160216_427_1762438968829_photo.JPG",
  "wind-damage-repair": "/assets/projects/Catch-all-bburg.jpg",
  "hail-damage-repair": "/assets/projects/dji_fly_20251105_160302_432_1762438957426_photo.JPG",
  "emergency-roof-repair": "/assets/projects/Landscaping-nets.jpg",
  "insurance-claims-help": "/assets/projects/dji_fly_20251105_160058_421_1762438980497_photo.JPG",
  "seamless-gutters": "/assets/projects/dji_fly_20250630_140030_755_1751306447124_photo.JPG",
  "gutter-guards": "/assets/projects/IMG_5557-1.jpg",
  "gutter-repair": "/assets/projects/dji_fly_20241025_170718_583_1729890501648_photo-1.jpg",
  "commercial-roof-repair": "/assets/projects/HVAC-protection.jpg",
  "commercial-roof-replacement": "/assets/projects/dji_fly_20251105_160154_425_1762438973026_photo.JPG",
  "commercial-roof-coatings": "/assets/projects/dji_fly_20251105_160244_430_1762438961614_photo.JPG",
  "hoa-roofing": "/assets/projects/dji_fly_20251105_160414_436_1762438949252_photo.JPG",
  "tpo-roofing": "/assets/projects/dji_fly_20250630_140110_757_1751306482991_photo.JPG",
  "epdm-roofing": "/assets/projects/dji_fly_20250630_140228_761_1751306561592_photo.JPG",
  "modified-bitumen": "/assets/projects/dji_fly_20250630_135346_724_1751306044686_photo.JPG",
  "vinyl-siding": "/assets/projects/dji_fly_20250630_135332_722_1751306023542_photo.JPG",
  "fiber-cement-siding": "/assets/projects/dji_fly_20251105_160308_433_1762438955249_photo.JPG",
  "siding-repair": "/assets/projects/dji_fly_20251105_160146_424_1762438974992_photo.JPG",
  "skylight-repair": "/assets/projects/IMG_5560-1.jpg",
  "silicone-roof-coating": "/assets/projects/IMG_5561-2.jpg",
};

function getServiceImage(service: Service): string | null {
  if (service.featuredImage) return urlForImage(service.featuredImage).width(600).height(400).url();
  return fallbackImages[service.slug] || "/assets/projects/dji_fly_20251105_160244_430_1762438961614_photo.JPG";
}
---

<Layout
  title="Roofing Services"
  description="Complete roofing services in Christiansburg & Roanoke VA. Roof replacement, shingle roofing, metal roofing, repairs, maintenance, gutters, and storm damage restoration."
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Roofing Services",
    "description": "Complete roofing services in Christiansburg & Roanoke VA.",
    "url": "https://moderndayroof.com/services",
    "mainEntity": {
      "@type": "ItemList",
      "itemListElement": parentServices.map((s, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "url": `https://moderndayroof.com/services/${s.slug}`,
        "name": s.name
      }))
    }
  })} />
  {/* Dark Hero with Project Photo */}
  <section class="relative min-h-[40vh] flex items-center dark-section" data-transparent-header>
    <div class="absolute inset-0 z-0">
      <img
        src="/assets/projects/dji_fly_20251105_160154_425_1762438973026_photo.JPG"
        alt="Aerial view of a completed Modern Day Roofing project"
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-bg-darker/95 via-bg-darker/80 to-bg-darker/50"></div>
    </div>
    <div class="relative z-10 mx-auto max-w-[1200px] px-4 md:px-6 py-16 md:py-24 w-full">
      <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Services" }]} />
      <h1 class="mt-6 text-3xl md:text-4xl lg:text-5xl font-bold text-white">
        Our Roofing Services
      </h1>
      <p class="mt-6 text-lg text-white/85 max-w-2xl leading-relaxed">
        From full roof replacements to emergency storm damage repairs, Modern Day Roofing
        delivers expert craftsmanship backed by manufacturer warranties across Christiansburg,
        Roanoke, and the New River Valley.
      </p>
    </div>
  </section>

  <SectionContainer background="white" padding="md">
    {parentServices.length === 0 && (
      <p class="text-center text-text-dim py-12">No services available yet.</p>
    )}

    <div class="space-y-16">
      {parentServices.map((parent) => {
        const children = getChildren(parent._id);
        return (
          <div>
            {/* Parent service - wide horizontal card */}
            <a
              href={`/services/${parent.slug}`}
              class="group grid grid-cols-1 md:grid-cols-5 gap-6 bg-bg-card border border-border rounded-xl overflow-hidden hover:border-accent/30 transition-colors"
            >
              <div class="md:col-span-2 aspect-video md:aspect-auto">
                <img
                  src={getServiceImage(parent)}
                  alt={parent.name}
                  class="w-full h-full object-cover"
                />
              </div>
              <div class="md:col-span-3 p-6 md:py-8 flex flex-col justify-center">
                <h2 class="text-2xl md:text-3xl font-bold text-text-primary group-hover:text-accent transition-colors">
                  {parent.name}
                </h2>
                {parent.description && (
                  <p class="mt-3 text-text-muted leading-relaxed">
                    {parent.description}
                  </p>
                )}
                <div class="mt-4">
                  <span class="text-accent font-semibold text-sm group-hover:underline">
                    Learn More &rarr;
                  </span>
                </div>
              </div>
            </a>

            {/* Child services grid */}
            {children.length > 0 && (
              <div class="mt-6 ml-0 md:ml-8">
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                  {children.map((child) => (
                    <Card variant="service" href={`/services/${child.slug}`}>
                      <div class="mb-4">
                        <img
                          src={getServiceImage(child)}
                          alt={child.name}
                          class="w-full rounded-lg object-cover"
                          style="aspect-ratio: 16/9;"
                        />
                      </div>
                      <h3 class="text-lg font-semibold text-text-primary mb-2">
                        {child.name}
                      </h3>
                      {child.description && (
                        <p class="text-sm text-text-muted">{child.description}</p>
                      )}
                    </Card>
                  ))}
                </div>
              </div>
            )}
          </div>
        );
      })}
    </div>

    <div class="text-center mt-16">
      <Button href="/contact" size="lg">Get Your Free Estimate</Button>
    </div>
  </SectionContainer>
</Layout>
