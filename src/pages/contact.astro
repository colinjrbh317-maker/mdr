---
import Layout from "@/layouts/Layout.astro";
import SectionContainer from "@/components/ui/SectionContainer.astro";
import Button from "@/components/ui/Button.astro";
import Breadcrumb from "@/components/common/Breadcrumb.astro";
import ContactForm from "@/components/forms/ContactForm";
import { loadQuery } from "@/sanity/lib/load-query";
import { SITE_SETTINGS_QUERY } from "@/sanity/lib/queries";

export const prerender = true;

const settings = await loadQuery<any>(SITE_SETTINGS_QUERY).catch(() => null);

const phone = settings?.phone || "(540) 553-6007";
const email = settings?.email || "sales@moderndayroof.com";
const address = settings?.address || "Christiansburg, VA 24073";

const breadcrumbItems = [
  { label: "Home", href: "/" },
  { label: "Contact" },
];

const siteUrl = Astro.site?.href || "https://moderndayroofing.com";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "RoofingContractor",
  name: "Modern Day Roofing",
  url: siteUrl,
  telephone: phone,
  email: email,
  address: {
    "@type": "PostalAddress",
    streetAddress: "80 College St. STE R",
    addressLocality: "Christiansburg",
    addressRegion: "VA",
    postalCode: "24073",
    addressCountry: "US",
  },
  areaServed: [
    { "@type": "City", name: "Christiansburg, VA" },
    { "@type": "City", name: "Roanoke, VA" },
    { "@type": "City", name: "Blacksburg, VA" },
    { "@type": "City", name: "Salem, VA" },
    { "@type": "City", name: "Radford, VA" },
  ],
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      opens: "08:30",
      closes: "17:00",
    },
  ],
};
---

<Layout
  title="Free Roofing Estimate | Modern Day Roofing"
  description="Get a free, no-obligation roof inspection and estimate from Modern Day Roofing. 24-hour response time. Serving the New River Valley and Roanoke."
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: breadcrumbItems.filter((item: any) => item.href).map((item: any, i: number) => ({
      "@type": "ListItem",
      position: i + 1,
      name: item.label,
      item: `${siteUrl}${item.href?.replace(/^\//, "")}`,
    })).concat([{ "@type": "ListItem", position: breadcrumbItems.length, name: "Contact" }]),
  })} />

  {/* Hero Banner */}
  <section class="relative py-14 md:py-20 dark-section" data-transparent-header>
    <div class="absolute inset-0 z-0">
      <img
        src="/assets/projects/dji_fly_20251105_160154_425_1762438973026_photo.JPG"
        alt="Roof replacement project"
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-bg-darker/85"></div>
    </div>
    <div class="relative z-10 mx-auto max-w-[900px] px-4 md:px-6 text-center">
      <Breadcrumb items={breadcrumbItems} />
      <h1 class="text-3xl md:text-5xl font-display font-bold mb-4 mt-4" style="color: #fff;">
        Get Your Free Roofing Estimate!
      </h1>
      <p class="text-lg max-w-2xl mx-auto leading-relaxed" style="color: rgba(255,255,255,0.85);">
        Fill out the form below to schedule your no-obligation roofing inspection and estimate.
        Our experts will provide you with a detailed assessment and a fair quote.
      </p>
    </div>
  </section>

  {/* Main Form Section */}
  <section class="bg-white py-12 md:py-16">
    <div class="mx-auto max-w-[700px] px-4 md:px-6">

      {/* Form Card */}
      <div class="bg-white rounded-2xl shadow-md border border-border overflow-hidden">
        <div class="p-6 md:p-10">
          <ContactForm client:load />
        </div>
      </div>

      {/* Contact Info Strip */}
      <div class="mt-8 grid grid-cols-1 md:grid-cols-3 gap-4 text-center">
        <a href={`tel:${phone.replace(/[^0-9+]/g, "")}`} class="flex flex-col items-center gap-2 p-4 bg-white rounded-xl border border-border hover:border-accent/30 transition-colors group">
          <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
          <span class="font-semibold text-text-primary text-sm group-hover:text-accent transition-colors">{phone}</span>
          <span class="text-xs text-text-muted">Call Us Directly</span>
        </a>
        <a href={`mailto:${email}`} class="flex flex-col items-center gap-2 p-4 bg-white rounded-xl border border-border hover:border-accent/30 transition-colors group">
          <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
          <span class="font-semibold text-text-primary text-sm group-hover:text-accent transition-colors">{email}</span>
          <span class="text-xs text-text-muted">Email Us</span>
        </a>
        <div class="flex flex-col items-center gap-2 p-4 bg-white rounded-xl border border-border">
          <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          <span class="font-semibold text-text-primary text-sm">Mon–Fri 8:30AM–5PM</span>
          <span class="text-xs text-accent font-medium">24/7 Storm Emergency</span>
        </div>
      </div>

    </div>
  </section>

  {/* Location & Contact Info */}
  <SectionContainer background="light" padding="md">
    <div class="max-w-4xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div>
          <h2 class="text-2xl font-display font-bold text-text-primary mb-4">Our Location</h2>
          <div class="space-y-4">
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-accent mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
              <div>
                <p class="font-semibold text-text-primary">80 College St. STE R</p>
                <p class="text-text-muted">Christiansburg, VA 24073</p>
              </div>
            </div>
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              <a href={`tel:${phone.replace(/[^0-9+]/g, "")}`} class="font-semibold text-text-primary hover:text-accent transition-colors text-lg">{phone}</a>
            </div>
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              <a href={`mailto:${email}`} class="font-semibold text-text-primary hover:text-accent transition-colors">{email}</a>
            </div>
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              <div>
                <p class="font-semibold text-text-primary">Mon–Fri 8:30 AM – 5:00 PM</p>
                <p class="text-sm text-accent font-medium">24/7 Storm Emergency Service</p>
              </div>
            </div>
          </div>
        </div>
        <div class="rounded-xl overflow-hidden border border-border" style="aspect-ratio: 4/3;">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3182.0!2d-80.4103!3d37.1318!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x884dc9b7bc7e2b9d%3A0x7a6b3c8e8f9d0e1a!2s80%20College%20St%20STE%20R%2C%20Christiansburg%2C%20VA%2024073!5e0!3m2!1sen!1sus!4v1700000000000"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Modern Day Roofing office location in Christiansburg, VA"
          ></iframe>
        </div>
      </div>
    </div>
  </SectionContainer>

  {/* What Happens Next */}
  <SectionContainer background="white" padding="md">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-display font-bold text-text-primary text-center mb-10">
        What Happens After You Reach Out
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-accent text-white flex items-center justify-center text-lg font-bold">1</div>
          <h3 class="font-bold text-text-primary mb-2">We Call Within 24 Hours</h3>
          <p class="text-sm text-text-muted">A real person from our team — not a call center — reaches out to learn about your situation and answer questions.</p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-accent text-white flex items-center justify-center text-lg font-bold">2</div>
          <h3 class="font-bold text-text-primary mb-2">Free On-Site Inspection</h3>
          <p class="text-sm text-text-muted">We schedule a time that works for you. Our inspector checks shingles, flashing, ventilation, gutters, and decking — with photos.</p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-accent text-white flex items-center justify-center text-lg font-bold">3</div>
          <h3 class="font-bold text-text-primary mb-2">Detailed Report & Quote</h3>
          <p class="text-sm text-text-muted">You get an honest assessment of your roof's condition and a transparent, itemized quote — no surprises, no pressure.</p>
        </div>
      </div>
    </div>
  </SectionContainer>
</Layout>
