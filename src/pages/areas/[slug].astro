---
import Layout from "@/layouts/Layout.astro";
import SectionContainer from "@/components/ui/SectionContainer.astro";
import Card from "@/components/ui/Card.astro";
import Button from "@/components/ui/Button.astro";
import Breadcrumb from "@/components/common/Breadcrumb.astro";
import ImagePlaceholder from "@/components/common/ImagePlaceholder.astro";
import BlockRenderer from "@/components/blocks/BlockRenderer.astro";
import LeadCaptureForm from "@/components/forms/LeadCaptureForm";
import { PortableText } from "astro-portabletext";
import { loadQuery } from "@/sanity/lib/load-query";
import {
  SERVICE_AREA_BY_SLUG_QUERY,
  ALL_SERVICE_AREA_SLUGS_QUERY,
} from "@/sanity/lib/queries";
import { urlForImage } from "@/sanity/lib/url-for-image";
import ScrollReveal from "@/components/common/ScrollReveal.astro";
import CityReviews from "@/components/common/CityReviews.astro";
import { areaFacts as tier1AreaFacts } from "@/data/area-content";

export const prerender = true;

export async function getStaticPaths() {
  const areas = await loadQuery<Array<{ slug: string }>>(ALL_SERVICE_AREA_SLUGS_QUERY);
  return areas.map((a) => ({
    params: { slug: a.slug },
  }));
}

const { slug } = Astro.params;
const area = await loadQuery<any>(SERVICE_AREA_BY_SLUG_QUERY, { slug });

if (!area) {
  return Astro.redirect("/404");
}

const isHub = area.isHubPage === true;
const childAreas = area.childAreas || [];

// Area-specific hero images (generated via NanoBanana Pro, unique per area)
const areaHeroImages: Record<string, string> = {
  "roanoke": "/assets/areas/roanoke-hero.webp",
  "christiansburg": "/assets/areas/christiansburg-hero.webp",
  "blacksburg": "/assets/areas/blacksburg-hero.webp",
  "salem": "/assets/areas/salem-hero.webp",
  "radford": "/assets/areas/radford-hero.webp",
  "bedford": "/assets/areas/bedford-hero.webp",
  "pulaski": "/assets/areas/pulaski-hero.webp",
  "dublin": "/assets/areas/dublin-hero.webp",
  "floyd": "/assets/areas/floyd-hero.webp",
  "wytheville": "/assets/areas/wytheville-hero.webp",
  "vinton": "/assets/areas/vinton-hero.webp",
  "troutville": "/assets/areas/troutville-hero.webp",
  "lexington": "/assets/areas/lexington-hero.webp",
  "covington": "/assets/areas/covington-hero.webp",
  "smith-mountain-lake": "/assets/areas/smith-mountain-lake-hero.webp",
  "new-river-valley": "/assets/areas/new-river-valley-hero.webp",
  "roanoke-area": "/assets/areas/roanoke-area-hero.webp",
};
const areaHeroImage = area.featuredImage
  ? urlForImage(area.featuredImage).width(1600).height(800).url()
  : areaHeroImages[slug as string] || "/assets/branding/crew-working-harness-1.png";
const siblingAreas = area.siblingAreas || [];
const servicesOffered = area.servicesOffered || [];

const seoTitle = area.seo?.metaTitle || `${area.name} Roofing Contractor | 5★ 231 Reviews | Free Estimates`;
const seoDescription =
  area.seo?.metaDescription || area.description || `${area.name}'s top-rated roofing contractor. Roof replacement, roof repair & storm damage restoration. GAF Master Elite, 5★ rated by 231 homeowners. Free estimates, call (540) 553-6007.`;

// Breadcrumb items
const breadcrumbItems = [
  { label: "Home", href: "/" },
  { label: "Service Areas", href: "/areas" },
];
if (!isHub && area.parentHub) {
  breadcrumbItems.push({
    label: area.parentHub.name,
    href: `/areas/${area.parentHub.slug}`,
  });
}
breadcrumbItems.push({ label: area.name });

// JSON-LD structured data
const siteUrl = Astro.site?.href || "https://moderndayroofing.com";

const areaServed = isHub
  ? childAreas.map((child: any) => ({
      "@type": "City",
      name: `${child.name}, VA`,
    }))
  : [{ "@type": "City", name: `${area.name}, VA` }];

// Fallback images for services without CMS photos
const serviceFallbackImages: Record<string, string> = {
  "roof-replacement": "/assets/projects/Untitled-1800-x-1440-px.jpg",
  "shingle-roofing": "/assets/projects/Untitled-1800-x-1440-px-1.jpg",
  "metal-roofing": "/assets/projects/dji_fly_20250630_135406_726_1751306060507_photo.JPG",
  "timber-seal": "/assets/projects/Untitled-1800-x-1440-px-4.jpg",
  "roof-repair": "/assets/projects/Untitled-1800-x-1440-px-2.jpg",
  "roof-maintenance": "/assets/projects/dji_fly_20250630_135554_733_1751306170083_photo.JPG",
  "gutters": "/assets/projects/dji_fly_20251105_160008_416_1762439005458_photo.JPG",
  "storm-damage": "/assets/projects/Untitled-1800-x-1440-px-3.jpg",
  "commercial-roofing": "/assets/projects/dji_fly_20251105_155920_411_1762439016516_photo.JPG",
  "flat-roofing": "/assets/projects/dji_fly_20250630_140410_766_1751306661861_photo.JPG",
  "siding": "/assets/projects/dji_fly_20251105_160046_419_1762438984409_photo-1.JPG",
  "skylights": "/assets/projects/IMG_5558-1.jpg",
  "roof-coatings": "/assets/projects/dji_fly_20250630_135844_746_1751306349301_photo.JPG",
};

function getServiceImage(service: any): string {
  if (service.featuredImage) return urlForImage(service.featuredImage).width(400).height(225).url();
  return serviceFallbackImages[service.slug] || "/assets/projects/dji_fly_20251105_160154_425_1762438973026_photo.JPG";
}

function getAreaImage(areaItem: any): string {
  if (areaItem.featuredImage) return urlForImage(areaItem.featuredImage).width(400).height(225).url();
  const slug = areaItem.slug?.current || areaItem.slug;
  return `/assets/areas/${slug}-hero.webp`;
}

const localBusinessJsonLd = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "RoofingContractor"],
  name: "Modern Day Roofing",
  url: siteUrl,
  telephone: "(540) 553-6007",
  address: {
    "@type": "PostalAddress",
    streetAddress: "80 College St. STE R",
    addressLocality: "Christiansburg",
    addressRegion: "VA",
    postalCode: "24073",
    addressCountry: "US",
  },
  areaServed,
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: "5.0",
    reviewCount: "231",
    bestRating: "5",
    worstRating: "1",
  },
  description: seoDescription,
};
---

<Layout title={seoTitle} description={seoDescription} ogImage={area.featuredImage ? urlForImage(area.featuredImage).width(1200).height(630).url() : undefined}>
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessJsonLd)} />

  {/* Full-Width Hero with Area Image */}
  <section class="relative min-h-[50vh] flex items-center dark-section" data-transparent-header>
    <div class="absolute inset-0 z-0">
      <img
        src={areaHeroImage}
        alt={`Roofing services in ${area.name}, Virginia`}
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-bg-darker/95 via-bg-darker/85 to-bg-darker/60"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-[1200px] px-4 md:px-6 py-16 md:py-24 w-full">
      <Breadcrumb items={breadcrumbItems} />
      <h1 class="mt-6 text-3xl md:text-4xl lg:text-5xl font-bold text-white">
        Roofing Services in {area.name}, VA
      </h1>
      {area.description && (
        <p class="mt-4 text-lg md:text-xl text-gray-300 max-w-2xl leading-relaxed">
          {area.description}
        </p>
      )}
      <div class="mt-8 flex flex-col sm:flex-row gap-4">
        <Button href="#get-estimate" size="lg">Get Your Free Estimate</Button>
        <Button href="tel:5405536007" variant="outline" size="lg" class="text-white border-white hover:bg-white hover:text-bg-dark">
          Call (540) 553-6007
        </Button>
      </div>
    </div>
  </section>

  {/* Services available badge bar */}
  {servicesOffered.length > 0 && (
    <SectionContainer background="light" padding="sm">
      <div class="flex flex-wrap items-center justify-center gap-2">
        <span class="text-sm text-text-muted mr-2">Services in {area.name}:</span>
        {servicesOffered.map((service: any) => (
          <a
            href={`/services/${service.slug}`}
            class="px-4 py-1.5 rounded-full text-sm font-medium bg-warm/10 text-warm-dark border border-warm/20 hover:bg-warm/20 transition-colors no-underline"
          >
            {service.name}
          </a>
        ))}
      </div>
    </SectionContainer>
  )}

  {/* Body Content */}
  {area.body && (
    <SectionContainer background="white" padding="md" maxWidth="narrow">
      <div class="prose prose-lg max-w-none text-text-body prose-headings:text-text-primary prose-headings:mt-10 prose-headings:mb-4 prose-a:text-accent prose-strong:text-text-primary prose-img:rounded-xl prose-p:leading-relaxed prose-li:leading-relaxed">
        <PortableText value={area.body} />
      </div>
    </SectionContainer>
  )}

  {/* Child Areas Grid (Hub pages only) */}
  {isHub && childAreas.length > 0 && (
    <SectionContainer background="light" padding="md">
      <h2 class="text-2xl md:text-3xl font-bold text-text-primary mb-8">
        Communities We Serve in the {area.name} Area
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {childAreas.map((child: any, i: number) => (
          <ScrollReveal delay={i * 100}>
            <Card variant="service" href={`/areas/${child.slug}`}>
              <div class="mb-4">
                <img
                  src={getAreaImage(child)}
                  alt={`Roofing services in ${child.name}, VA`}
                  class="w-full rounded-lg object-cover"
                  style="aspect-ratio: 16/9;"
                  loading="lazy"
                />
              </div>
              <h3 class="text-lg font-semibold text-text-primary mb-2">
                {child.name}
              </h3>
              {child.description && (
                <p class="text-sm text-text-muted">{child.description}</p>
              )}
            </Card>
          </ScrollReveal>
        ))}
      </div>
    </SectionContainer>
  )}

  {/* Services Offered */}
  {servicesOffered.length > 0 && (
    <SectionContainer background={isHub ? "warm" : "light"} padding="md">
      <h2 class="text-2xl md:text-3xl font-bold text-text-primary mb-8">
        Roofing Services in {area.name}
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {servicesOffered.map((service: any, i: number) => (
          <ScrollReveal delay={i * 100}>
            <Card variant="service" href={`/services/${service.slug}`}>
              <div class="mb-4">
                <img
                  src={getServiceImage(service)}
                  alt={service.name}
                  class="w-full rounded-lg object-cover"
                  style="aspect-ratio: 16/9;"
                  loading="lazy"
                />
              </div>
              <h3 class="text-lg font-semibold text-text-primary mb-2">
                {service.name}
              </h3>
              {service.description && (
                <p class="text-sm text-text-muted">{service.description}</p>
              )}
            </Card>
          </ScrollReveal>
        ))}
      </div>
    </SectionContainer>
  )}

  {/* Page Builder Blocks */}
  {area.pageBuilder && area.pageBuilder.length > 0 && (
    <BlockRenderer blocks={area.pageBuilder} />
  )}

  {/* Location + Service Pages */}
  {servicesOffered.length > 0 && (
    <SectionContainer background="white" padding="md">
      <h2 class="text-2xl md:text-3xl font-bold text-text-primary mb-4">
        {area.name} Roofing Services
      </h2>
      <p class="text-text-muted mb-8">
        Explore our specific services available in {area.name}, Virginia.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {servicesOffered.map((service: any) => (
          <a
            href={`/areas/${slug}/${service.slug}`}
            class="flex items-center gap-3 p-4 rounded-xl border border-border hover:border-accent/30 hover:shadow-md transition-all bg-bg-card no-underline group"
          >
            <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>
            <div>
              <span class="text-sm font-semibold text-text-primary group-hover:text-accent transition-colors">{service.name} in {area.name}</span>
            </div>
          </a>
        ))}
      </div>
    </SectionContainer>
  )}

  {/* City-specific Google Reviews (Tier 1 cities only) */}
  {tier1AreaFacts[slug as string] && <CityReviews city={area.name} />}

  {/* Lead Capture Form */}
  <SectionContainer background="warm" padding="md" id="get-estimate">
    <div class="max-w-2xl mx-auto">
      <div class="text-center mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-text-primary">
          Get Your Free Roofing Estimate in {area.name}
        </h2>
        <p class="mt-3 text-text-muted">
          Free inspection. No obligation. We'll provide an honest assessment and competitive quote for your {area.name} property.
        </p>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-6 md:p-8">
        <LeadCaptureForm client:load source={`area-${slug}`} />
      </div>
    </div>
  </SectionContainer>

  {/* Sibling Areas Cross-links (Child pages only) */}
  {!isHub && (siblingAreas.length > 0 || area.parentHub) && (
    <SectionContainer background="dark" padding="sm">
      <div class="text-center">
        {area.parentHub && (
          <p class="text-text-muted mb-4">
            Part of our{" "}
            <a href={`/areas/${area.parentHub.slug}`} class="text-accent hover:underline font-semibold">
              {area.parentHub.name}
            </a>{" "}
            service area
          </p>
        )}
        {siblingAreas.length > 0 && (
          <div>
            <p class="text-sm text-text-dim mb-3">Also serving nearby:</p>
            <div class="flex flex-wrap justify-center gap-2">
              {siblingAreas.map((sibling: any) => (
                <a
                  href={`/areas/${sibling.slug}`}
                  class="inline-block px-4 py-2 bg-bg-card border border-border rounded-full text-sm text-text-muted hover:text-accent hover:border-accent/30 transition-colors"
                >
                  {sibling.name}
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </SectionContainer>
  )}
</Layout>
