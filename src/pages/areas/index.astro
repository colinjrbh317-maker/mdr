---
import Layout from "@/layouts/Layout.astro";
import SectionContainer from "@/components/ui/SectionContainer.astro";
import Card from "@/components/ui/Card.astro";
import Button from "@/components/ui/Button.astro";
import Breadcrumb from "@/components/common/Breadcrumb.astro";
import ImagePlaceholder from "@/components/common/ImagePlaceholder.astro";
import { loadQuery } from "@/sanity/lib/load-query";
import { SERVICE_AREAS_QUERY } from "@/sanity/lib/queries";
import { urlForImage } from "@/sanity/lib/url-for-image";

export const prerender = true;

interface ServiceArea {
  _id: string;
  name: string;
  slug: string;
  isHubPage?: boolean;
  description?: string;
  featuredImage?: any;
  sortOrder?: number;
  parentHub?: {
    _id: string;
    name: string;
    slug: string;
  };
}

const areas = await loadQuery<ServiceArea[]>(SERVICE_AREAS_QUERY);
const hubs = areas.filter((a) => a.isHubPage);
const children = areas.filter((a) => !a.isHubPage);

function getChildren(hubId: string) {
  return children.filter((c) => c.parentHub?._id === hubId);
}

// AI-generated area images (fallbacks when no CMS image)
const areaImages: Record<string, string> = {
  "roanoke": "/assets/areas/roanoke-hero.webp",
  "christiansburg": "/assets/areas/christiansburg-hero.webp",
  "blacksburg": "/assets/areas/blacksburg-hero.webp",
  "salem": "/assets/areas/salem-hero.webp",
  "radford": "/assets/areas/radford-hero.webp",
  "bedford": "/assets/areas/bedford-hero.webp",
  "pulaski": "/assets/areas/pulaski-hero.webp",
  "dublin": "/assets/areas/dublin-hero.webp",
  "floyd": "/assets/areas/floyd-hero.webp",
  "wytheville": "/assets/areas/wytheville-hero.webp",
  "vinton": "/assets/areas/vinton-hero.webp",
  "troutville": "/assets/areas/troutville-hero.webp",
  "lexington": "/assets/areas/lexington-hero.webp",
  "covington": "/assets/areas/covington-hero.webp",
  "smith-mountain-lake": "/assets/areas/smith-mountain-lake-hero.webp",
  "new-river-valley": "/assets/areas/new-river-valley-hero.webp",
  "roanoke-area": "/assets/areas/roanoke-area-hero.webp",
};

function getAreaImage(area: ServiceArea): string {
  if (area.featuredImage) return urlForImage(area.featuredImage).width(600).height(400).url();
  return areaImages[area.slug] || "/assets/branding/crew-working-harness-1.png";
}

function getAreaThumb(area: ServiceArea): string {
  if (area.featuredImage) return urlForImage(area.featuredImage).width(400).height(225).url();
  return areaImages[area.slug] || "/assets/branding/crew-working-harness-1.png";
}
---

<Layout
  title="Service Areas"
  description="Professional roofing in the New River Valley and Roanoke Area. Serving Christiansburg, Blacksburg, Radford, Salem, and surrounding Virginia communities."
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Service Areas",
    "description": "Professional roofing in the New River Valley and Roanoke Area.",
    "url": "https://moderndayroof.com/areas",
    "mainEntity": {
      "@type": "ItemList",
      "itemListElement": areas.map((a, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "url": `https://moderndayroof.com/areas/${a.slug}`,
        "name": a.name
      }))
    }
  })} />
  {/* Hero */}
  <section class="relative min-h-[40vh] flex items-center dark-section" data-transparent-header>
    <div class="absolute inset-0 z-0">
      <img
        src="/assets/branding/crew-working-harness-1.png"
        alt="Modern Day Roofing crew working across Southwest Virginia"
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-bg-darker/95 via-bg-darker/85 to-bg-darker/60"></div>
    </div>
    <div class="relative z-10 mx-auto max-w-[1200px] px-4 md:px-6 py-16 md:py-24 w-full">
      <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Service Areas" }]} />
      <h1 class="mt-6 text-3xl md:text-4xl lg:text-5xl font-bold text-white">
        Our Service Areas
      </h1>
      <p class="mt-4 text-lg md:text-xl text-gray-300 max-w-2xl leading-relaxed">
        Modern Day Roofing proudly serves homeowners across the New River Valley
        and Roanoke Area. From our offices in Christiansburg and Roanoke, we deliver
        expert roofing services throughout Southwest Virginia.
      </p>
    </div>
  </section>

  <SectionContainer background="white" padding="md">
    {hubs.length === 0 && (
      <p class="text-center text-text-dim py-12">No service areas available yet.</p>
    )}

    <div class="space-y-16">
      {hubs.map((hub) => {
        const hubChildren = getChildren(hub._id);
        return (
          <div>
            {/* Hub - wide horizontal card */}
            <a
              href={`/areas/${hub.slug}`}
              class="group grid grid-cols-1 md:grid-cols-5 gap-6 bg-bg-card border border-border rounded-xl overflow-hidden hover:border-accent/30 transition-colors"
            >
              <div class="md:col-span-2 aspect-video md:aspect-auto">
                <img
                  src={getAreaImage(hub)}
                  alt={`Roofing services in ${hub.name}, Virginia`}
                  class="w-full h-full object-cover"
                />
              </div>
              <div class="md:col-span-3 p-6 md:py-8 flex flex-col justify-center">
                <h2 class="text-2xl md:text-3xl font-bold text-text-primary group-hover:text-accent transition-colors">
                  {hub.name}
                </h2>
                {hub.description && (
                  <p class="mt-3 text-text-muted leading-relaxed">
                    {hub.description}
                  </p>
                )}
                <div class="mt-4">
                  <span class="text-accent font-semibold text-sm group-hover:underline">
                    View All {hub.name} Areas &rarr;
                  </span>
                </div>
              </div>
            </a>

            {/* Child areas grid */}
            {hubChildren.length > 0 && (
              <div class="mt-6 ml-0 md:ml-8">
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                  {hubChildren.map((child) => (
                    <Card variant="service" href={`/areas/${child.slug}`}>
                      <div class="mb-4">
                        <img
                          src={getAreaThumb(child)}
                          alt={`Roofing services in ${child.name}, Virginia`}
                          class="w-full rounded-lg object-cover"
                          style="aspect-ratio: 16/9;"
                        />
                      </div>
                      <h3 class="text-lg font-semibold text-text-primary mb-2">
                        {child.name}
                      </h3>
                      {child.description && (
                        <p class="text-sm text-text-muted">{child.description}</p>
                      )}
                    </Card>
                  ))}
                </div>
              </div>
            )}
          </div>
        );
      })}
    </div>

    <div class="text-center mt-16">
      <Button href="/contact" size="lg">Get Your Free Estimate</Button>
    </div>
  </SectionContainer>
</Layout>
