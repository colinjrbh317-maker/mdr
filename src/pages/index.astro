---
import Layout from "@/layouts/Layout.astro";
import SectionContainer from "@/components/ui/SectionContainer.astro";
import Button from "@/components/ui/Button.astro";
import TrustBar from "@/components/blocks/TrustBar.astro";
import StatsCounter from "@/components/blocks/StatsCounter.astro";
import ScrollReveal from "@/components/common/ScrollReveal.astro";
import AngleDivider from "@/components/common/AngleDivider.astro";
import ProcessSection from "@/components/home/ProcessSection.astro";
import ServicesAndGallery from "@/components/home/ServicesAndGallery.astro";
import HeroErie from "@/components/home/HeroErie.astro";
import GoogleReviews from "@/components/home/GoogleReviews.astro";
import CertificationStrip from "@/components/home/CertificationStrip.astro";
---

<Layout title="Roofing Contractor in Christiansburg & Roanoke VA">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": ["Organization", "RoofingContractor"],
    name: "Modern Day Roofing",
    url: "https://moderndayroof.com",
    telephone: "(540) 553-6007",
    address: {
      "@type": "PostalAddress",
      streetAddress: "80 College St. STE R",
      addressLocality: "Christiansburg",
      addressRegion: "VA",
      postalCode: "24073",
      addressCountry: "US",
    },
    openingHoursSpecification: [
      {
        "@type": "OpeningHoursSpecification",
        dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
        opens: "08:30",
        closes: "17:00",
      },
    ],
    areaServed: [
      { "@type": "City", name: "Christiansburg, VA" },
      { "@type": "City", name: "Roanoke, VA" },
      { "@type": "City", name: "Blacksburg, VA" },
      { "@type": "City", name: "Salem, VA" },
      { "@type": "City", name: "Radford, VA" },
    ],
    description: "GAF Master Elite roofing contractor serving Christiansburg, Roanoke, and the New River Valley. Premium materials. Premium roofs.",
    knowsAbout: ["Roof Replacement", "Roof Repair", "Metal Roofing", "Shingle Roofing", "Storm Damage Repair", "Gutters"],
  })} />

  {/* 1. HERO */}
  <HeroErie />

  {/* Hero → Trust Bar transition */}
  <AngleDivider direction="down" color="var(--color-bg-light)" />

  {/* 2. TRUST BAR */}
  <SectionContainer background="light" padding="sm">
    <TrustBar />
  </SectionContainer>

  {/* 3. SERVICES GRID + BEFORE/AFTER */}
  <AngleDivider direction="up" color="var(--color-bg-white)" />
  <ServicesAndGallery />

  {/* 4. GOOGLE REVIEWS (Erie's most powerful section) */}
  <GoogleReviews />

  {/* 5. STATS COUNTER */}
  <StatsCounter />

  {/* 6. PROCESS STEPS */}
  <ProcessSection />

  {/* 7. FINANCING CTA */}
  <SectionContainer background="white" padding="md">
    <ScrollReveal>
      <div class="max-w-4xl mx-auto text-center">
        <p class="text-accent font-semibold text-sm uppercase tracking-wider mb-2">
          Affordable Options
        </p>
        <h2 class="text-3xl md:text-4xl font-display font-bold text-text-primary mb-4">
          Flexible Financing Available
        </h2>
        <p class="text-text-body text-lg mb-8 max-w-2xl mx-auto">
          Don't let budget concerns delay protecting your home. We offer $0 down financing options
          with competitive rates so you can get a new roof today and pay over time.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <Button href="/financing" size="lg">
            Learn About Financing
          </Button>
          <Button href="/contact" variant="outline" size="lg">
            Get a Free Estimate
          </Button>
        </div>
      </div>
    </ScrollReveal>
  </SectionContainer>

  {/* 8. CERTIFICATION STRIP */}
  <CertificationStrip />

  {/* 9. FINAL CTA */}
  <AngleDivider direction="down" color="var(--color-accent)" />
  <SectionContainer background="accent" padding="md">
    <ScrollReveal>
      <div class="text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-white">
          Ready to Protect Your Home?
        </h2>
        <p class="mt-4 text-white/90 max-w-2xl mx-auto text-lg">
          Get a free, no-obligation roof inspection and estimate. We'll assess your
          roof's condition and provide honest recommendations.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
          <Button href="/contact" variant="secondary" size="lg">
            Schedule Free Inspection
          </Button>
          <Button href="tel:5405536007" variant="ghost" size="lg" class="text-white border-white/30 hover:bg-white/10">
            Call (540) 553-6007
          </Button>
        </div>
      </div>
    </ScrollReveal>
  </SectionContainer>
</Layout>

<style>
  @keyframes accent-line-draw {
    from { width: 0; }
    to { width: 6rem; }
  }

  .hero-accent-line {
    animation: accent-line-draw 1s ease-out 0.5s both;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-accent-line {
      animation: none;
    }
  }
</style>
