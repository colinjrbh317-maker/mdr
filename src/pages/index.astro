---
import Layout from "@/layouts/Layout.astro";
import SectionContainer from "@/components/ui/SectionContainer.astro";
import Button from "@/components/ui/Button.astro";
import TrustBar from "@/components/blocks/TrustBar.astro";
import StatsCounter from "@/components/blocks/StatsCounter.astro";
import FaqSectionBlock from "@/components/blocks/FaqSectionBlock.astro";
import ScrollReveal from "@/components/common/ScrollReveal.astro";
import AngleDivider from "@/components/common/AngleDivider.astro";
import ServicesAndGallery from "@/components/home/ServicesAndGallery.astro";
import HeroErie from "@/components/home/HeroErie.astro";
import GoogleReviews from "@/components/home/GoogleReviews.astro";
import WhyMDR from "@/components/home/WhyMDR.astro";

const homepageFaqs = [
  {
    question: "How much does a new roof cost in Virginia?",
    answer: "Most roof replacements in the New River Valley and Roanoke range from $8,000 to $25,000 depending on size, materials, and complexity. We provide free inspections and detailed estimates so you know exactly what to expect — no surprises.",
  },
  {
    question: "What is a GAF Master Elite contractor?",
    answer: "Only the top 1% of roofing contractors in the country earn GAF Master Elite certification. It means we've met rigorous standards for training, insurance, and customer satisfaction — and it qualifies us to offer GAF's strongest warranty, the Golden Pledge.",
  },
  {
    question: "Do you offer financing for roof replacement?",
    answer: "Yes. We offer $0-down financing with flexible monthly payments. Most homeowners qualify, and we'll walk you through the options during your free estimate.",
  },
  {
    question: "How long does a roof replacement take?",
    answer: "Most residential roof replacements are completed in 1-2 days. We'll confirm timing during your inspection and keep you updated throughout the project.",
  },
  {
    question: "Do you help with insurance claims for storm damage?",
    answer: "Absolutely. We work directly with your insurance company from inspection through final payment. Our team documents the damage, meets with adjusters on-site, and handles the paperwork so you don't have to.",
  },
];
---

<Layout
  title="Roofing Contractor Christiansburg, Roanoke & Blacksburg VA | 5★ 231 Reviews"
  description="Modern Day Roofing — Christiansburg, Roanoke & Blacksburg's top-rated roofing contractor. Roof replacement, repair & storm damage. GAF Master Elite. 5★ 231 reviews. Free estimates. (540) 553-6007."
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": ["Organization", "RoofingContractor"],
    name: "Modern Day Roofing",
    url: "https://moderndayroof.com",
    telephone: "(540) 553-6007",
    address: {
      "@type": "PostalAddress",
      streetAddress: "80 College St. STE R",
      addressLocality: "Christiansburg",
      addressRegion: "VA",
      postalCode: "24073",
      addressCountry: "US",
    },
    openingHoursSpecification: [
      {
        "@type": "OpeningHoursSpecification",
        dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
        opens: "08:30",
        closes: "17:00",
      },
    ],
    areaServed: [
      { "@type": "City", name: "Christiansburg, VA" },
      { "@type": "City", name: "Roanoke, VA" },
      { "@type": "City", name: "Blacksburg, VA" },
      { "@type": "City", name: "Salem, VA" },
      { "@type": "City", name: "Radford, VA" },
    ],
    email: "sales@moderndayroof.com",
    foundingDate: "2019",
    image: "https://moderndayroof.com/og-default.png",
    sameAs: [
      "https://www.facebook.com/moderndayroofing",
      "https://www.instagram.com/moderndayroofing",
      "https://www.linkedin.com/company/modern-day-roofing",
      "https://nextdoor.com/pages/modern-day-roofing-christiansburg-va",
    ],
    description: "GAF Master Elite roofing contractor serving Christiansburg, Roanoke, and the New River Valley. Built to protect. Backed for life.",
    knowsAbout: ["Roof Replacement", "Roof Repair", "Metal Roofing", "Shingle Roofing", "Storm Damage Repair", "Gutters"],
  })} />

  {/* 1. HERO */}
  <HeroErie />

  {/* 2. TRUST BAR */}
  <SectionContainer background="light" padding="xs">
    <TrustBar />
  </SectionContainer>

  {/* 3. SERVICES GRID + BEFORE/AFTER */}
  <AngleDivider direction="up" color="var(--color-bg-white)" />
  <ServicesAndGallery />

  {/* Inline CTA after services */}
  <SectionContainer background="light" padding="sm">
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 text-center">
      <p class="text-text-muted text-sm">Ready to get started?</p>
      <Button href="/contact" size="sm">Get a Free Estimate</Button>
      <span class="text-text-dim text-sm hidden sm:inline">or</span>
      <a href="tel:5405536007" class="text-sm font-semibold text-text-primary hover:text-accent transition-colors">(540) 553-6007</a>
    </div>
  </SectionContainer>

  {/* 4. WHY MDR — value proposition cards */}
  <WhyMDR />

  {/* 5. SERVICE AREAS — discovery path to location pages */}
  <SectionContainer background="light" padding="md">
    <ScrollReveal>
      <div class="text-center mb-10">
        <p class="text-accent font-semibold text-sm uppercase tracking-wider mb-2">
          Locally Owned. Community Focused.
        </p>
        <h2 class="text-3xl md:text-4xl font-display font-bold text-text-primary">
          Serving Southwest Virginia
        </h2>
        <p class="mt-3 text-text-muted text-lg max-w-2xl mx-auto">
          From our offices in Christiansburg and Roanoke, we serve homeowners across the New River Valley and Roanoke area.
        </p>
      </div>
    </ScrollReveal>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
      {/* NRV Hub */}
      <ScrollReveal>
        <a href="/areas/new-river-valley" class="group block rounded-xl overflow-hidden border border-border hover:border-accent/30 hover:shadow-lg transition-all">
          <div class="aspect-video overflow-hidden">
            <img src="/assets/areas/new-river-valley-hero.webp" alt="New River Valley roofing services" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" width="1200" height="674" loading="lazy" />
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold text-text-primary group-hover:text-accent transition-colors">New River Valley</h3>
            <p class="text-text-muted text-sm mt-2">Christiansburg, Blacksburg, Radford, Pulaski, Dublin, Floyd, Wytheville, Pearisburg</p>
            <span class="inline-flex items-center text-accent font-semibold text-sm mt-3 group-hover:underline">
              View NRV Areas
              <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </span>
          </div>
        </a>
      </ScrollReveal>

      {/* Roanoke Hub */}
      <ScrollReveal delay={100}>
        <a href="/areas/roanoke-area" class="group block rounded-xl overflow-hidden border border-border hover:border-accent/30 hover:shadow-lg transition-all">
          <div class="aspect-video overflow-hidden">
            <img src="/assets/areas/roanoke-area-hero.webp" alt="Roanoke area roofing services" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" width="1200" height="674" loading="lazy" />
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold text-text-primary group-hover:text-accent transition-colors">Roanoke Area</h3>
            <p class="text-text-muted text-sm mt-2">Roanoke, Salem, Vinton, Bedford, Hollins, Bonsack, Smith Mountain Lake, Troutville</p>
            <span class="inline-flex items-center text-accent font-semibold text-sm mt-3 group-hover:underline">
              View Roanoke Areas
              <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </span>
          </div>
        </a>
      </ScrollReveal>
    </div>

    {/* Quick city links */}
    <div class="flex flex-wrap justify-center gap-2">
      {["Christiansburg", "Blacksburg", "Roanoke", "Salem", "Radford", "Bedford", "Pulaski", "Smith Mountain Lake"].map((city) => (
        <a
          href={`/areas/${city.toLowerCase().replace(/ /g, "-")}`}
          class="px-4 py-2 rounded-full border border-border text-sm font-medium text-text-primary hover:border-accent/30 hover:text-accent hover:shadow-sm transition-all no-underline bg-white"
        >
          {city}
        </a>
      ))}
    </div>

    <div class="text-center mt-8">
      <Button href="/areas" variant="outline" size="lg">
        View All Service Areas
      </Button>
    </div>
  </SectionContainer>

  {/* Inline CTA before reviews */}
  <SectionContainer background="warm" padding="sm">
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 text-center">
      <p class="text-text-body font-medium text-sm">Not sure what you need? We'll figure it out together.</p>
      <Button href="/contact" size="sm" variant="outline">Schedule Free Inspection</Button>
    </div>
  </SectionContainer>

  {/* 6. GOOGLE REVIEWS */}
  <GoogleReviews />

  {/* 6. STATS COUNTER */}
  <StatsCounter />

  {/* 7. FINANCING CTA */}
  <SectionContainer background="white" padding="md">
    <ScrollReveal>
      <div class="max-w-4xl mx-auto text-center">
        <p class="text-accent font-semibold text-sm uppercase tracking-wider mb-2">
          $0 Down. Seriously.
        </p>
        <h2 class="text-3xl md:text-4xl font-display font-bold text-text-primary mb-4">
          Get Your Roof Now. Pay Over Time.
        </h2>
        <p class="text-text-body text-lg mb-8 max-w-2xl mx-auto">
          A new roof is a big investment. We make it easier with $0-down financing
          and payments that fit your monthly budget.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <Button href="/financing" size="lg">
            Learn About Financing
          </Button>
          <Button href="/contact" variant="outline" size="lg">
            Get a Free Estimate
          </Button>
        </div>
      </div>
    </ScrollReveal>
  </SectionContainer>

  {/* 8. FAQ */}
  <FaqSectionBlock heading="Common Questions About Roofing in Virginia" faqs={homepageFaqs} />

  {/* 9. FINAL CTA — DO NOT CHANGE */}
  <AngleDivider direction="down" color="var(--color-accent)" />
  <SectionContainer background="accent" padding="md">
    <ScrollReveal>
      <div class="text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-white">
          Let's See Where Your Roof Stands.
        </h2>
        <p class="mt-4 text-white/90 max-w-2xl mx-auto text-lg">
          Book a free, no-pressure inspection. We'll give you an honest report —
          even if the answer is "you're fine for now."
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 text-lg font-bold rounded-lg bg-white text-accent hover:bg-gray-100 shadow-lg transition-all min-h-[56px]">
            Schedule Free Inspection
            <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          </a>
          <a href="tel:5405536007" class="inline-flex items-center justify-center px-8 py-4 text-lg font-bold rounded-lg bg-transparent text-white border-2 border-white hover:bg-white/10 transition-all min-h-[56px]">
            Call (540) 553-6007
          </a>
        </div>
      </div>
    </ScrollReveal>
  </SectionContainer>

  {/* Sticky mobile CTA is now in Layout */}
</Layout>

<style>
  @keyframes accent-line-draw {
    from { width: 0; }
    to { width: 6rem; }
  }

  .hero-accent-line {
    animation: accent-line-draw 1s ease-out 0.5s both;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-accent-line {
      animation: none;
    }
  }
</style>
