---
import Layout from "@/layouts/Layout.astro";
import SectionContainer from "@/components/ui/SectionContainer.astro";
import Button from "@/components/ui/Button.astro";
import Breadcrumb from "@/components/common/Breadcrumb.astro";
import LeadCaptureForm from "@/components/forms/LeadCaptureForm";

export const prerender = true;

const breadcrumbItems = [
  { label: "Home", href: "/" },
  { label: "Our Process" },
];

const steps = [
  {
    number: "01",
    title: "Free Inspection",
    description: "We assess shingles, flashing, ventilation, gutters, and decking. You get a detailed report with photos — even if the answer is 'you're fine for now.'",
    detail: "30–45 min on-site",
  },
  {
    number: "02",
    title: "Detailed Proposal",
    description: "A clear, itemized proposal with no hidden costs. We walk through every line so you know exactly what you're paying for and why.",
    detail: "Transparent pricing",
  },
  {
    number: "03",
    title: "Material Selection",
    description: "Choose from GAF's full shingle line. We'll show samples, explain the differences, and help you pick what looks best on your home.",
    detail: "GAF Timberline HDZ & more",
  },
  {
    number: "04",
    title: "Scheduling",
    description: "We work around your schedule. You'll know the exact start date and get updates if anything changes. No surprises.",
    detail: "Typically 1–2 weeks out",
  },
  {
    number: "05",
    title: "Installation",
    description: "Our crew arrives on time, protects your landscaping, installs to GAF specs, and cleans up completely. Most homes are done in 1–2 days.",
    detail: "1–2 day completion",
  },
  {
    number: "06",
    title: "Final Walkthrough",
    description: "We inspect the finished roof together. You approve before we consider the job complete. Then we register your GAF warranty — you're covered for decades.",
    detail: "Your sign-off required",
  },
];
---

<Layout
  title="Our Roofing Process | Step by Step | Modern Day Roofing"
  description="See exactly how Modern Day Roofing handles your project from free inspection to final walkthrough. Six clear steps, no surprises, no hidden costs."
>
  {/* Hero */}
  <section class="relative min-h-[45vh] flex items-center dark-section" data-transparent-header>
    <div class="absolute inset-0 z-0">
      <img
        src="/assets/projects/mdr-roofs-for-troops-5907.jpg"
        alt="Modern Day Roofing team — Roofs for Troops"
        class="w-full h-full object-cover object-top"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-bg-darker/95 via-bg-darker/80 to-bg-darker/40"></div>
    </div>
    <div class="relative z-10 mx-auto max-w-[1200px] px-4 md:px-6 py-16 md:py-24 w-full">
      <Breadcrumb items={breadcrumbItems} />
      <div class="mt-6 max-w-3xl">
        <p class="text-accent-light font-semibold text-sm uppercase tracking-wider mb-3">
          From Start to Finish
        </p>
        <h1 class="text-4xl md:text-5xl font-bold text-white">
          Our Roofing Process
        </h1>
        <p class="mt-4 text-lg text-white/85 max-w-2xl leading-relaxed">
          Six clear steps from inspection to completion. No surprises, no hidden costs, no pressure.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          <Button href="/contact" size="lg">Start Your Project</Button>
          <Button href="tel:5405536007" variant="outline" size="lg" class="text-white border-white hover:bg-white hover:text-bg-dark">
            Call (540) 553-6007
          </Button>
        </div>
      </div>
    </div>
  </section>

  {/* Video — First Thing */}
  <section class="bg-bg-darker">
    <video
      autoplay
      muted
      loop
      playsinline
      class="w-full max-h-[75vh] object-cover block"
      aria-label="Modern Day Roofing — project showcase"
    >
      <source src="/assets/video/mdr-final-edit.mp4" type="video/mp4" />
    </video>
  </section>

  {/* Process Steps */}
  <SectionContainer background="white" padding="lg">
    <div class="text-center mb-14">
      <h2 class="text-2xl md:text-3xl font-display font-bold text-text-primary">
        Your Project in 6 Steps
      </h2>
      <p class="mt-3 text-text-muted max-w-xl mx-auto">
        Every project follows the same proven process. No shortcuts, no guesswork.
      </p>
    </div>
    <div class="max-w-4xl mx-auto space-y-6">
      {steps.map((step, i) => (
        <div class={`flex flex-col md:flex-row gap-5 items-start ${i % 2 === 1 ? 'md:flex-row-reverse' : ''}`}>
          <div class="flex-shrink-0 w-16 h-16 rounded-2xl bg-accent text-white flex items-center justify-center">
            <span class="text-xl font-display font-bold">{step.number}</span>
          </div>
          <div class="flex-1 bg-bg-card border border-border rounded-xl p-5">
            <div class="flex items-center justify-between mb-1.5">
              <h3 class="text-lg font-display font-bold text-text-primary">{step.title}</h3>
              <span class="text-xs text-accent font-semibold bg-accent/10 px-3 py-1 rounded-full hidden sm:block">
                {step.detail}
              </span>
            </div>
            <p class="text-text-body text-sm leading-relaxed">{step.description}</p>
          </div>
        </div>
      ))}
    </div>
  </SectionContainer>

  {/* CTA + Form */}
  <SectionContainer background="light" padding="md">
    <div class="max-w-2xl mx-auto">
      <div class="text-center mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-text-primary">
          Ready? Step One Is Free.
        </h2>
        <p class="mt-3 text-text-muted">
          A free, no-obligation inspection. Fill out the form and we'll be in touch within 24 hours.
        </p>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-6 md:p-8">
        <LeadCaptureForm client:load source="our-process" />
      </div>
    </div>
  </SectionContainer>
</Layout>
