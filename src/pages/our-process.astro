---
import Layout from "@/layouts/Layout.astro";
import SectionContainer from "@/components/ui/SectionContainer.astro";
import Button from "@/components/ui/Button.astro";
import Breadcrumb from "@/components/common/Breadcrumb.astro";
import LeadCaptureForm from "@/components/forms/LeadCaptureForm";

export const prerender = true;

const breadcrumbItems = [
  { label: "Home", href: "/" },
  { label: "Our Process" },
];

const steps = [
  {
    number: "01",
    title: "Free Inspection",
    description: "We assess your roof's condition top to bottom — shingles, flashing, ventilation, gutters, and decking. You get a detailed report with photos, even if the answer is 'you're fine for now.'",
    detail: "30-45 minutes on-site",
  },
  {
    number: "02",
    title: "Detailed Proposal",
    description: "You receive a clear, itemized proposal with no hidden costs. We walk you through every line item so you know exactly what you're paying for and why.",
    detail: "Transparent pricing",
  },
  {
    number: "03",
    title: "Material Selection",
    description: "Choose your shingles, color, and style from GAF's full product line. We'll show you samples, explain the differences, and help you pick what looks best on your home.",
    detail: "GAF Timberline HDZ & more",
  },
  {
    number: "04",
    title: "Scheduling",
    description: "We work around your schedule and weather. You'll know the exact start date, and we'll keep you updated if anything changes. No surprises.",
    detail: "Typically 1-2 weeks out",
  },
  {
    number: "05",
    title: "Installation",
    description: "Our professional crew arrives on time, protects your landscaping, installs to GAF specifications, and cleans up thoroughly. Most residential roofs are completed in 1-2 days.",
    detail: "1-2 day completion",
  },
  {
    number: "06",
    title: "Final Walkthrough",
    description: "We inspect the finished roof together. You approve the work before we consider the job complete. Then we register your GAF warranty and you're protected for decades.",
    detail: "Your sign-off required",
  },
];

const differentiators = [
  {
    title: "GAF Master Elite Certified",
    description: "Top 3% of roofers nationwide. This certification means better warranties, better materials, and better installation quality.",
  },
  {
    title: "Local Family Business",
    description: "Two offices in Christiansburg and Roanoke. We live in the community we serve. When a storm hits, we're already here.",
  },
  {
    title: "600+ Roofs Completed",
    description: "Experience matters. We've seen every roof type, every problem, and every situation in southwest Virginia's climate.",
  },
  {
    title: "No Subcontractors",
    description: "Our crews are our own. Every installer is trained, insured, and accountable to our quality standards.",
  },
];
---

<Layout
  title="Our Roofing Process | Step by Step | Modern Day Roofing"
  description="See exactly how Modern Day Roofing handles your project from free inspection to final walkthrough. Six clear steps, no surprises, no hidden costs."
>
  {/* Hero */}
  <section class="relative min-h-[40vh] flex items-center dark-section" data-transparent-header>
    <div class="absolute inset-0 z-0">
      <img
        src="/assets/team/ASP_6381-2.jpg"
        alt="Austin leading the Modern Day Roofing team"
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-bg-darker/95 via-bg-darker/85 to-bg-darker/50"></div>
    </div>
    <div class="relative z-10 mx-auto max-w-[1200px] px-4 md:px-6 py-16 md:py-24 w-full">
      <Breadcrumb items={breadcrumbItems} />
      <div class="mt-6 max-w-3xl">
        <p class="text-accent-light font-semibold text-sm uppercase tracking-wider mb-3">
          From Start to Finish
        </p>
        <h1 class="text-4xl md:text-5xl font-bold text-white">
          Our Roofing Process
        </h1>
        <p class="mt-4 text-lg text-white/85 max-w-2xl leading-relaxed">
          Six clear steps from inspection to completion. No surprises, no hidden costs, no pressure. Here's exactly what to expect.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          <Button href="/contact" size="lg">Start Your Project</Button>
          <Button href="tel:5405536007" variant="outline" size="lg" class="text-white border-white hover:bg-white hover:text-bg-dark">
            Call (540) 553-6007
          </Button>
        </div>
      </div>
    </div>
  </section>

  {/* Process Steps */}
  <SectionContainer background="white" padding="lg">
    <div class="text-center mb-16">
      <h2 class="text-2xl md:text-3xl font-display font-bold text-text-primary">
        Your Roofing Project in 6 Steps
      </h2>
      <p class="mt-3 text-text-muted max-w-xl mx-auto">
        Every project follows the same proven process. No shortcuts, no guesswork.
      </p>
    </div>
    <div class="max-w-4xl mx-auto space-y-8">
      {steps.map((step, i) => (
        <div class={`flex flex-col md:flex-row gap-6 items-start ${i % 2 === 1 ? 'md:flex-row-reverse' : ''}`}>
          <div class="flex-shrink-0 w-20 h-20 rounded-2xl bg-accent text-white flex items-center justify-center">
            <span class="text-2xl font-display font-bold">{step.number}</span>
          </div>
          <div class="flex-1 bg-bg-card border border-border rounded-xl p-6">
            <div class="flex items-center justify-between mb-2">
              <h3 class="text-xl font-display font-bold text-text-primary">{step.title}</h3>
              <span class="text-xs text-accent font-semibold bg-accent/10 px-3 py-1 rounded-full hidden sm:block">
                {step.detail}
              </span>
            </div>
            <p class="text-text-body text-sm leading-relaxed">{step.description}</p>
          </div>
        </div>
      ))}
    </div>
  </SectionContainer>

  {/* What Makes MDR Different */}
  <SectionContainer background="light" padding="md">
    <div class="text-center mb-12">
      <h2 class="text-2xl md:text-3xl font-display font-bold text-text-primary">
        What Makes Us Different
      </h2>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-4xl mx-auto">
      {differentiators.map((item) => (
        <div class="bg-bg-card border border-border rounded-xl p-6">
          <div class="flex items-start gap-3">
            <div class="w-10 h-10 rounded-full bg-accent/10 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-text-primary mb-1">{item.title}</h3>
              <p class="text-sm text-text-muted">{item.description}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </SectionContainer>

  {/* CTA + Form */}
  <SectionContainer background="white" padding="md">
    <div class="max-w-2xl mx-auto">
      <div class="text-center mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-text-primary">
          Start Your Project — Free Estimate
        </h2>
        <p class="mt-3 text-text-muted">
          Step one is a free, no-obligation inspection. Fill out the form and we'll be in touch within 24 hours.
        </p>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-6 md:p-8">
        <LeadCaptureForm client:load source="our-process" />
      </div>
    </div>
  </SectionContainer>
</Layout>
