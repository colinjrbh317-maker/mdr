---
import Layout from "@/layouts/Layout.astro";
import LeadCaptureFormMini from "@/components/forms/LeadCaptureFormMini";

export const prerender = true;

// Select 6 reviews for social proof
const reviews = [
  {
    name: "Shannon P.",
    initials: "SP",
    color: "bg-purple-700",
    city: "Christiansburg",
    quote: "Modern Day Roofing impressed us from our very first encounter. Professional, responsive, and delivered exactly what they promised.",
  },
  {
    name: "David G.",
    initials: "DG",
    color: "bg-blue-600",
    city: "Christiansburg",
    quote: "Efficient, reliable, and thorough. A fair price for a super roof replacement. From the initial inspection to the final cleanup, everything was top-notch.",
  },
  {
    name: "Amory L.",
    initials: "AL",
    color: "bg-orange-700",
    city: "Roanoke",
    quote: "I am a first time homeowner and they really made it easy to understand. They explained everything, the clean up was great, the crew was very respectful. 10/10 recommend.",
  },
  {
    name: "Sarah T.",
    initials: "ST",
    color: "bg-violet-500",
    city: "Blacksburg",
    quote: "Phenomenal. The pricing, service and installation. They are true professionals from start to finish. Our new roof looks amazing.",
  },
  {
    name: "Mike R.",
    initials: "MR",
    color: "bg-red-600",
    city: "Radford",
    quote: "Had lowest price for highest quality product, excellent job overall. Very courteous and professional. Went the extra mile.",
  },
  {
    name: "Noah L.",
    initials: "NL",
    color: "bg-slate-600",
    city: "Blacksburg",
    quote: "Very impressed with the professionalism from start to finish. The estimate was detailed, the crew was courteous, and they cleaned up everything.",
  },
];

const faqs = [
  {
    q: "What roofing services does the $500 discount apply to?",
    a: "The $500 off applies to any roofing service — roof replacement, repair, metal roofing, storm damage, gutters, siding, commercial roofing, and more. If it's on our services page, the discount applies.",
  },
  {
    q: "Is there a catch?",
    a: "No catch. Schedule your free inspection before May 31, 2026, and the $500 discount is applied to your project. No minimum purchase required beyond the cost of the service itself.",
  },
  {
    q: "How do I redeem the discount?",
    a: "Submit your info on this page or call us at (540) 553-6007 and mention the Spring 2026 Special. We'll schedule your free inspection and apply the discount to your quote.",
  },
  {
    q: "When does this offer expire?",
    a: "May 31, 2026. Your free inspection must be scheduled by this date to qualify for the $500 discount.",
  },
  {
    q: "What happens during the free inspection?",
    a: "One of our certified inspectors will examine your roof, document any issues with photos, and provide you with a detailed, no-obligation quote — usually within 24 hours of the inspection.",
  },
];
---

<Layout
  title="$500 Off Any Roofing Service | Spring 2026 Special"
  description="Save $500 on any roofing service from Modern Day Roofing. Schedule your free inspection before May 31, 2026. GAF Master Elite contractor serving Christiansburg, Roanoke & the New River Valley."
>

  <!-- HERO -->
  <section class="relative bg-bg-dark overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_50%,rgba(192,57,43,0.3),transparent_60%)]"></div>
    </div>

    <div class="relative mx-auto max-w-[1200px] px-4 md:px-6 py-16 md:py-24">
      <div class="grid lg:grid-cols-2 gap-12 items-center">

        <!-- Left: Offer Copy -->
        <div class="text-center lg:text-left">
          <span class="inline-block px-4 py-1.5 bg-accent text-white text-xs font-bold uppercase tracking-widest rounded-full mb-6">
            Spring 2026 Special
          </span>

          <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading font-extrabold text-white leading-[1.1] mb-4">
            $500 Off Any<br>Roofing Service
          </h1>

          <p class="text-lg text-white/70 mb-6 max-w-lg mx-auto lg:mx-0">
            Schedule your free inspection before May 31 and save. No hidden fees, no obligations — just honest roofing from Virginia's top-rated team.
          </p>

          <!-- Urgency -->
          <div class="inline-flex items-center gap-2 px-4 py-2 bg-accent/20 border border-accent/30 rounded-lg mb-8">
            <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="text-accent font-bold text-sm">Offer expires May 31, 2026</span>
          </div>

          <!-- Trust Badges (Mobile) -->
          <div class="flex flex-wrap items-center justify-center lg:justify-start gap-4 lg:hidden">
            <div class="flex items-center gap-1.5">
              <div class="flex gap-0.5">
                {[1,2,3,4,5].map(() => (
                  <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
              <span class="text-white/60 text-xs">231+ Reviews</span>
            </div>
            <span class="text-white/30">|</span>
            <span class="text-white/60 text-xs">GAF Master Elite</span>
            <span class="text-white/30">|</span>
            <span class="text-white/60 text-xs">BBB A+</span>
          </div>
        </div>

        <!-- Right: Lead Form Card -->
        <div class="relative">
          <div class="bg-white rounded-2xl shadow-2xl p-6 md:p-8 border-t-4 border-accent">
            <h2 class="text-xl font-bold text-text-primary mb-1 text-center">Claim Your $500 Discount</h2>
            <p class="text-sm text-text-muted mb-6 text-center">We'll call within 24 hours to schedule your free inspection.</p>

            <LeadCaptureFormMini client:load source="500-off-landing" ctaText="Claim My $500 Discount" />

            <div class="flex items-center justify-center gap-4 mt-4 text-[10px] text-text-dim">
              <span>Free Inspection</span>
              <span class="w-1 h-1 rounded-full bg-text-dim"></span>
              <span>No Obligation</span>
              <span class="w-1 h-1 rounded-full bg-text-dim"></span>
              <span>24hr Response</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <section class="bg-bg-light py-6 border-y border-border">
    <div class="mx-auto max-w-[1200px] px-4 md:px-6">
      <div class="flex flex-wrap items-center justify-center gap-8 md:gap-12">
        <div class="flex items-center gap-2">
          <span class="text-3xl font-bold text-text-primary">600+</span>
          <span class="text-sm text-text-muted">Roofs<br>Completed</span>
        </div>
        <div class="w-px h-10 bg-border hidden md:block"></div>
        <div class="flex items-center gap-2">
          <span class="text-3xl font-bold text-text-primary">231+</span>
          <span class="text-sm text-text-muted">Five-Star<br>Reviews</span>
        </div>
        <div class="w-px h-10 bg-border hidden md:block"></div>
        <div class="flex items-center gap-2">
          <span class="text-3xl font-bold text-text-primary">50yr</span>
          <span class="text-sm text-text-muted">GAF Golden<br>Pledge Warranty</span>
        </div>
        <div class="w-px h-10 bg-border hidden md:block"></div>
        <div class="flex items-center gap-2">
          <span class="text-3xl font-bold text-text-primary">Top 1%</span>
          <span class="text-sm text-text-muted">Contractor<br>in America</span>
        </div>
      </div>
    </div>
  </section>

  <!-- WHY MDR -->
  <section class="py-16 md:py-20 bg-white">
    <div class="mx-auto max-w-[1200px] px-4 md:px-6">
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-text-primary text-center mb-12">
        Why Homeowners Choose Modern Day Roofing
      </h2>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-bg-light rounded-xl p-6 text-center">
          <div class="w-12 h-12 rounded-full bg-accent/10 flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="font-bold text-text-primary mb-2">50-Year Warranty</h3>
          <p class="text-sm text-text-muted">GAF Golden Pledge — non-prorated, transferable. The strongest in the industry.</p>
        </div>

        <div class="bg-bg-light rounded-xl p-6 text-center">
          <div class="w-12 h-12 rounded-full bg-accent/10 flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="font-bold text-text-primary mb-2">$0 Down Financing</h3>
          <p class="text-sm text-text-muted">0% interest options. Soft credit check — no impact to your score.</p>
        </div>

        <div class="bg-bg-light rounded-xl p-6 text-center">
          <div class="w-12 h-12 rounded-full bg-accent/10 flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="font-bold text-text-primary mb-2">Local Expert Team</h3>
          <p class="text-sm text-text-muted">Based in Christiansburg & Roanoke. We know Virginia roofs inside and out.</p>
        </div>

        <div class="bg-bg-light rounded-xl p-6 text-center">
          <div class="w-12 h-12 rounded-full bg-accent/10 flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
            </svg>
          </div>
          <h3 class="font-bold text-text-primary mb-2">4.9-Star Rated</h3>
          <p class="text-sm text-text-muted">231+ verified Google reviews. See what our customers say below.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="py-16 md:py-20 bg-bg-light">
    <div class="mx-auto max-w-[1200px] px-4 md:px-6">
      <div class="text-center mb-10">
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-text-primary mb-3">
          What Our Customers Say
        </h2>
        <div class="flex items-center justify-center gap-2">
          <div class="flex gap-0.5">
            {[1,2,3,4,5].map(() => (
              <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <span class="text-text-muted text-sm font-medium">4.9 out of 5 — 231+ reviews on Google</span>
        </div>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
        {reviews.map((review) => (
          <div class="bg-white rounded-xl p-5 shadow-sm border border-border">
            <div class="flex items-center gap-3 mb-3">
              <div class={`w-9 h-9 rounded-full ${review.color} flex items-center justify-center text-white font-semibold text-xs flex-shrink-0`}>
                {review.initials}
              </div>
              <div>
                <p class="font-semibold text-text-primary text-sm">{review.name}</p>
                <p class="text-xs text-text-dim">{review.city}</p>
              </div>
              <svg class="w-5 h-5 flex-shrink-0 ml-auto" viewBox="0 0 24 24" fill="none">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
              </svg>
            </div>
            <div class="flex gap-0.5 mb-2">
              {[1,2,3,4,5].map(() => (
                <svg class="w-3.5 h-3.5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <p class="text-text-body text-sm leading-relaxed">{review.quote}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 md:py-20 bg-white">
    <div class="mx-auto max-w-[800px] px-4 md:px-6">
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-text-primary text-center mb-10">
        Frequently Asked Questions
      </h2>

      <div class="space-y-4">
        {faqs.map((faq, i) => (
          <details class="group bg-bg-light rounded-xl border border-border overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer list-none [&::-webkit-details-marker]:hidden">
              <span class="font-semibold text-text-primary text-sm pr-4">{faq.q}</span>
              <svg class="w-5 h-5 text-text-dim flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-4">
              <p class="text-sm text-text-muted leading-relaxed">{faq.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="py-16 md:py-20 bg-bg-dark">
    <div class="mx-auto max-w-[600px] px-4 md:px-6 text-center">
      <span class="inline-block px-3 py-1 bg-accent text-white text-xs font-bold uppercase tracking-wider rounded-full mb-4">
        Limited Time
      </span>
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-white mb-3">
        Don't Miss Out — $500 Off Ends May 31
      </h2>
      <p class="text-white/60 mb-8">
        Schedule your free inspection today. No obligation, no pressure — just honest roofing advice from Virginia's most certified team.
      </p>

      <div class="bg-white rounded-2xl p-6 md:p-8 shadow-2xl border-t-4 border-accent">
        <LeadCaptureFormMini client:load source="500-off-landing-bottom" ctaText="Claim My $500 Discount" />
      </div>

      <a href="tel:5405536007" class="inline-flex items-center gap-2 mt-6 text-white/60 hover:text-white text-sm transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        Or call (540) 553-6007
      </a>
    </div>
  </section>

</Layout>
