---
import Layout from "@/layouts/Layout.astro";
import SectionContainer from "@/components/ui/SectionContainer.astro";
import Card from "@/components/ui/Card.astro";
import Badge from "@/components/ui/Badge.astro";
import Breadcrumb from "@/components/common/Breadcrumb.astro";
import ImagePlaceholder from "@/components/common/ImagePlaceholder.astro";
import { loadQuery } from "@/sanity/lib/load-query";
import {
  ALL_BLOG_CATEGORY_SLUGS_QUERY,
  BLOG_POSTS_BY_CATEGORY_QUERY,
  BLOG_CATEGORIES_QUERY,
} from "@/sanity/lib/queries";
import { urlForImage } from "@/sanity/lib/url-for-image";

export const prerender = true;

export async function getStaticPaths() {
  const categories = await loadQuery<Array<{ slug: string }>>(ALL_BLOG_CATEGORY_SLUGS_QUERY);
  return categories.map((cat) => ({
    params: { slug: cat.slug },
  }));
}

const { slug } = Astro.params;

const [posts, allCategories] = await Promise.all([
  loadQuery<any[]>(BLOG_POSTS_BY_CATEGORY_QUERY, { categorySlug: slug }).catch(() => []),
  loadQuery<any[]>(BLOG_CATEGORIES_QUERY).catch(() => []),
]);

const category = allCategories.find((c: any) => c.slug === slug);

if (!category) {
  return Astro.redirect("/blog");
}

const breadcrumbItems = [
  { label: "Home", href: "/" },
  { label: "Blog", href: "/blog" },
  { label: category.title },
];

function formatDate(dateStr: string | undefined): string {
  if (!dateStr) return "";
  return new Date(dateStr).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<Layout
  title={`${category.title} | Blog | Modern Day Roofing`}
  description={category.description || `Read our latest articles about ${category.title.toLowerCase()} from Modern Day Roofing.`}
>
  <SectionContainer background="darker" padding="lg">
    <Breadcrumb items={breadcrumbItems} />
    <div class="mt-6 text-center max-w-3xl mx-auto">
      <p class="text-accent font-semibold text-sm uppercase tracking-wider mb-3">
        Education Hub
      </p>
      <h1 class="text-4xl md:text-5xl font-bold text-text-primary">
        {category.title}
      </h1>
      {category.description && (
        <p class="mt-4 text-text-muted max-w-2xl mx-auto">
          {category.description}
        </p>
      )}
    </div>
  </SectionContainer>

  {/* Category Navigation */}
  <SectionContainer background="dark" padding="sm">
    <div class="flex flex-wrap items-center justify-center gap-2">
      <a
        href="/blog"
        class="px-4 py-2 rounded-full text-sm font-medium border border-border text-text-muted hover:text-accent hover:border-accent transition-colors"
      >
        All Posts
      </a>
      {allCategories.map((cat: any) => (
        <a
          href={`/blog/category/${cat.slug}`}
          class:list={[
            "px-4 py-2 rounded-full text-sm font-medium transition-colors",
            cat.slug === slug
              ? "bg-accent text-white border border-accent"
              : "border border-border text-text-muted hover:text-accent hover:border-accent",
          ]}
        >
          {cat.title}
        </a>
      ))}
    </div>
  </SectionContainer>

  <SectionContainer background="dark" padding="md">
    {posts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map((post: any) => (
          <Card variant="default" href={`/blog/${post.slug}`}>
            <div class="mb-4">
              {post.featuredImage ? (
                <img
                  src={urlForImage(post.featuredImage).width(600).height(340).url()}
                  alt={post.title}
                  class="w-full rounded-lg object-cover"
                  style="aspect-ratio: 16/9;"
                  loading="lazy"
                />
              ) : (
                <ImagePlaceholder
                  description={`${post.title} featured image`}
                  aspectRatio="16/9"
                  class="w-full"
                />
              )}
            </div>
            <div class="flex items-center gap-2 mb-3">
              {post.category?.title && (
                <Badge variant="certification" text={post.category.title} />
              )}
              {post.publishedAt && (
                <span class="text-xs text-text-dim">
                  {formatDate(post.publishedAt)}
                </span>
              )}
            </div>
            <h2 class="text-lg font-semibold text-text-primary mb-2">
              {post.title}
            </h2>
          </Card>
        ))}
      </div>
    ) : (
      <div class="text-center py-16">
        <p class="text-text-dim">No posts in this category yet. Check back soon!</p>
        <a href="/blog" class="mt-4 inline-block text-accent hover:underline">
          View all posts
        </a>
      </div>
    )}
  </SectionContainer>
</Layout>
