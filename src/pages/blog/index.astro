---
import Layout from "@/layouts/Layout.astro";
import SectionContainer from "@/components/ui/SectionContainer.astro";
import Card from "@/components/ui/Card.astro";
import Badge from "@/components/ui/Badge.astro";
import ImagePlaceholder from "@/components/common/ImagePlaceholder.astro";
import BlogSearch from "@/components/blog/BlogSearch";
import Breadcrumb from "@/components/common/Breadcrumb.astro";
import { loadQuery } from "@/sanity/lib/load-query";
import { BLOG_POSTS_QUERY, BLOG_CATEGORIES_QUERY } from "@/sanity/lib/queries";
import { urlForImage } from "@/sanity/lib/url-for-image";
import ScrollReveal from "@/components/common/ScrollReveal.astro";

export const prerender = true;

const [posts, categories] = await Promise.all([
  loadQuery<any[]>(BLOG_POSTS_QUERY).catch(() => []),
  loadQuery<any[]>(BLOG_CATEGORIES_QUERY).catch(() => []),
]);

function formatDate(dateStr: string | undefined): string {
  if (!dateStr) return "";
  return new Date(dateStr).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}

const featuredPost = posts.length > 0 ? posts[0] : null;
const mediumPosts = posts.slice(1, 3);
const remainingPosts = posts.slice(3);

// Fallback images for blog posts without CMS photos — cycle through real project images
const blogFallbackImages = [
  "/assets/projects/dji_fly_20251105_160154_425_1762438973026_photo.JPG",
  "/assets/projects/Untitled-1800-x-1440-px.jpg",
  "/assets/projects/dji_fly_20250630_135406_726_1751306060507_photo.JPG",
  "/assets/projects/Untitled-1800-x-1440-px-2.jpg",
  "/assets/projects/dji_fly_20251105_160008_416_1762439005458_photo.JPG",
  "/assets/projects/Untitled-1800-x-1440-px-3.jpg",
];

function getPostImage(post: any, index: number): string {
  if (post.featuredImage) return urlForImage(post.featuredImage).width(800).height(500).url();
  return blogFallbackImages[index % blogFallbackImages.length];
}
---

<Layout
  title="Roofing Blog & Education Hub"
  description="Expert roofing advice, maintenance tips, and industry insights from Modern Day Roofing. Learn about roof repair, replacement, materials, and more."
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Roofing Blog & Education Hub",
    "description": "Expert roofing advice and industry insights from Modern Day Roofing.",
    "url": "https://moderndayroof.com/blog",
    "mainEntity": {
      "@type": "ItemList",
      "itemListElement": posts.map((p: any, i: number) => ({
        "@type": "ListItem",
        "position": i + 1,
        "url": `https://moderndayroof.com/blog/${p.slug}`,
        "name": p.title
      }))
    }
  })} />
  <section class="relative py-14 md:py-20 dark-section" data-transparent-header>
    <div class="absolute inset-0 z-0">
      <img
        src="/assets/projects/dji_fly_20250630_135554_733_1751306170083_photo.JPG"
        alt="Completed roofing project"
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-bg-darker/80"></div>
    </div>
    <div class="relative z-10 mx-auto max-w-[1200px] px-4 md:px-6">
    <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Blog" }]} />
    <div class="text-center mb-8 mt-6">
      <p class="text-accent-light font-semibold text-sm uppercase tracking-wider mb-3">
        Education Hub
      </p>
      <h1 class="text-4xl md:text-5xl font-bold text-white">
        Roofing Insights & Tips
      </h1>
      <p class="mt-4 text-white/80 max-w-2xl mx-auto">
        Expert advice on roof maintenance, repair, and replacement from the Modern Day Roofing team.
      </p>
    </div>

    {/* Search */}
    <div class="mb-8">
      <BlogSearch client:load posts={posts} />
    </div>

    {/* Category Links */}
    {categories.length > 0 && (
      <div class="flex flex-wrap items-center justify-center gap-2">
        <span class="px-4 py-2 rounded-full text-sm font-medium bg-accent text-white border border-accent">
          All Posts
        </span>
        {categories.map((cat: any) => (
          <a
            href={`/blog/category/${cat.slug}`}
            class="px-4 py-2 rounded-full text-sm font-medium border border-white/30 text-white/80 hover:text-white hover:border-white transition-colors no-underline"
          >
            {cat.title}
          </a>
        ))}
      </div>
    )}
    </div>
  </section>

  <SectionContainer background="white" padding="md">
    {posts.length > 0 ? (
      <div>
        {/* Featured post: full-width */}
        {featuredPost && (
          <ScrollReveal>
            <a href={`/blog/${featuredPost.slug}`} class="block no-underline mb-10">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-8 bg-bg-card border border-border rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition-shadow">
                <div class="aspect-[16/9] md:aspect-auto overflow-hidden">
                  <img
                    src={getPostImage(featuredPost, 0)}
                    alt={featuredPost.title}
                    class="w-full h-full object-cover"
                    loading="eager"
                  />
                </div>
                <div class="p-6 md:p-8 flex flex-col justify-center">
                  <div class="flex items-center gap-2 mb-3">
                    {featuredPost.category?.title && (
                      <Badge variant="certification" text={featuredPost.category.title} />
                    )}
                    {featuredPost.publishedAt && (
                      <span class="text-xs text-text-dim">
                        {formatDate(featuredPost.publishedAt)}
                      </span>
                    )}
                  </div>
                  <h2 class="text-2xl md:text-3xl font-bold text-text-primary mb-3">
                    {featuredPost.title}
                  </h2>
                  {featuredPost.excerpt && (
                    <p class="text-text-muted leading-relaxed">{featuredPost.excerpt}</p>
                  )}
                </div>
              </div>
            </a>
          </ScrollReveal>
        )}

        {/* Medium posts: 2-column */}
        {mediumPosts.length > 0 && (
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
            {mediumPosts.map((post: any, i: number) => (
              <ScrollReveal delay={i * 100}>
                <Card variant="default" href={`/blog/${post.slug}`}>
                  <div class="mb-4">
                    <img
                      src={getPostImage(post, i + 1)}
                      alt={post.title}
                      class="w-full rounded-lg object-cover"
                      style="aspect-ratio: 16/9;"
                      loading="lazy"
                    />
                  </div>
                  <div class="flex items-center gap-2 mb-3">
                    {post.category?.title && (
                      <Badge variant="certification" text={post.category.title} />
                    )}
                    {post.publishedAt && (
                      <span class="text-xs text-text-dim">
                        {formatDate(post.publishedAt)}
                      </span>
                    )}
                  </div>
                  <h2 class="text-lg font-semibold text-text-primary mb-2">
                    {post.title}
                  </h2>
                </Card>
              </ScrollReveal>
            ))}
          </div>
        )}

        {/* Remaining posts: 3-column */}
        {remainingPosts.length > 0 && (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {remainingPosts.map((post: any, i: number) => (
              <ScrollReveal delay={i * 80}>
                <Card variant="default" href={`/blog/${post.slug}`}>
                  <div class="mb-4">
                    <img
                      src={getPostImage(post, i + 3)}
                      alt={post.title}
                      class="w-full rounded-lg object-cover"
                      style="aspect-ratio: 16/9;"
                      loading="lazy"
                    />
                  </div>
                  <div class="flex items-center gap-2 mb-3">
                    {post.category?.title && (
                      <Badge variant="certification" text={post.category.title} />
                    )}
                    {post.publishedAt && (
                      <span class="text-xs text-text-dim">
                        {formatDate(post.publishedAt)}
                      </span>
                    )}
                  </div>
                  <h2 class="text-lg font-semibold text-text-primary mb-2">
                    {post.title}
                  </h2>
                </Card>
              </ScrollReveal>
            ))}
          </div>
        )}
      </div>
    ) : (
      <div class="text-center py-16">
        <p class="text-text-muted">No blog posts yet. Check back soon!</p>
      </div>
    )}
  </SectionContainer>

  {/* CTA after blog posts */}
  <SectionContainer background="accent" padding="md">
    <div class="text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-3">
        Have a Roofing Question?
      </h2>
      <p class="text-white/85 max-w-xl mx-auto mb-6">
        Our team is happy to answer your questions — no obligation, no pressure.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/contact" class="inline-flex items-center justify-center px-6 py-3 font-bold rounded-lg bg-white text-accent hover:bg-gray-100 shadow-sm transition-all text-sm">
          Get a Free Estimate
        </a>
        <a href="tel:5405536007" class="inline-flex items-center justify-center px-6 py-3 font-bold rounded-lg border-2 border-white text-white hover:bg-white/10 transition-all text-sm">
          Call (540) 553-6007
        </a>
      </div>
    </div>
  </SectionContainer>
</Layout>
