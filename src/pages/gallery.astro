---
import Layout from "@/layouts/Layout.astro";
import SectionContainer from "@/components/ui/SectionContainer.astro";
import Breadcrumb from "@/components/common/Breadcrumb.astro";
import Button from "@/components/ui/Button.astro";
import { loadQuery } from "@/sanity/lib/load-query";
import { BEFORE_AFTER_PROJECTS_QUERY } from "@/sanity/lib/queries";
import { urlForImage } from "@/sanity/lib/url-for-image";

export const prerender = true;

const breadcrumbItems = [
  { label: "Home", href: "/" },
  { label: "Gallery" },
];

const categories = [
  { label: "All", value: "all" },
  { label: "Shingle", value: "shingle" },
  { label: "Metal", value: "metal" },
  { label: "Repair", value: "repair" },
  { label: "Storm Damage", value: "storm-damage" },
  { label: "Gutters", value: "gutters" },
];

// Static gallery projects with categories. Real photos from Alicia's Drive (mdr-*) +
// drone aerials. Each item is unique to its category — click any photo to enlarge.
const galleryProjects = [
  // Shingle replacements (Alicia's labeled before/afters as headline finished shots)
  { src: "/assets/drive/mdr-after-heritage.jpg", title: "GAF Heritage Replacement — Complete", location: "Christiansburg, VA", category: "shingle" },
  { src: "/assets/drive/mdr-after-4plex.jpg", title: "Multi-Unit Roof Replacement", location: "New River Valley, VA", category: "shingle" },
  { src: "/assets/drive/mdr-after-terracotta.png", title: "Terracotta Tile Restoration", location: "Roanoke Area, VA", category: "shingle" },
  { src: "/assets/web/gallery-dji_fly_20251105_160154_425_1762438973026_photo.jpg", title: "Architectural Shingle Replacement", location: "Roanoke, VA", category: "shingle" },
  { src: "/assets/web/gallery-dji_fly_20250630_135332_722_1751306023542_photo.jpg", title: "New Roof — Residential", location: "Salem, VA", category: "shingle" },
  { src: "/assets/web/gallery-dji_fly_20250721_123356_135_1753115663863_photo.jpg", title: "Complete Roof System — Aerial", location: "Radford, VA", category: "shingle" },
  { src: "/assets/web/gallery-dji_fly_20251105_160244_430_1762438961614_photo.jpg", title: "Completed Roof — Aerial View", location: "Blacksburg, VA", category: "shingle" },
  { src: "/assets/web/gallery-img_6325.jpg", title: "Residential Roof — Street View", location: "Christiansburg, VA", category: "shingle" },
  { src: "/assets/web/gallery-img_6324.jpg", title: "Replacement — Complete", location: "Radford, VA", category: "shingle" },
  // Metal
  { src: "/assets/web/dji_fly_20250630_135406_726_1751306060507_photo.webp", title: "Standing Seam Metal Roof", location: "Christiansburg, VA", category: "metal" },
  { src: "/assets/web/gallery-dji_fly_20250711_160918_986_1752264568015_photo.jpg", title: "Metal Roofing — Farmhouse", location: "Floyd, VA", category: "metal" },
  { src: "/assets/web/gallery-dji_fly_20250711_170804_84_1752268097606_photo.jpg", title: "Standing Seam — Finished", location: "Roanoke, VA", category: "metal" },
  // Repair (Alicia's labeled repair photos)
  { src: "/assets/drive/mdr-repair-12.jpg", title: "Active Leak Repair", location: "Blacksburg, VA", category: "repair" },
  { src: "/assets/drive/mdr-repair-11.jpg", title: "Shingle Repair Detail", location: "Christiansburg, VA", category: "repair" },
  { src: "/assets/drive/mdr-repair-3tab.jpg", title: "3-Tab Repair", location: "Salem, VA", category: "repair" },
  { src: "/assets/drive/mdr-repair-13.jpg", title: "Valley Repair", location: "Radford, VA", category: "repair" },
  { src: "/assets/drive/mdr-repair-7.jpg", title: "Flashing Repair", location: "Roanoke, VA", category: "repair" },
  { src: "/assets/drive/mdr-repair-after.jpg", title: "Repair — Completed", location: "Smith Mountain Lake, VA", category: "repair" },
  // Storm damage
  { src: "/assets/drive/mdr-storm-damage-1.jpg", title: "Storm Damage Assessment", location: "New River Valley, VA", category: "storm-damage" },
  { src: "/assets/drive/mdr-storm-damage-2.jpg", title: "Wind Damage Repair", location: "Roanoke, VA", category: "storm-damage" },
  { src: "/assets/drive/mdr-storm-damage-tree.jpg", title: "Tree Impact — Emergency", location: "Christiansburg, VA", category: "storm-damage" },
  // Gutters (Alicia's labeled gutter photos)
  { src: "/assets/drive/mdr-gutters-1.jpg", title: "Seamless Gutter Install", location: "Christiansburg, VA", category: "gutters" },
  { src: "/assets/drive/mdr-gutters-2.jpg", title: "Gutter System — Complete", location: "Blacksburg, VA", category: "gutters" },
  { src: "/assets/drive/mdr-gutters-3.jpg", title: "Gutter Guard Installation", location: "Radford, VA", category: "gutters" },
];

// Before/after project pairs — real Alicia pairs
const beforeAfterProjects = [
  {
    title: "GAF Heritage Replacement — Before & After",
    location: "Christiansburg, VA",
    category: "shingle",
    before: "/assets/drive/mdr-before-heritage.jpg",
    after: "/assets/drive/mdr-after-heritage.jpg",
  },
  {
    title: "Multi-Unit Replacement — Before & After",
    location: "New River Valley, VA",
    category: "shingle",
    before: "/assets/drive/mdr-before-4plex.jpg",
    after: "/assets/drive/mdr-after-4plex.jpg",
  },
  {
    title: "Terracotta Tile Restoration — Before & After",
    location: "Roanoke Area, VA",
    category: "shingle",
    before: "/assets/drive/mdr-before-terracotta.png",
    after: "/assets/drive/mdr-after-terracotta.png",
  },
  {
    title: "Roof Repair — Before & After",
    location: "Southwest Virginia",
    category: "repair",
    before: "/assets/drive/mdr-repair-before.jpg",
    after: "/assets/drive/mdr-repair-after.jpg",
  },
];
---

<Layout
  title="Project Gallery | Before & After Roofing Projects"
  description="See the results of our roofing work. Browse before and after photos of roof replacements, repairs, metal roofing, and storm damage restoration in the New River Valley."
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ImageGallery",
    "name": "Project Gallery",
    "description": "Before and after photos of roofing projects in the New River Valley.",
    "url": "https://moderndayroof.com/gallery",
    "image": galleryProjects.map(p => ({
      "@type": "ImageObject",
      "contentUrl": `https://moderndayroof.com${p.src}`,
      "name": p.title,
      "description": `${p.title} — ${p.location}`
    }))
  })} />
  {/* Hero with background image */}
  <section class="relative py-16 md:py-24 dark-section" data-transparent-header>
    <div class="absolute inset-0 z-0">
      <img
        src="/assets/web/gallery-dji_fly_20250630_135454_730_1751306110963_photo.jpg"
        alt="Completed roofing project aerial view"
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-bg-darker/80"></div>
    </div>
    <div class="relative z-10 mx-auto max-w-[1200px] px-4 md:px-6">
      <Breadcrumb items={breadcrumbItems} />
      <div class="mt-6 text-center max-w-3xl mx-auto">
        <p class="text-accent-light font-semibold text-sm uppercase tracking-wider mb-3">
          Our Work
        </p>
        <h1 class="text-4xl md:text-5xl font-bold text-white">
          Project Gallery
        </h1>
        <p class="mt-4 text-lg text-white/80 max-w-2xl mx-auto">
          See the transformation. Browse completed roofing projects from across the New River Valley and Roanoke area.
        </p>
      </div>
    </div>
  </section>

  {/* Before & After Section */}
  <SectionContainer background="white" padding="md">
    <div class="text-center mb-10">
      <h2 class="text-2xl md:text-3xl font-bold text-text-primary">Before & After</h2>
      <p class="mt-2 text-text-muted">Real projects. Real transformations.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8 max-w-5xl mx-auto">
      {beforeAfterProjects.map((project) => (
        <div class="bg-bg-card border border-border rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition-shadow">
          <div class="grid grid-cols-2 gap-0">
            <button
              type="button"
              class="gallery-zoom relative block w-full text-left focus-visible:outline-2 focus-visible:outline-accent"
              data-src={project.before}
              data-title={`Before — ${project.title}`}
              aria-label={`Open larger view: Before — ${project.title}`}
            >
              <span class="absolute top-2 left-2 bg-black/70 text-white text-[10px] font-bold uppercase px-2 py-1 rounded z-10">Before</span>
              <img src={project.before} alt={`Before — ${project.title}`} class="w-full aspect-square object-cover hover:opacity-90 transition-opacity" loading="lazy" />
            </button>
            <button
              type="button"
              class="gallery-zoom relative block w-full text-left focus-visible:outline-2 focus-visible:outline-accent"
              data-src={project.after}
              data-title={`After — ${project.title}`}
              aria-label={`Open larger view: After — ${project.title}`}
            >
              <span class="absolute top-2 left-2 bg-accent text-white text-[10px] font-bold uppercase px-2 py-1 rounded z-10">After</span>
              <img src={project.after} alt={`After — ${project.title}`} class="w-full aspect-square object-cover hover:opacity-90 transition-opacity" loading="lazy" />
            </button>
          </div>
          <div class="p-4">
            <h3 class="font-semibold text-text-primary text-sm">{project.title}</h3>
            <p class="text-xs text-text-muted mt-1">{project.location}</p>
          </div>
        </div>
      ))}
    </div>
  </SectionContainer>

  {/* Project Gallery Grid */}
  <SectionContainer background="light" padding="md">
    <div class="text-center mb-8">
      <h2 class="text-2xl md:text-3xl font-bold text-text-primary">Completed Projects</h2>
      <p class="mt-2 text-text-muted">Browse our work by category</p>
    </div>

    {/* Category Filter */}
    <div class="flex overflow-x-auto gap-2 mb-10 pb-2 -mx-4 px-4 md:flex-wrap md:justify-center md:overflow-visible md:mx-0 md:px-0 scrollbar-hide" id="gallery-filters">
      {categories.map((cat) => (
        <button
          data-category={cat.value}
          class:list={[
            "gallery-filter px-5 py-2.5 rounded-full text-sm font-medium border transition-colors whitespace-nowrap flex-shrink-0",
            cat.value === "all"
              ? "bg-accent text-white border-accent"
              : "bg-white text-text-muted border-border hover:border-accent hover:text-text-primary",
          ]}
        >
          {cat.label}
        </button>
      ))}
    </div>

    {/* Card Grid */}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" id="gallery-grid">
      {galleryProjects.map((project) => (
        <button
          type="button"
          class="gallery-item gallery-zoom group text-left focus-visible:outline-2 focus-visible:outline-accent"
          data-category={project.category}
          data-src={project.src}
          data-title={project.title}
          aria-label={`Open larger view: ${project.title}`}
        >
          <div class="bg-white border border-border rounded-xl overflow-hidden transition-all hover:border-accent/40 hover:shadow-lg">
            <div class="relative aspect-[4/3] overflow-hidden">
              <img
                src={project.src}
                alt={project.title}
                class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                loading="lazy"
              />
              <span class="absolute top-3 left-3 bg-white/90 backdrop-blur-sm text-text-primary text-[11px] font-semibold uppercase tracking-wide px-3 py-1 rounded-full">
                {project.category === "storm-damage" ? "Storm Damage" : project.category.charAt(0).toUpperCase() + project.category.slice(1)}
              </span>
              <span class="absolute bottom-3 right-3 bg-black/60 text-white p-2 rounded-full opacity-0 group-hover:opacity-100 transition-opacity" aria-hidden="true">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zm-7-3v6m-3-3h6"/>
                </svg>
              </span>
            </div>
            <div class="p-4">
              <h3 class="font-semibold text-text-primary text-sm group-hover:text-accent transition-colors">{project.title}</h3>
              <p class="text-xs text-text-muted mt-1 flex items-center gap-1">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                {project.location}
              </p>
            </div>
          </div>
        </button>
      ))}
    </div>
  </SectionContainer>

  {/* Lightbox modal — shows enlarged image when any photo card is clicked */}
  <div
    id="gallery-lightbox"
    class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/90 p-4"
    role="dialog"
    aria-modal="true"
    aria-labelledby="lightbox-title"
  >
    <button
      type="button"
      id="lightbox-close"
      class="absolute top-4 right-4 z-10 bg-white/10 hover:bg-white/20 backdrop-blur-sm text-white p-3 rounded-full transition-colors"
      aria-label="Close (Esc)"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
    <figure class="max-w-[95vw] max-h-[90vh] flex flex-col items-center gap-3">
      <img id="lightbox-image" src="" alt="" class="max-w-full max-h-[80vh] object-contain rounded-lg shadow-2xl" />
      <figcaption id="lightbox-title" class="text-white text-sm md:text-base font-medium text-center"></figcaption>
    </figure>
  </div>

  {/* CTA */}
  <SectionContainer background="accent" padding="md">
    <div class="text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white">
        Your Home Could Be Next.
      </h2>
      <p class="mt-4 text-white/90 max-w-2xl mx-auto text-lg">
        Join 1,000+ Virginia homeowners who chose MDR. Get a free inspection and see what's possible.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 text-base font-bold rounded-lg bg-white text-accent hover:bg-gray-100 shadow-lg transition-all min-h-[52px]">
          Get Free Estimate
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        </a>
        <a href="tel:5405536007" class="inline-flex items-center justify-center px-8 py-4 text-base font-bold rounded-lg border-2 border-white text-white hover:bg-white/10 transition-all min-h-[52px]">
          Call (540) 553-6007
        </a>
      </div>
    </div>
  </SectionContainer>
</Layout>

<style>
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script>
  function initGallery() {
    const filters = document.querySelectorAll<HTMLButtonElement>(".gallery-filter");
    const items = document.querySelectorAll<HTMLElement>(".gallery-item");

    filters.forEach((btn) => {
      btn.addEventListener("click", () => {
        const category = btn.dataset.category;

        // Update active state
        filters.forEach((f) => {
          f.classList.remove("bg-accent", "text-white", "border-accent");
          f.classList.add("bg-white", "text-text-muted", "border-border");
        });
        btn.classList.remove("bg-white", "text-text-muted", "border-border");
        btn.classList.add("bg-accent", "text-white", "border-accent");

        // Filter items with fade
        items.forEach((item) => {
          if (category === "all" || item.dataset.category === category) {
            item.style.display = "";
          } else {
            item.style.display = "none";
          }
        });
      });
    });

    // --- Lightbox: click any .gallery-zoom (cards + before/after pairs) to enlarge ---
    const lightbox = document.getElementById("gallery-lightbox");
    const lightboxImg = document.getElementById("lightbox-image") as HTMLImageElement | null;
    const lightboxTitle = document.getElementById("lightbox-title");
    const closeBtn = document.getElementById("lightbox-close");

    function openLightbox(src: string, title: string) {
      if (!lightbox || !lightboxImg || !lightboxTitle) return;
      lightboxImg.src = src;
      lightboxImg.alt = title;
      lightboxTitle.textContent = title;
      lightbox.classList.remove("hidden");
      lightbox.classList.add("flex");
      document.body.style.overflow = "hidden";
    }
    function closeLightbox() {
      if (!lightbox || !lightboxImg) return;
      lightbox.classList.add("hidden");
      lightbox.classList.remove("flex");
      lightboxImg.src = "";
      document.body.style.overflow = "";
    }

    document.querySelectorAll<HTMLButtonElement>(".gallery-zoom").forEach((btn) => {
      btn.addEventListener("click", () => {
        const src = btn.dataset.src;
        const title = btn.dataset.title || "";
        if (src) openLightbox(src, title);
      });
    });

    closeBtn?.addEventListener("click", closeLightbox);
    lightbox?.addEventListener("click", (e) => {
      // Click on backdrop (outside the figure) closes
      if (e.target === lightbox) closeLightbox();
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && lightbox && !lightbox.classList.contains("hidden")) closeLightbox();
    });
  }

  initGallery();
  document.addEventListener("astro:after-swap", initGallery);
</script>
