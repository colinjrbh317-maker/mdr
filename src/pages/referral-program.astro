---
import Layout from "@/layouts/Layout.astro";
import SectionContainer from "@/components/ui/SectionContainer.astro";
import Button from "@/components/ui/Button.astro";
import Breadcrumb from "@/components/common/Breadcrumb.astro";
import LeadCaptureForm from "@/components/forms/LeadCaptureForm";

export const prerender = true;

const breadcrumbItems = [
  { label: "Home", href: "/" },
  { label: "Referral Program" },
];

const steps = [
  {
    number: "1",
    title: "Refer a Friend or Neighbor",
    description: "Know someone who needs a roof? Fill out the form below or call us with their name and number.",
  },
  {
    number: "2",
    title: "We Take Care of Them",
    description: "We'll reach out, schedule a free inspection, and give them the same quality service you received.",
  },
  {
    number: "3",
    title: "You Get Rewarded",
    description: "Once the project is complete, you receive your referral reward. It's that simple.",
  },
];

const testimonials = [
  {
    name: "Sarah M.",
    location: "Christiansburg, VA",
    text: "I referred my neighbor after they saw our new roof. We both ended up happy — great roof for them, great reward for me!",
  },
  {
    name: "James T.",
    location: "Roanoke, VA",
    text: "I've referred three families so far. MDR makes it easy and always follows through on the reward.",
  },
  {
    name: "Linda K.",
    location: "Blacksburg, VA",
    text: "My sister needed a new roof after the storm. I referred her to MDR and they took care of everything. Couldn't be happier.",
  },
];
---

<Layout
  title="Referral Program | Earn Rewards | Modern Day Roofing"
  description="Refer a friend to Modern Day Roofing and earn rewards. Our referral program rewards you for spreading the word about quality roofing in Virginia."
>
  {/* Hero */}
  <section class="relative min-h-[40vh] flex items-center dark-section" data-transparent-header>
    <div class="absolute inset-0 z-0">
      <img
        src="/assets/web/dji_fly_20250630_140410_766_1751306661861_photo.jpg"
        alt="Modern Day Roofing referral program"
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-bg-darker/95 via-bg-darker/85 to-bg-darker/50"></div>
    </div>
    <div class="relative z-10 mx-auto max-w-[1200px] px-4 md:px-6 py-16 md:py-24 w-full">
      <Breadcrumb items={breadcrumbItems} />
      <div class="mt-6 max-w-3xl">
        <p class="text-accent-light font-semibold text-sm uppercase tracking-wider mb-3">
          Referral Program
        </p>
        <h1 class="text-4xl md:text-5xl font-bold text-white">
          Refer a Friend, Earn Rewards
        </h1>
        <p class="mt-4 text-lg text-white/85 max-w-2xl leading-relaxed">
          Love your new roof? Share the experience. When you refer a friend and they complete a project with us, you get rewarded.
        </p>
        <div class="mt-8">
          <Button href="#referral-form" size="lg">Submit a Referral</Button>
        </div>
      </div>
    </div>
  </section>

  {/* How It Works */}
  <SectionContainer background="white" padding="lg">
    <div class="text-center mb-12">
      <h2 class="text-2xl md:text-3xl font-display font-bold text-text-primary">
        How It Works
      </h2>
      <p class="mt-3 text-text-muted max-w-xl mx-auto">
        Three simple steps to earn your referral reward.
      </p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
      {steps.map((step) => (
        <div class="text-center">
          <div class="w-14 h-14 mx-auto mb-4 rounded-full bg-accent text-white flex items-center justify-center text-xl font-bold">
            {step.number}
          </div>
          <h3 class="text-lg font-bold text-text-primary mb-2">{step.title}</h3>
          <p class="text-sm text-text-muted">{step.description}</p>
        </div>
      ))}
    </div>
  </SectionContainer>

  {/* What You Earn */}
  <SectionContainer background="light" padding="md">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-2xl md:text-3xl font-display font-bold text-text-primary mb-4">
        What You Earn
      </h2>
      <p class="text-text-body text-lg leading-relaxed mb-6">
        For every successful referral that leads to a completed roofing project, you'll receive a
        <strong class="text-accent"> cash reward</strong>. The exact amount depends on the project scope — but
        our past referrers have been very happy with the payout.
      </p>
      <div class="bg-bg-card border border-border rounded-xl p-8 inline-block">
        <p class="text-text-muted text-sm uppercase tracking-wider mb-2">Referral Reward</p>
        <p class="text-4xl font-display font-bold text-accent">$$$</p>
        <p class="text-text-muted text-sm mt-2">Per completed project</p>
      </div>
      <p class="text-sm text-text-muted mt-6">
        Call <a href="tel:5405536007" class="text-accent font-semibold hover:underline">(540) 553-6007</a> to ask about current reward amounts.
      </p>
    </div>
  </SectionContainer>

  {/* Testimonials from Referrers */}
  <SectionContainer background="white" padding="md">
    <div class="text-center mb-10">
      <h2 class="text-2xl md:text-3xl font-display font-bold text-text-primary">
        What Our Referrers Say
      </h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
      {testimonials.map((t) => (
        <div class="bg-bg-card border border-border rounded-xl p-6">
          <div class="flex items-center gap-1 mb-3">
            {Array.from({ length: 5 }).map(() => (
              <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="text-text-body text-sm leading-relaxed">"{t.text}"</p>
          <div class="mt-4 pt-3 border-t border-border">
            <p class="font-semibold text-text-primary text-sm">{t.name}</p>
            <p class="text-xs text-text-muted">{t.location}</p>
          </div>
        </div>
      ))}
    </div>
  </SectionContainer>

  {/* Referral Form */}
  <SectionContainer background="warm" padding="md" id="referral-form">
    <div class="max-w-2xl mx-auto">
      <div class="text-center mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-text-primary">
          Submit Your Referral Today
        </h2>
        <p class="mt-3 text-text-muted">
          Tell us who to contact and we'll take it from there. You'll be notified when the project is complete and your reward is ready.
        </p>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-6 md:p-8">
        <LeadCaptureForm client:load source="referral-program" />
      </div>
    </div>
  </SectionContainer>
</Layout>
