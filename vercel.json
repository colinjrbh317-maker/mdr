{
  "rewrites": [
    { "source": "/ingest/static/:path*", "destination": "https://us-assets.i.posthog.com/static/:path*" },
    { "source": "/ingest/:path*", "destination": "https://us.i.posthog.com/:path*" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=15768000; includeSubDomains" },
        { "key": "X-DNS-Prefetch-Control", "value": "on" }
      ]
    }
  ],
  "redirects": [
    { "source": "/lp", "destination": "https://lp.moderndayroof.com/branded", "permanent": true },
    { "source": "/lp/:campaign", "destination": "https://lp.moderndayroof.com/:campaign", "permanent": true },
    { "source": "/home/", "destination": "/", "permanent": true },
    { "source": "/contact-us/", "destination": "/contact", "permanent": true },
    { "source": "/services/", "destination": "/services", "permanent": true },
    { "source": "/roof-replacement/", "destination": "/services/roof-replacement", "permanent": true },
    { "source": "/roof-repair/", "destination": "/services/roof-repair", "permanent": true },
    { "source": "/roof-inspections-and-safety/", "destination": "/services/roof-inspection", "permanent": true },
    { "source": "/blog/", "destination": "/blog", "permanent": true },
    { "source": "/faqs/", "destination": "/faq", "permanent": true },
    { "source": "/local-roofing-services/", "destination": "/areas", "permanent": true },
    { "source": "/roanoke/", "destination": "/areas/roanoke", "permanent": true },
    { "source": "/radford/", "destination": "/areas/radford", "permanent": true },
    { "source": "/pulaski/", "destination": "/areas/pulaski", "permanent": true },
    { "source": "/christiansburg-roofing-company/", "destination": "/areas/christiansburg", "permanent": true },
    { "source": "/blacksburg-roofing-company/", "destination": "/areas/blacksburg", "permanent": true },
    { "source": "/salem-roofing-company/", "destination": "/areas/salem", "permanent": true },
    { "source": "/floyd-roofing-company/", "destination": "/areas/floyd", "permanent": true },
    { "source": "/wytheville-roofing-company/", "destination": "/areas/wytheville", "permanent": true },
    { "source": "/troutville-roofing-company/", "destination": "/areas/troutville", "permanent": true },
    { "source": "/smith-mountain-lake-roofing-company/", "destination": "/areas/smith-mountain-lake", "permanent": true },
    { "source": "/privacy-policy/", "destination": "/privacy", "permanent": true },
    { "source": "/terms-and-conditions/", "destination": "/terms", "permanent": true },
    { "source": "/sitemap/", "destination": "/sitemap-index.xml", "permanent": true },
    { "source": "/referral-program/", "destination": "/referral-program", "permanent": true },
    { "source": "/test-home/financing/", "destination": "/financing", "permanent": true },
    { "source": "/test-home/:path*", "destination": "/", "permanent": true },
    { "source": "/roofgiveaway2026/", "destination": "/", "permanent": true },
    { "source": "/custom-testimonial/:path*", "destination": "/", "permanent": true },
    { "source": "/roanokehomeandgardengiveaway/", "destination": "/", "permanent": true },
    { "source": "/feed/", "destination": "/", "permanent": true },
    { "source": "/comments/feed/", "destination": "/", "permanent": true },
    { "source": "/author/:path*", "destination": "/", "permanent": true },
    { "source": "/wp-json/:path*", "destination": "/", "permanent": true },
    { "source": "/testimonials/", "destination": "/reviews", "permanent": true },
    { "source": "/wp-login.php", "destination": "/", "permanent": true },
    { "source": "/wp-admin/:path*", "destination": "/", "permanent": true },
    { "source": "/wp-includes/:path*", "destination": "/", "permanent": true },
    { "source": "/wp-content/:path*", "destination": "/", "permanent": true },
    { "source": "/xmlrpc.php", "destination": "/", "permanent": true },
    { "source": "/:path*/page/:num(\\d+)", "destination": "/:path*", "permanent": true },
    { "source": "/category/:path*", "destination": "/blog", "permanent": true },
    { "source": "/tag/:path*", "destination": "/blog", "permanent": true }
  ]
}
